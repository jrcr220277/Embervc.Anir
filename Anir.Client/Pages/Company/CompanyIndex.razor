@page "/companies"
@using Anir.Shared.Contracts.Companies
@using Anir.Shared.Contracts.Common
@using Anir.Client.Services.Company
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="pa-2">

    @if (IsInitializingPage)
    {
        <UiLoading Indeterminate="true" Message="Cargando empresas..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }

    <!-- ============================================================
     ENCABEZADO PRINCIPAL
     ============================================================ -->
    <MudPaper Class="pa-2 mb-2">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <div class="d-flex align-center">
                    <!-- Icono grande -->
                    <MudIcon Icon="@Icons.Material.Filled.Domain" Color="Color.Primary" Size="Size.Large" />
                    <div class="ml-2">
                        <!-- Título -->
                        <MudText Typo="Typo.h5" Color="Color.Primary">Clasificador de Empresas</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Gestión de empresas: búsqueda, filtros y acciones masivas
                        </MudText>
                    </div>
                </div>
            </MudItem>
                       
        </MudGrid>
    </MudPaper>

    <!-- ============================================================
     ACTION BAR (Agregar, Buscar, Filtros)
     ============================================================ -->
    <MudPaper Class="pa-2 mb-2">
        <MudGrid AlignItems="Center">

            <!-- Botón Agregar -->
            <MudItem xs="12" md="3" Class="d-flex align-center">
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.AddCircleOutline"
                           OnClick="OpenAddModal">
                    Agregar
                </MudButton>
            </MudItem>

            <!-- Buscador -->
            <MudItem xs="12" md="6" Class="d-flex align-center justify-center">
                <MudTextField T="string"
                              Value="@SearchText"
                              ValueChanged="OnSearchInput"
                              Clearable="true"
                              Placeholder="Buscar..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Margin="Margin.Dense"
                              Class="mud-width-full search-box" />
            </MudItem>

            <!-- Filtro Estado -->
            <MudItem xs="12" md="3" Class="d-flex justify-end">
                <MudSelect T="string"
                           Placeholder="Estado"
                           Value="@StatusFilterValue"
                           ValueChanged="OnStatusFilterChanged"
                           Dense="true"
                           Class="filter-select">

                    <MudSelectItem Value=@("Todos")>Todos</MudSelectItem>
                    <MudSelectItem Value=@("Activo")>Activo</MudSelectItem>
                    <MudSelectItem Value=@("Inactivo")>Inactivo</MudSelectItem>
                </MudSelect>
            </MudItem>

        </MudGrid>
    </MudPaper>


    <!-- ============================================================
         ACCIONES MASIVAS (solo si hay selección o global)
         ============================================================ -->
    <MudCollapse Expanded="@(SelectedItems?.Any() == true || IsGlobalSelected)">
        <MudPaper Class="pa-3 mb-2 bulk-actions-bar" Elevation="1">

            <MudGrid AlignItems="Center">

                <!-- IZQUIERDA -->
                <MudItem xs="12" sm="6" Class="d-flex align-center">

                    <!-- Botón para activar selección global -->
                    <MudIconButton Icon="@(
                                                      IsGlobalSelected
                                                      ? Icons.Material.Filled.Close
                                                          : Icons.Material.Filled.SelectAll
                    )"
                               Color="Color.Primary"
                               OnClick="ToggleGlobalSelection"
                               Title="Seleccionar todos los elementos filtrados" />


<MudText Typo="Typo.subtitle2" Class="fw-bold ml-2">
                        @BulkSelectionText
                    </MudText>

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2">
                        Acciones masivas disponibles
                    </MudText>
                </MudItem>

                <!-- DERECHA -->
                <MudItem xs="12" sm="6" Class="d-flex justify-end">
                    <MudStack Row="true" Spacing="1">

                        <MudButton Color="Color.Error"
                                   Variant="Variant.Filled"
                                   StartIcon="@Icons.Material.Filled.DeleteForever"
                                   Disabled="@IsProcessingBulkAction"
                                   OnClick="DeleteSelected">
                            Eliminar
                        </MudButton>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.PictureAsPdf"
                                   OnClick="ExportPdf">
                            PDF
                        </MudButton>

                        <MudButton Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   StartIcon="@Icons.Material.Filled.GridOn"
                                   OnClick="ExportExcel">
                            Excel
                        </MudButton>

                    </MudStack>
                </MudItem>

            </MudGrid>
        </MudPaper>
    </MudCollapse>



    <!-- ============================================================
         TABLA PRINCIPAL (ServerData)
         ============================================================ -->
    <MudTable T="CompanyDto"
              ServerData="ServerReload"
              @ref="TableRef"
              Hover="true"
              Striped="true"
              Dense="true"
              MultiSelection="true"
              @bind-SelectedItems="SelectedItems"
              SelectOnRowClick="false"
              Loading="@IsLoadingTable"
              HorizontalScrollbar="true">

        <HeaderContent>
            <MudTh><MudTableSortLabel T="CompanyDto" SortLabel="ShortName">Abrev.</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="CompanyDto" SortLabel="Name">Nombre</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="CompanyDto" SortLabel="ProvinceName">Provincia</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="CompanyDto" SortLabel="MunicipalityName">Municipio</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="CompanyDto" SortLabel="Active">Estado</MudTableSortLabel></MudTh>
            <MudTh Style="text-align:end">Acciones</MudTh>
        </HeaderContent>

        <RowTemplate Context="company">
            <MudTd>@company.ShortName</MudTd>
            <MudTd>@company.Name</MudTd>
            <MudTd>@company.ProvinceName</MudTd>
            <MudTd>@company.MunicipalityName</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(company.Active ? Color.Success : Color.Error)" Size="Size.Small">
                    @(company.Active ? "Activa" : "Inactiva")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:end">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" OnClick="@(() => ViewCompany(company))" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" OnClick="@(() => EditCompany(company))" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteCompany(company))" Size="Size.Small" />
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="pa-4 text-center">
                No se encontraron datos para mostrar.
            </MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 5, 10, 15, 20, 50, 100 }"
                           RowsPerPageString="Filas por página:"
                           InfoFormat="{first_item}-{last_item} de {all_items}"
                           AllItemsText="Todas"
                           HorizontalAlignment="HorizontalAlignment.Right" />
        </PagerContent>

    </MudTable>

</MudContainer>


@code {
    // ============================================================
    // DEPENDENCIAS
    // ============================================================
    [Inject] private CompanyService CompanyService { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private IConfiguration Config { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [Inject] private ILogger<CompanyIndex> Logger { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;

    // ============================================================
    // ESTADO GENERAL
    // ============================================================
    private bool IsInitializingPage = true;
    private bool IsLoadingTable = false;
    private bool IsProcessingBulkAction = false;

    private MudTable<CompanyDto>? TableRef;
    private HashSet<CompanyDto> SelectedItems = new(new CompanyDtoComparer());

    private string SearchText = string.Empty;
    private string StatusFilterValue = "Todos";

    private IReadOnlyList<CompanyDto> LastPageItems = Array.Empty<CompanyDto>();

    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _serverReloadCts;

    // Flag para saber si está activa la selección global
    private bool IsGlobalSelected = false;

    protected override Task OnInitializedAsync()
    {
        IsInitializingPage = false;
        return Task.CompletedTask;
    }

    // ============================================================
    // SERVER DATA (Paginación + Orden + Filtros)
    // ============================================================
    private async Task<TableData<CompanyDto>> ServerReload(TableState state, CancellationToken token)
    {
        _serverReloadCts?.Cancel();
        _serverReloadCts = CancellationTokenSource.CreateLinkedTokenSource(token);
        var linkedToken = _serverReloadCts.Token;

        IsLoadingTable = true;

        try
        {
            var query = MapTableStateToQuery(state);

            var response = await CompanyService.GetPagedAsync(query, linkedToken);

            if (response.Result == ResponseStatus.Success && response.Value != null)
            {
                LastPageItems = response.Value.Items.ToList().AsReadOnly();

                return new TableData<CompanyDto>
                {
                    Items = response.Value.Items,
                    TotalItems = response.Value.TotalCount
                };
            }

            await AlertService.ShowError("Error", response.ErrorMessage ?? "Error cargando empresas");
            return new TableData<CompanyDto>();
        }
        finally
        {
            IsLoadingTable = false;
        }
    }

    private CompanyQueryDto MapTableStateToQuery(TableState state)
    {
        return new CompanyQueryDto
        {
            Page = state.Page + 1,
            Size = state.PageSize,
            Sort = state.SortLabel ?? "Name",
            Desc = state.SortDirection == SortDirection.Descending,
            Search = string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
            ActiveFilter = StatusFilterValue switch
            {
                "Activo" => true,
                "Inactivo" => false,
                _ => null
            }
        };
    }

    // ============================================================
    // BÚSQUEDA CON DEBOUNCE
    // ============================================================
    private void OnSearchInput(string value)
    {
        SearchText = value;

        _searchDebounceCts?.Cancel();
        _searchDebounceCts = new CancellationTokenSource();

        var token = _searchDebounceCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(300, token);
                if (!token.IsCancellationRequested && TableRef != null)
                    await TableRef.ReloadServerData();
            }
            catch { }
        });
    }

    // ============================================================
    // FILTRO DE ESTADO
    // ============================================================
    private async Task OnStatusFilterChanged(string value)
    {
        StatusFilterValue = value;
        if (TableRef != null) await TableRef.ReloadServerData();
    }

    // ============================================================
    // CRUD: MODALES
    // ============================================================
    private async Task OpenAddModal()
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = CompanyModal.ModalMode.Add,
            ["Company"] = null
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = false,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<CompanyModal>(
            "Nueva Empresa", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled && TableRef != null)
            await TableRef.ReloadServerData();
    }

    private async Task EditCompany(CompanyDto company)
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = CompanyModal.ModalMode.Edit,
            ["Company"] = company
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = false,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<CompanyModal>(
            "Editar Empresa", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled && TableRef != null)
            await TableRef.ReloadServerData();
    }

    private async Task ViewCompany(CompanyDto company)
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = CompanyModal.ModalMode.View,
            ["Company"] = company
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = true,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        await DialogService.ShowAsync<CompanyModal>(
            "Detalle Empresa", parameters, options);
    }
    
    // ============================================================
    // CRUD: ELIMINAR INDIVIDUAL
    // ============================================================
    private async Task DeleteCompany(CompanyDto company)
    {
        var confirmed = await AlertService.ShowConfirmation(
          "Eliminar Registro",
          $"¿Desea eliminar {company.ShortName}?");

        if (!confirmed) return;

        var response = await CompanyService.DeleteAsync(company.Id);

        if (response.Result == ResponseStatus.Success)
        {
            SelectedItems.RemoveWhere(c => c.Id == company.Id);
            if (TableRef != null) await TableRef.ReloadServerData();
            await AlertService.ShowSuccess("Éxito", "Empresa eliminada correctamente.");
        }
        else
        {
            await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
        }
    }

    // ============================================================
    // SELECCIÓN
    // ============================================================
    private void SelectAllVisible()
    {
        SelectedItems.Clear();
        foreach (var item in LastPageItems)
            SelectedItems.Add(item);
    }

    private void ToggleGlobalSelection()
    {
        IsGlobalSelected = !IsGlobalSelected;
        SelectedItems.Clear();
    }

    /// <summary>
    /// Texto dinámico para mostrar cantidad seleccionada.
    /// - Si es global: muestra el total de la tabla.
    /// - Si es local: muestra el conteo de SelectedItems.
    /// </summary>
    private string BulkSelectionText =>
    IsGlobalSelected
        ? "Seleccionando TODAS las empresas filtradas"
        : $"{SelectedItems.Count} seleccionada{(SelectedItems.Count == 1 ? "" : "s")}";

 
    // ============================================================
    // ACCIONES MASIVAS
    // ============================================================
    private async Task DeleteSelected()
    {
        var confirmed = await AlertService.ShowConfirmation(
            "Eliminar seleccionadas",
            IsGlobalSelected
                ? "¿Eliminar TODAS las empresas filtradas?"
                : $"¿Eliminar {SelectedItems.Count} empresas?"
        );

        if (!confirmed) return;

        IsProcessingBulkAction = true;

        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };

            var response = await CompanyService.DeleteBatchAsync(request);

            if (response.Result == ResponseStatus.Success)
            {
                SelectedItems.Clear();
                IsGlobalSelected = false;
                if (TableRef != null) await TableRef.ReloadServerData();
                await AlertService.ShowSuccess("Éxito", "Empresas eliminadas correctamente.");
            }
            else
            {
                await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
            }
        }
        finally
        {
            IsProcessingBulkAction = false;
        }
    }

    private async Task ExportPdf()
    {
        var request = new BulkSelectionRequest
        {
            SelectAll = IsGlobalSelected,
            Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
        };

        var response = await CompanyService.ExportPdfAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("openPdfBlob", bytes);
        }
        else
        {
            await AlertService.ShowError("Error", "No se pudo generar el PDF.");
        }
    }

    private async Task ExportExcel()
    {
        var request = new BulkSelectionRequest
        {
            SelectAll = IsGlobalSelected,
            Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
        };

        var response = await CompanyService.ExportExcelAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("downloadFile", "CompaniesReport.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
        }
        else
        {
            await AlertService.ShowError("Error", "No se pudo generar el Excel.");
        }
    }

    // ============================================================
    // LIMPIEZA DE RECURSOS
    // ============================================================
    public void Dispose()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _serverReloadCts?.Cancel();
        _serverReloadCts?.Dispose();
    }

    // ============================================================
    // COMPARER PARA SELECCIÓN ESTABLE
    // ============================================================
    private class CompanyDtoComparer : IEqualityComparer<CompanyDto>
    {
        public bool Equals(CompanyDto? x, CompanyDto? y) => x?.Id == y?.Id;
        public int GetHashCode(CompanyDto obj) => obj.Id.GetHashCode();
    }
}

    
