@using Anir.Client.Services
@using Anir.Client.Services.Company
@using Anir.Shared.Enums
@using MudBlazor
@using Anir.Shared.Contracts
@using Anir.Shared.Contracts.Companies

<MudDialog Style="width: 780px; max-width: 95vw;">

    <!-- ============================
         TÍTULO DEL MODAL
         ============================ -->
    <TitleContent>
        <MudStack Direction="Row" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@(CurrentMode == ModalMode.Add ? Icons.Material.Filled.AddCircle :
                                                      CurrentMode == ModalMode.Edit ? Icons.Material.Filled.Edit :
                                                      Icons.Material.Filled.Visibility)"
                     Size="Size.Medium" Color="Color.Primary" />

            <MudText Typo="Typo.h6">
                @(CurrentMode == ModalMode.Add ? "Crear Empresa" :
                  CurrentMode == ModalMode.Edit ? "Editar Empresa" :
                  "Detalle de la Empresa")
            </MudText>
        </MudStack>
    </TitleContent>

    <!-- ============================
         CONTENIDO DEL MODAL
         ============================ -->
    <DialogContent>

        @if (_isLoading)
        {
            <UiLoading Indeterminate="true" Message="Cargando..." Size="Size.Medium" />
        }
        else
        {
            <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmitAsync" id="form-entity">
                <DataAnnotationsValidator />

                <MudGrid Spacing="3">

                    <!-- ============================
                         COLUMNA IZQUIERDA: DATOS BÁSICOS
                         ============================ -->
                    <MudItem xs="12" md="8">
                        <MudPaper Elevation="1" Outlined="true" Rounded="true" Class="pa-4 mb-4">


                            <MudText Typo="Typo.subtitle1" Class="mb-3 font-weight-bold">
                                Detalles de la Empresa
                            </MudText>
                                                      

                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ShortName)"
                                          For="@(() => _formModel.ShortName)"
                                          @bind-Value="_formModel.ShortName"
                                          HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.ShortName)"
                                          HelperTextOnFocus="true"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Clearable="true"
                                          ReadOnly="@(IsViewMode)" />

                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Name)"
                                          For="@(() => _formModel.Name)"
                                          @bind-Value="_formModel.Name"
                                          HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.Name)"
                                          HelperTextOnFocus="true"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Clearable="true"
                                          ReadOnly="@(IsViewMode)" />

                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Address)"
                                          For="@(() => _formModel.Address)"
                                          @bind-Value="_formModel.Address"
                                          HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.Address)"
                                          HelperTextOnFocus="true"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Clearable="true"
                                          ReadOnly="@(IsViewMode)" />

                        </MudPaper>
                    </MudItem>

                    <!-- ============================
                         COLUMNA DERECHA: UBICACIÓN
                         ============================ -->
                    <MudItem xs="12" md="4">
                        <MudPaper Elevation="1" Outlined="true" Rounded="true" Class="pa-4 mb-4">

                            <MudText Typo="Typo.subtitle1" Class="mb-3 font-weight-bold">
                                Ubicación y Estado
                            </MudText>

                            <!-- PROVINCIA -->
                            <MudSelect T="int"
                                       Value="SelectedProvinceId"
                                       ValueChanged="OnProvinceChanged"
                                       Margin="Margin.Dense"
                                       FullWidth="true"
                                       Dense="true"
                                       Disabled="@(IsViewMode)">


                                <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>

                                @foreach (var item in AllProvinces)
                                {
                                    <MudSelectItem T="int" Value="@item.Id">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- MUNICIPIO -->
                            <MudSelect T="int?"
                                       Label="Municipio"
                                       @bind-Value="_formModel.MunicipalityId"
                                       Margin="Margin.Dense"
                                       FullWidth="true"
                                       Dense="true"
                                       Disabled="@(IsViewMode || SelectedProvinceId == 0)">

                                <MudSelectItem T="int?" Value="@((int?)null)">- Seleccionar -</MudSelectItem>

                                @foreach (var item in FilteredMunicipalities)
                                {
                                    <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                                }
                            </MudSelect>

                            <!-- ESTADO -->
                            <MudSwitch T="bool"
                                       @bind-Checked="_formModel.Active"
                                       Color="Color.Primary"
                                       Disabled="@(IsViewMode)"
                                       Class="mt-4"
                                       Label="@(_formModel.Active ? "Activo" : "Inactivo")" />

                        </MudPaper>
                    </MudItem>

                </MudGrid>
            </EditForm>
        }
    </DialogContent>

    <!-- ============================
         BOTONES DEL MODAL
         ============================ -->
    <DialogActions>
        

        @if (!IsViewMode)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       ButtonType="ButtonType.Submit"
                       Form="form-entity"
                       Disabled="@_isSaving">

                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" />
                }

                Guardar
            </MudButton>
        }
      
    </DialogActions>

</MudDialog>

@code {

    // ============================================================
    // INYECCIONES
    // ============================================================
    [Inject] private ProvinceService ProvinceService { get; set; } = default!;
    [Inject] private MunicipalityService MunicipalityService { get; set; } = default!;
    [Inject] private CompanyService CompanyService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    // ============================================================
    // PARÁMETROS DEL MODAL
    // ============================================================
    [Parameter] public ModalMode CurrentMode { get; set; }
    [Parameter] public CompanyDto? Company { get; set; }
    [Parameter] public EventCallback OnListUpdated { get; set; }

    public enum ModalMode { Add, Edit, View }

    // ============================================================
    // ESTADO INTERNO
    // ============================================================
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool IsViewMode => CurrentMode == ModalMode.View;

    // ============================================================
    // FORMULARIO
    // ============================================================
    private CompanyDto _formModel = new() { MunicipalityId = 0, Active = true };
    private EditContext? _editContext;

    // ============================================================
    // DATOS DE UBICACIÓN
    // ============================================================
    private List<ProvinceDto> AllProvinces = new();
    private List<MunicipalityDto> AllMunicipalities = new();
    private List<MunicipalityDto> FilteredMunicipalities = new();

    // Provincia seleccionada
    private int SelectedProvinceId;

    // ============================================================
    // CARGA INICIAL
    // ============================================================
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        AllProvinces = await ProvinceService.GetAllAsync() ?? new();
        AllMunicipalities = await MunicipalityService.GetAllAsync() ?? new();

        _isLoading = false;
    }

    // ============================================================
    // CARGA DE PARÁMETROS (EDITAR / VER)
    // ============================================================
    protected override void OnParametersSet()
    {
        if (Company != null)
        {
            _formModel = new CompanyDto
            {
                Id = Company.Id,
                ShortName = Company.ShortName,
                Name = Company.Name ?? string.Empty,
                Address = Company.Address ?? string.Empty,
                MunicipalityId = Company.MunicipalityId,
                Active = Company.Active
            };

            SelectedProvinceId = AllMunicipalities
                .FirstOrDefault(item => item.Id == _formModel.MunicipalityId)
                ?.ProvinceId ?? 0;
        }
        else
        {
            _formModel = new CompanyDto { Active = true, MunicipalityId = 0 };
            SelectedProvinceId = 0;
        }

        _editContext = new EditContext(_formModel);
        FilterMunicipalities();
    }

    // ============================================================
    // REFRESCAR LISTA DE MUNICIPIOS AL CARBIAR PROVINCIA
    // ============================================================
    private void OnProvinceChanged(int value)
    {
        SelectedProvinceId = value;   // ← breakpoint aquí
        FilterMunicipalities();       // ← breakpoint aquí
    }


    // ============================================================
    // FILTRAR MUNICIPIOS POR PROVINCIA
    // ============================================================
    private void FilterMunicipalities()
    {
        FilteredMunicipalities = AllMunicipalities
            .Where(item => item.ProvinceId == SelectedProvinceId)
            .OrderBy(item => item.Name)
            .ToList();

        if (!FilteredMunicipalities.Any(item => item.Id == _formModel.MunicipalityId))
            _formModel.MunicipalityId = null;

    }

    // ============================================================
    // GUARDAR
    // ============================================================
    private async Task HandleSubmitAsync()
    {
        if (_editContext == null || !_editContext.Validate())
            return;

        _isSaving = true;
        StateHasChanged();

        try
        {
            ProcessResponse<CompanyDto>? response = CurrentMode == ModalMode.Add
                ? await CompanyService.CreateAsync(_formModel)
                : await CompanyService.UpdateAsync(_formModel.Id, _formModel);

            if (response?.Result == ResponseStatus.Success)
            {
                await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
                await OnListUpdated.InvokeAsync();
                Dialog.Close(DialogResult.Ok(true));
            }
            else
            {
                await AlertService.ShowError("Error", response?.ErrorMessage ?? response?.PrettyMessage ?? "Error al guardar.");

            }
        }
        catch
        {
            await AlertService.ShowError("Error", "Error de conexión.");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }

}
