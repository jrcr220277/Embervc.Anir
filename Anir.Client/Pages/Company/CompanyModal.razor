@using Anir.Client.Services
@using Anir.Client.Services.Company
@using Anir.Shared.Enums
@using MudBlazor
@using Anir.Shared.Contracts
@using Anir.Shared.Contracts.Companies
@using System.ComponentModel.DataAnnotations

<MudDialog Elevation="24" Style="width: 780px; max-width: 95vw;">

    <!-- ============================
     TÍTULO DEL MODAL 
     ============================ -->
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">

           
                <MudIcon Icon="@(CurrentMode == ModalMode.Add ? Icons.Material.TwoTone.AddCircle
                                                                                              : CurrentMode == ModalMode.Edit
                                                                                                  ? Icons.Material.TwoTone.Edit
                                                                                                  : Icons.Material.TwoTone.Visibility)"
                         Size="Size.Large" />
          

            <MudStack Spacing="0">
                <MudText Typo="Typo.h6" Class="font-weight-medium">
                    @(CurrentMode == ModalMode.Add ? "Crear Empresa" :
                      CurrentMode == ModalMode.Edit ? "Editar Empresa" :
                      "Detalle de la Empresa")
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(CurrentMode == ModalMode.Add ? "Complete los datos para registrar una nueva empresa" :
                      CurrentMode == ModalMode.Edit ? "Modifique los datos de la empresa seleccionada" :
                      "Visualización de la información de la empresa")
                </MudText>
            </MudStack>

        </MudStack>
    </TitleContent>

    <!-- ============================
         CONTENIDO DEL MODAL
    ============================ -->
    <DialogContent>

        @if (_isLoading)
        {
            <UiLoading Indeterminate="true" Message="Cargando..." Size="Size.Medium" />
        }
        else
        {
            <EditForm Model="_formModel" OnValidSubmit="HandleSubmitAsync" id="form-entity">
                <DataAnnotationsValidator />

                <MudGrid Spacing="3">

                    <!-- DATOS BÁSICOS -->
                    <MudItem xs="12">
                        <MudPaper Elevation="1" Class="pa-3 rounded-lg" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Business" Color="Color.Default" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Datos básicos</MudText>
                            </MudStack>

                            <MudGrid Spacing="2">
                                <!-- Abreviatura -->
                                <MudItem xs="12" sm="4">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Abreviatura</MudText>
                                            <MudText Typo="Typo.body1">@_formModel.ShortName</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="Abreviatura"
                                                      @bind-Value="_formModel.ShortName"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true" />
                                    }
                                </MudItem>

                                <!-- Nombre -->
                                <MudItem xs="12" sm="8">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Nombre</MudText>
                                            <MudText Typo="Typo.body1">@_formModel.Name</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="Nombre"
                                                      @bind-Value="_formModel.Name"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true" />
                                    }
                                </MudItem>
                            </MudGrid>

                            <!-- Dirección -->
                            <MudItem xs="12">
                                @if (IsViewMode)
                                {
                                    <MudStack>
                                        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Dirección</MudText>
                                        <MudText Typo="Typo.body1">@_formModel.Address</MudText>
                                    </MudStack>
                                }
                                else
                                {
                                    <MudTextField Label="Dirección"
                                                  @bind-Value="_formModel.Address"
                                                  Variant="Variant.Outlined"
                                                  Required="true"
                                                  FullWidth="true"
                                                  Margin="Margin.Dense"
                                                  Clearable="true" />
                                }
                            </MudItem>
                        </MudPaper>
                    </MudItem>

                    <!-- UBICACIÓN -->
                    <MudItem xs="12">
                        <MudPaper Elevation="1" Class="pa-3 rounded-lg" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Color="Color.Default" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Ubicación</MudText>
                            </MudStack>

                            <MudGrid Spacing="2">
                                <!-- Provincia -->
                                <MudItem xs="12" sm="6">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Provincia</MudText>
                                            <MudText Typo="Typo.body1">
                                                @(AllProvinces.FirstOrDefault(p => p.Id == SelectedProvinceId)?.Name ?? "-")
                                            </MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudSelect T="int"
                                                   Label="Provincia"
                                                   Value="SelectedProvinceId"
                                                   ValueChanged="OnProvinceChanged"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   FullWidth="true"
                                                   Dense="true">
                                            <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                            @foreach (var item in AllProvinces)
                                            {
                                                <MudSelectItem T="int" Value="@item.Id">@item.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                </MudItem>

                                <!-- Municipio -->
                                <MudItem xs="12" sm="6">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Municipio</MudText>
                                            <MudText Typo="Typo.body1">
                                                @(FilteredMunicipalities.FirstOrDefault(m => m.Id == _formModel.MunicipalityId)?.Name ?? "-")
                                            </MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudSelect T="int?"
                                                   Label="Municipio"
                                                   @bind-Value="_formModel.MunicipalityId"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   FullWidth="true"
                                                   Dense="true">
                                            <MudSelectItem T="int?" Value="@((int?)null)">- Seleccionar -</MudSelectItem>
                                            @foreach (var item in FilteredMunicipalities)
                                            {
                                                <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>

                    <!-- ESTADO DE LA EMPRESA -->
                    <MudItem xs="12">
                        <MudPaper Class="pa-3" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Verified" Color="Color.Default" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Estado de la empresa</MudText>
                            </MudStack>

                            @if (IsViewMode)
                            {
                                <MudChip T="string"
                                         Color="@(_formModel.Active ? Color.Success : Color.Error)"
                                         Variant="Variant.Filled">
                                    @(_formModel.Active ? "Activo" : "Inactivo")
                                </MudChip>
                            }
                            else
                            {
                                <MudSwitch T="bool"
                                           @bind-Value="_formModel.Active"
                                           Color="Color.Primary"
                                           ThumbIcon="@(_formModel.Active ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                           ThumbIconColor="@(_formModel.Active ? Color.Success : Color.Default)"
                                           Label="@(_formModel.Active ? "Activo" : "Inactivo")" />
                            }
                        </MudPaper>
                    </MudItem>

                </MudGrid>
            </EditForm>
        }

    </DialogContent>




    <!-- ============================
         BOTONES
         ============================ -->
    <DialogActions>

        @if (!IsViewMode)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       ButtonType="ButtonType.Submit"
                       Form="form-entity"
                       Disabled="@_isSaving">

                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }

                @(CurrentMode == ModalMode.Add
                    ? "Crear"
                    : CurrentMode == ModalMode.Edit
                        ? "Actualizar"
                        : "Guardar")
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Size="Size.Medium"
                       OnClick="Close">
                Cerrar
            </MudButton>
        }

    </DialogActions>

</MudDialog>


@code {

    // ============================================================
    // INYECCIONES
    // ============================================================
    [Inject] private ProvinceService ProvinceService { get; set; } = default!;
    [Inject] private MunicipalityService MunicipalityService { get; set; } = default!;
    [Inject] private CompanyService CompanyService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    // ============================================================
    // PARÁMETROS
    // ============================================================
    [Parameter] public ModalMode CurrentMode { get; set; }
    [Parameter] public CompanyDto? Company { get; set; }
    [Parameter] public EventCallback OnListUpdated { get; set; }

    public enum ModalMode { Add, Edit, View }

    // ============================================================
    // ESTADO
    // ============================================================
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool IsViewMode => CurrentMode == ModalMode.View;

    // ============================================================
    // FORMULARIO
    // ============================================================
    private CompanyDto _formModel = new() { MunicipalityId = 0, Active = true };
    
    void Close()
    {
        Dialog.Close();
    }

    // ============================================================
    // UBICACIÓN
    // ============================================================
    private List<ProvinceDto> AllProvinces = new();
    private List<MunicipalityDto> AllMunicipalities = new();
    private List<MunicipalityDto> FilteredMunicipalities = new();

    private int SelectedProvinceId;

    // ============================================================
    // CARGA INICIAL
    // ============================================================
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        AllProvinces = await ProvinceService.GetAllAsync() ?? new();
        AllMunicipalities = await MunicipalityService.GetAllAsync() ?? new();

        // Cargar modelo AQUÍ (no en OnParametersSet)
        if (Company != null)
        {
            _formModel = new CompanyDto
            {
                Id = Company.Id,
                ShortName = Company.ShortName,
                Name = Company.Name ?? string.Empty,
                Address = Company.Address ?? string.Empty,
                MunicipalityId = Company.MunicipalityId,
                Active = Company.Active
            };

            SelectedProvinceId = AllMunicipalities
                .FirstOrDefault(item => item.Id == _formModel.MunicipalityId)
                ?.ProvinceId ?? 0;
        }
        else
        {
            _formModel = new CompanyDto { Active = true, MunicipalityId = 0 };
            SelectedProvinceId = 0;
        }

       
        FilterMunicipalities();

        _isLoading = false;
        StateHasChanged();
    }

   
    // ============================================================
    // CAMBIO DE PROVINCIA
    // ============================================================
    private void OnProvinceChanged(int value)
    {
        SelectedProvinceId = value;
        FilterMunicipalities();
    }

    // ============================================================
    // FILTRAR MUNICIPIOS
    // ============================================================
    private void FilterMunicipalities()
    {
        FilteredMunicipalities = AllMunicipalities
            .Where(item => item.ProvinceId == SelectedProvinceId)
            .OrderBy(item => item.Name)
            .ToList();

        if (!FilteredMunicipalities.Any(item => item.Id == _formModel.MunicipalityId))
            _formModel.MunicipalityId = null;
    }

    // ============================================================
    // GUARDAR
    // ============================================================
    private async Task HandleSubmitAsync()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            ProcessResponse<CompanyDto>? response;

            if (CurrentMode == ModalMode.Add)
            {
                response = await CompanyService.CreateAsync(_formModel);
            }
            else
            {
                response = await CompanyService.UpdateAsync(_formModel.Id, _formModel);
            }

            if (response?.Result == ResponseStatus.Success)
            {
                await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
                await OnListUpdated.InvokeAsync();
                Dialog.Close(DialogResult.Ok(true));
                return;
            }

            await AlertService.ShowError("Error", response?.ErrorMessage ?? response?.PrettyMessage ?? "Error al guardar.");
        }
        catch
        {
            await AlertService.ShowError("Error", "Error de conexión.");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }



}
