@page "/register"
@using Anir.Shared.Enums

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-2">
    <MudGrid Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudItem xs="12" sm="10" md="6" lg="5" Class="d-flex flex-column align-items-center">

            <div class="d-flex flex-column justify-center align-center mt-2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Large" />
                </MudAvatar>
                <MudText Typo="Typo.h5" Class="font-weight-bold">Crear cuenta</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-n1">
                    Complete los datos para registrarse
                </MudText>
            </div>

            <MudCard Outlined="true" Class="pa-6 mt-4">
                <MudCardContent>

                    <MudGrid Justify="Justify.FlexStart" Class="mb-2">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoLogin" Title="Ir al Login" />
                    </MudGrid>

                    <EditForm EditContext="_editContext" OnValidSubmit="HandleRegisterAsync">
                        <DataAnnotationsValidator />
                        <MudStack Spacing="2">
                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.FullName)"
                                          For="@(() => _formModel.FullName)"
                                          @bind-Value="_formModel.FullName"
                                          HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.FullName)"
                                          HelperTextOnFocus="true"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Clearable="true" />

                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Email)"
                                          For="@(() => _formModel.Email)"
                                          @bind-Value="_formModel.Email"
                                          InputType="InputType.Email"
                                          HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.Email)"
                                          HelperTextOnFocus="true"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                          Clearable="true" />

                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Password)"
                                          For="@(() => _formModel.Password)"
                                          @bind-Value="_formModel.Password"
                                          InputType="@(showPassword ? InputType.Text : InputType.Password)"
                                          HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.Password)"
                                          HelperTextOnFocus="true"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="TogglePasswordVisibility"
                                          Clearable="true" />

                            @* CORREGIDO: Agregado toggle de visibilidad + adornment para alinear con el campo anterior *@
                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ConfirmPassword)"
                                          For="@(() => _formModel.ConfirmPassword)"
                                          @bind-Value="_formModel.ConfirmPassword"
                                          InputType="@(showConfirm ? InputType.Text : InputType.Password)"
                                          HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.ConfirmPassword)"
                                          HelperTextOnFocus="true"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          FullWidth="true"
                                          Margin="Margin.Dense"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="ToggleConfirmVisibility"
                                          Clearable="true" />

                            <MudButton Loading="@isSaving"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       ButtonType="ButtonType.Submit">
                                Registrarse
                            </MudButton>
                        </MudStack>
                    </EditForm>

                </MudCardContent>
            </MudCard>

            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-4 d-flex justify-center align-center">
                ¿Ya tienes cuenta?
                <MudLink OnClick="GoLogin" Color="Color.Secondary" Class="ml-2 d-flex align-center" Typo="Typo.body2">
                    Inicia sesión
                </MudLink>
            </MudText>

        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IAlertService Alerts { get; set; } = default!;

    private RegisterRequest _formModel = new();
    private EditContext? _editContext;
    private bool isSaving = false;
    private bool showPassword = false;
    private bool showConfirm = false; // CORREGIDO: variable nueva

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_formModel);
    }

    private void TogglePasswordVisibility() => showPassword = !showPassword;
    private void ToggleConfirmVisibility() => showConfirm = !showConfirm; // CORREGIDO: toggle nuevo
    private void GoLogin() => Nav.NavigateTo("/login");

    private async Task HandleRegisterAsync()
    {
        if (_editContext == null || !_editContext.Validate()) return;

        isSaving = true;
        var result = await AuthService.RegisterAsync(_formModel);

        if (result.Result == ResponseStatus.Failed)
        {
            var msg = result.PrettyMessage ?? result.ErrorMessage ?? "No se pudo completar el registro.";
            await Alerts.ShowError("Error", msg);
            isSaving = false;
            return;
        }

        await Alerts.ShowSuccess("Registro exitoso", result.PrettyMessage ?? "Revise su correo para confirmar su cuenta.");
        Nav.NavigateTo("/login");
        isSaving = false;
    }
}