@page "/reset-password"
@using Anir.Shared.Enums

@inject NavigationManager Nav
@inject IAuthService AuthService
@inject IAlertService Alerts

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-2">
    <MudGrid Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudItem xs="12" sm="10" md="6" lg="5" Class="d-flex flex-column align-items-center">

            <div class="d-flex flex-column justify-center align-center mt-2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" />
                </MudAvatar>
                <MudText Typo="Typo.h5" Class="font-weight-bold">Restablecer contraseña</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-n1">
                    Introduzca su nueva contraseña
                </MudText>
            </div>

            <MudCard Outlined="true" Class="pa-6 mt-4">
                <MudCardContent>

                    @if (isLoading)
                    {
                        <div class="d-flex justify-center align-center" style="min-height: 200px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                        </div>
                    }
                    else if (invalidLink)
                    {
                        <MudText Typo="Typo.h6" Color="Color.Error">Enlace inválido o expirado.</MudText>
                    }
                    else
                    {
                        <EditForm EditContext="_editContext" OnValidSubmit="HandleResetAsync">
                            <DataAnnotationsValidator />
                            <MudStack Spacing="2">

                                @* CORREGIDO: Agregado toggle de visibilidad *@
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => model.NewPassword)"
                                              For="@(() => model.NewPassword)"
                                              @bind-Value="model.NewPassword"
                                              InputType="@(showPassword ? InputType.Text : InputType.Password)"
                                              HelperText="@ModelMetadataHelper.GetHelperText(() => model.NewPassword)"
                                              HelperTextOnFocus="true"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              FullWidth="true"
                                              Margin="Margin.Dense"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="TogglePasswordVisibility"
                                              Clearable="true" />

                                @* CORREGIDO: Agregado toggle de visibilidad *@
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => model.ConfirmPassword)"
                                              For="@(() => model.ConfirmPassword)"
                                              @bind-Value="model.ConfirmPassword"
                                              InputType="@(showConfirm ? InputType.Text : InputType.Password)"
                                              HelperText="@ModelMetadataHelper.GetHelperText(() => model.ConfirmPassword)"
                                              HelperTextOnFocus="true"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              FullWidth="true"
                                              Margin="Margin.Dense"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="ToggleConfirmVisibility"
                                              Clearable="true" />

                                <MudButton Loading="@isSaving"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           ButtonType="ButtonType.Submit">
                                    Restablecer contraseña
                                </MudButton>

                            </MudStack>
                        </EditForm>
                    }

                </MudCardContent>
            </MudCard>

        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private bool isLoading = true;
    private bool invalidLink = false;
    private bool isSaving = false;
    private bool showPassword = false;  // CORREGIDO: nueva
    private bool showConfirm = false;  // CORREGIDO: nueva

    private ResetPasswordRequest model = new();
    private EditContext? _editContext;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var email = query["email"];
        var token = query["token"];

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(token))
        {
            invalidLink = true;
            isLoading = false;
            return;
        }

        model.Email = email;
        model.Token = token;
        _editContext = new EditContext(model);
        isLoading = false;
    }

    private void TogglePasswordVisibility() => showPassword = !showPassword;
    private void ToggleConfirmVisibility() => showConfirm = !showConfirm;

    private async Task HandleResetAsync()
    {
        if (_editContext == null || !_editContext.Validate()) return;

        if (model.NewPassword != model.ConfirmPassword)
        {
            await Alerts.ShowError("Error", "Las contraseñas no coinciden.");
            return;
        }

        isSaving = true;
        var result = await AuthService.ResetPasswordAsync(model);

        if (result.Result == ResponseStatus.Failed)
        {
            var msg = result.PrettyMessage ?? result.ErrorMessage ?? "No se pudo restablecer la contraseña.";
            await Alerts.ShowError("Error", msg);
            isSaving = false;
            return;
        }

        await Alerts.ShowSuccess("Contraseña restablecida", result.PrettyMessage ?? "Tu contraseña fue actualizada correctamente.");
        await Task.Delay(500);
        Nav.NavigateTo("/login");
        isSaving = false;
    }
}