@page "/account/profile"

@using Anir.Shared.Contracts.User
@using Anir.Shared.Contracts.Auth
@using Anir.Shared.Contracts.Common
@using Anir.Client.Components
@using Anir.Shared.Enums
@using Anir.Client.Components.File

@inject NavigationManager Nav
@inject IAuthService AuthService
@inject IAlertService Alerts
@inject UserState UserState

@* CORREGIDO: MaxWidth.Medium porque el perfil tiene más ancho (grid 3+9) *@
<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-2">
    <MudGrid Justify="Justify.Center" AlignItems="AlignItems.Center">
        <MudItem xs="12" sm="10" md="10" lg="10" Class="d-flex flex-column align-items-center">

            <div class="d-flex flex-column justify-center align-center mt-2">
                <MudAvatar Size="Size.Large" Color="Color.Primary" Variant="Variant.Filled">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Size="Size.Large" />
                </MudAvatar>
                <MudText Typo="Typo.h5" Class="font-weight-bold">Mi Perfil</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Actualice su información personal</MudText>
            </div>

            <EditForm EditContext="_editContext" OnValidSubmit="HandleSaveAsync">
                <DataAnnotationsValidator />

                <MudCard Outlined="true" Class="pa-6 mt-4">
                    <MudCardContent>

                        @if (isLoading)
                        {
                            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 220px;">
                                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                            </MudStack>
                        }
                        else
                        {
                            <MudGrid Spacing="3">
                                <MudItem xs="12" md="3">
                                    <MudStack Spacing="2" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="font-weight-bold">Foto de Perfil</MudText>
                                        <PhotoUploader Value="@(_formModel.ImageFile?.Url)"
                                                       IsProfile="true"
                                                       PixelSize="150"
                                                       OnUploaded="HandleImageUploaded" />
                                    </MudStack>
                                </MudItem>

                                <MudItem xs="12" md="9">
                                    <MudStack Spacing="2">
                                        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="font-weight-bold">Datos personales</MudText>

                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.FullName)"
                                                      For="@(() => _formModel.FullName)"
                                                      @bind-Value="_formModel.FullName"
                                                      HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.FullName)"
                                                      HelperTextOnFocus="true"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true" />

                                        <MudText Typo="Typo.subtitle1" Color="Color.Secondary" Class="font-weight-bold">Preferencias</MudText>

                                        @* CAMBIO: MudToggleGroup en lugar de MudChipSet *@
                                        <MudToggleGroup T="ThemeMode"
                                                        @bind-SelectedValue="_formModel.ThemeMode"
                                                        Color="Color.Primary"
                                                        Variant="Variant.Outlined"
                                                        Size="Size.Large"
                                                        Rounded="true">
                                            <MudToggleItem Value="@ThemeMode.Light" Icon="@Icons.Material.Filled.LightMode" Text="Claro" />
                                            <MudToggleItem Value="@ThemeMode.Dark" Icon="@Icons.Material.Filled.DarkMode" Text="Oscuro" />
                                            <MudToggleItem Value="@ThemeMode.Auto" Icon="@Icons.Material.Filled.Brightness4" Text="Auto" />
                                        </MudToggleGroup>
                                    </MudStack>
                                </MudItem>
                            </MudGrid>
                        }

                    </MudCardContent>

                    <MudCardActions Class="justify-end mt-2">
                        <MudButton Loading="@isSaving"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   ButtonType="ButtonType.Submit">
                            Guardar cambios
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </EditForm>

        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private UpdateProfileRequest _formModel = new();
    private EditContext? _editContext;
    private bool isSaving = false;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(UserState.Id))
        {
            var result = await AuthService.MeAsync();
            if (result.Result == ResponseStatus.Failed || result.Value == null)
            {
                Nav.NavigateTo("/login", true);
                return;
            }
            UserState.Set(result.Value);
        }

        _formModel.FullName = UserState.FullName ?? "";
        _formModel.ThemeMode = UserState.ThemeMode;
        _formModel.ImageFile = UserState.ImageFile;
        _editContext = new EditContext(_formModel);
        isLoading = false;
    }

    private Task HandleImageUploaded(FileResponse? file)
    {
        _formModel.ImageFile = file;
        return Task.CompletedTask;
    }

    private async Task HandleSaveAsync()
    {
        if (_editContext == null || !_editContext.Validate()) return;

        isSaving = true;
        try
        {
            var result = await AuthService.UpdateProfileAsync(_formModel);

            if (result.Result == ResponseStatus.Failed)
            {
                var msg = result.PrettyMessage ?? result.ErrorMessage ?? "No se pudo actualizar el perfil.";
                await Alerts.ShowError("Error", msg);
                return;
            }

            await Alerts.ShowSuccess("Perfil actualizado", result.PrettyMessage ?? "Los cambios se guardaron correctamente.");

            var me = await AuthService.MeAsync();
            if (me.Result == ResponseStatus.Success && me.Value != null)
            {
                UserState.Set(me.Value);
                _formModel.FullName = me.Value.FullName ?? _formModel.FullName;
                _formModel.ThemeMode = me.Value.ThemeMode;
                _formModel.ImageFile = me.Value.ImageFile;
                _editContext.NotifyValidationStateChanged();
            }
        }
        catch (Exception ex)
        {
            await Alerts.ShowError("Error", $"Error guardando perfil: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }
}