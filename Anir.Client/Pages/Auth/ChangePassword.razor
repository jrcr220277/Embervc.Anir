@page "/change-password"
@using Anir.Shared.Enums
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-2">
    <MudGrid Justify="Justify.Center" AlignItems="Center">
        <MudItem xs="12" sm="10" md="6" lg="5" Class="d-flex flex-column align-items-center">

            <!-- Encabezado -->
            <div class="d-flex flex-column justify-center align-center mb-2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" />
                </MudAvatar>

                <MudText Typo="Typo.h5" Class="font-weight-bold">Cambiar contraseña</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-n1">
                    Introduce tu contraseña actual y la nueva contraseña
                </MudText>
            </div>

            <!-- Card -->
            <MudCard Class="pa-6 mt-4" Elevation="2">
                <MudCardContent>

                    @if (isLoading)
                    {
                        <div class="d-flex justify-center align-center" style="min-height:220px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                        </div>
                    }
                    else
                    {
                        <EditForm EditContext="_editContext" OnValidSubmit="HandleChangePasswordAsync">
                            <DataAnnotationsValidator />

                            <MudStack Spacing="2">

                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.CurrentPassword)"
                                              For="@(() => _formModel.CurrentPassword)"
                                              @bind-Value="_formModel.CurrentPassword"
                                              InputType="@(showCurrent? InputType.Text: InputType.Password)"
                                              HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.CurrentPassword)"
                                              HelperTextOnFocus="true"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              FullWidth="true"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(showCurrent? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="ToggleCurrentVisibility"
                                              Clearable="true" />

                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.NewPassword)"
                                              For="@(() => _formModel.NewPassword)"
                                              @bind-Value="_formModel.NewPassword"
                                              InputType="@(showNew? InputType.Text: InputType.Password)"
                                              HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.NewPassword)"
                                              HelperTextOnFocus="true"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              FullWidth="true"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(showNew? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="ToggleNewVisibility"
                                              Clearable="true" />

                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ConfirmPassword)"
                                              For="@(() => _formModel.ConfirmPassword)"
                                              @bind-Value="_formModel.ConfirmPassword"
                                              InputType="@(showConfirm? InputType.Text: InputType.Password)"
                                              HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.ConfirmPassword)"
                                              HelperTextOnFocus="true"
                                              Variant="Variant.Outlined"
                                              Required="true"
                                              FullWidth="true"
                                              Adornment="Adornment.End"
                                              AdornmentIcon="@(showConfirm? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                              OnAdornmentClick="ToggleConfirmVisibility"
                                              Clearable="true" />

                                <MudButton Loading="@isSaving"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           ButtonType="ButtonType.Submit">
                                    Cambiar contraseña
                                </MudButton>

                                <MudButton Variant="Variant.Text"
                                           Color="Color.Secondary"
                                           OnClick="GoBack">
                                    Cancelar
                                </MudButton>

                            </MudStack>
                        </EditForm>
                    }

                </MudCardContent>
            </MudCard>

        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IAlertService Alerts { get; set; } = default!;

    private ChangePasswordRequest _formModel = new();
    private EditContext? _editContext;

    private bool isSaving = false;
    private bool isLoading = false;

    private bool showCurrent = false;
    private bool showNew = false;
    private bool showConfirm = false;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_formModel);
    }

    private void ToggleCurrentVisibility() => showCurrent = !showCurrent;
    private void ToggleNewVisibility() => showNew = !showNew;
    private void ToggleConfirmVisibility() => showConfirm = !showConfirm;

    private void GoBack() => Nav.NavigateTo("/dashboard");

    private async Task HandleChangePasswordAsync()
    {
        if (_editContext == null || !_editContext.Validate())
            return;

        if (_formModel.NewPassword != _formModel.ConfirmPassword)
        {
            await Alerts.ShowError("Error", "La nueva contraseña y la confirmación no coinciden.");
            return;
        }

        isSaving = true;
        isLoading = true;

        var result = await AuthService.ChangePasswordAsync(_formModel);

        // ❌ Si falló → mostramos mensaje del backend
        if (result.Result == ResponseStatus.Failed)
        {
            var msg = result.PrettyMessage
                      ?? result.ErrorMessage
                      ?? "No se pudo cambiar la contraseña.";

            await Alerts.ShowError("Error", msg);

            isSaving = false;
            isLoading = false;
            return;
        }

        // ✔ Si todo OK → mensaje del backend o uno por defecto
        await Alerts.ShowSuccess(
            "Listo",
            result.PrettyMessage ?? "Contraseña actualizada correctamente."
        );

        Nav.NavigateTo("/dashboard");

        isSaving = false;
        isLoading = false;
    }

}
