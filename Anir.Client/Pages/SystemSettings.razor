@page "/system/settings"
@attribute [Authorize]

@inject SystemSettingService SettingService
@inject IAlertService Alerts

<PageTitle>Configuración del Sistema</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-3">

    @if (_isLoading)
    {
        <UiLoading Indeterminate="true" Message="Cargando configuración..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }

    <!-- ╔══════════════════════════════════════════════════════════════╗
         ║ SOLUCIÓN: El EditForm debe envolver TODO, incluido el Paper ║
         ╚══════════════════════════════════════════════════════════════╝ -->
    <EditForm EditContext="_editContext" OnValidSubmit="HandleSaveAsync">
        <DataAnnotationsValidator />

        <!-- PATRÓN ÚNICO (Con el iconito pequeño que te gustó) -->
        <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.TwoTone.Settings" Size="Size.Medium" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Configuración del Sistema</MudText>
                </MudStack>
                
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-none d-md-block mr-2">
                        Última actualización: @_formModel.LastUpdated.ToLocalTime().ToString("g")
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="HandleReset" Disabled="@_isSaving">
                        Descartar
                    </MudButton>
                    <!-- Ahora este botón SÍ sabe que pertenece al EditForm de arriba -->
                    <MudButton Loading="@_isSaving" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" ButtonType="ButtonType.Submit">
                        Guardar
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- CONTENIDO DEL FORMULARIO -->
        <MudStack AlignItems="AlignItems.Center" Class="mb-4">
            <MudExpansionPanels Elevation="1" Rounded="true" Style="max-width: 900px; width: 100%;">

                @* ═══ 1. IDENTIDAD ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelIdentity">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Business" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Identidad de la Organización</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelIdentity ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" Class="d-flex justify-center">
                                <PhotoUploader Value="@(_formModel.ImageFile?.Url)" IsProfile="false" PixelSize="120" OnUploaded="HandleImageUploaded" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ShortName)" For="@(() => _formModel.ShortName)" @bind-Value="_formModel.ShortName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Name)" For="@(() => _formModel.Name)" @bind-Value="_formModel.Name" Variant="Variant.Outlined" Required="true" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.TaxId)" For="@(() => _formModel.TaxId)" @bind-Value="_formModel.TaxId" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.LegalRepresentative)" For="@(() => _formModel.LegalRepresentative)" @bind-Value="_formModel.LegalRepresentative" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.LegalRepresentativeTitle)" For="@(() => _formModel.LegalRepresentativeTitle)" @bind-Value="_formModel.LegalRepresentativeTitle" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>

                @* ═══ 2. CONTACTO ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelContact">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spaing="2">
                                <MudIcon Icon="@Icons.Material.Filled.ContactMail" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Información de Contacto</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelContact ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Address)" For="@(() => _formModel.Address)" @bind-Value="_formModel.Address" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Phone)" For="@(() => _formModel.Phone)" @bind-Value="_formModel.Phone" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Email)" For="@(() => _formModel.Email)" @bind-Value="_formModel.Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Website)" For="@(() => _formModel.Website)" @bind-Value="_formModel.Website" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>

                @* ═══ 3. REPORTES ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelReports">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Description" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Textos para Reportes</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelReports ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="3">
                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ReportHeaderText)" For="@(() => _formModel.ReportHeaderText)" @bind-Value="_formModel.ReportHeaderText" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" HelperText="Aparece en la parte superior de los reportes PDF y Excel" HelperTextOnFocus="true" />
                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ReportFooterText)" For="@(() => _formModel.ReportFooterText)" @bind-Value="_formModel.ReportFooterText" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" HelperText="Aparece en la parte inferior de los reportes" HelperTextOnFocus="true" />
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>

                @* ═══ 4. APARIENCIA ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelAppearance">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Palette" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Apariencia</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelAppearance ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                            <MudItem xs="12" md="4">
                                <MudStack Spacing="2" AlignItems="AlignItems.Start">
                                    <MudColorPicker Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.PrimaryColor)" @bind-Value="_primaryColor" Variant="Variant.Outlined" Margin="Margin.Dense" UpdateEvent="update:onchange" />
                                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="ResetColor">
                                        Restablecer color original
                                    </MudButton>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="12" md="8">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Vista previa:</MudText>
                                    <MudChip T="string" Text="@(string.IsNullOrEmpty(_formModel.ShortName) ? _formModel.Name : _formModel.ShortName)" Variant="Variant.Filled" Style="@($"background-color: {_primaryColor.ToString()}; color: #fff;")" />
                                    <MudButton Variant="Variant.Filled" Style="@($"background-color: {_primaryColor.ToString()};")" DisableElevation="true" Size="Size.Small">Botón ejemplo</MudButton>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </MudStack>
        
    </EditForm> <!-- Aquí cierra el EditForm que ahora envuelve todo -->

</MudContainer>

@code {
    // ... El código @code permanece EXACTAMENTE igual, no toques nada aquí ...
    private SystemSettingDto _formModel = new();
    private SystemSettingDto? _originalModel;
    private EditContext _editContext = new(new SystemSettingDto());
    private bool _isLoading = true;
    private bool _isSaving;
    private MudColor _primaryColor = new("#4A6FA5");

    private bool _panelIdentity = true;
    private bool _panelContact;
    private bool _panelReports;
    private bool _panelAppearance;

    protected override async Task OnInitializedAsync()
    {
        var result = await SettingService.GetAsync();

        if (result is not null)
        {
            _formModel = result;
            _originalModel = CloneDto(_formModel);
        }
        else
        {
            await Alerts.ShowError("Error", "No se pudo cargar la configuración del sistema.");
            _formModel = new SystemSettingDto();
            _originalModel = new SystemSettingDto();
        }

        if (!string.IsNullOrEmpty(_formModel.PrimaryColor))
            _primaryColor = new MudColor(_formModel.PrimaryColor);

        _editContext = new EditContext(_formModel);
        _isLoading = false;
    }

    private Task HandleImageUploaded(FileResponse? file)
    {
        _formModel.ImageFile = file;
        return Task.CompletedTask;
    }

    private void ResetColor()
    {
        _primaryColor = new MudColor("#4A6FA5");
        _formModel.PrimaryColor = null;
    }

    private void HandleReset()
    {
        if (_originalModel is null) return;
        _formModel.Name = _originalModel.Name;
        _formModel.ShortName = _originalModel.ShortName;
        _formModel.ImageFile = _originalModel.ImageFile;
        _formModel.TaxId = _originalModel.TaxId;
        _formModel.LegalRepresentative = _originalModel.LegalRepresentative;
        _formModel.LegalRepresentativeTitle = _originalModel.LegalRepresentativeTitle;
        _formModel.Address = _originalModel.Address;
        _formModel.Phone = _originalModel.Phone;
        _formModel.Email = _originalModel.Email;
        _formModel.Website = _originalModel.Website;
        _formModel.ReportHeaderText = _originalModel.ReportHeaderText;
        _formModel.ReportFooterText = _originalModel.ReportFooterText;
        _formModel.PrimaryColor = _originalModel.PrimaryColor;
        _formModel.LastUpdated = _originalModel.LastUpdated;

        if (!string.IsNullOrEmpty(_formModel.PrimaryColor))
            _primaryColor = new MudColor(_formModel.PrimaryColor);

        _editContext?.NotifyValidationStateChanged();
    }

    private async Task HandleSaveAsync()
    {
        if (_editContext is null || !_editContext.Validate()) return;

        _formModel.PrimaryColor = $"#{_primaryColor.R:X2}{_primaryColor.G:X2}{_primaryColor.B:X2}";

        _isSaving = true;
        try
        {
            var result = await SettingService.UpdateAsync(_formModel);

            if (result?.Value is null)
            {
                await Alerts.ShowError("Error", result?.ErrorMessage ?? "No se pudo guardar la configuración.");
                return;
            }

            _originalModel = CloneDto(result.Value);
            _formModel.LastUpdated = result.Value.LastUpdated;

            await Alerts.ShowSuccess("Configuración guardada", "Los cambios se aplicaron correctamente.");
        }
        catch (Exception ex)
        {
            await Alerts.ShowError("Error", $"Error guardando configuración: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static SystemSettingDto CloneDto(SystemSettingDto src) => new()
    {
        Id = src.Id,
        ImageFile = src.ImageFile,
        Name = src.Name,
        ShortName = src.ShortName,
        TaxId = src.TaxId,
        LegalRepresentative = src.LegalRepresentative,
        LegalRepresentativeTitle = src.LegalRepresentativeTitle,
        Address = src.Address,
        Phone = src.Phone,
        Email = src.Email,
        Website = src.Website,
        ReportHeaderText = src.ReportHeaderText,
        ReportFooterText = src.ReportFooterText,
        PrimaryColor = src.PrimaryColor,
        LastUpdated = src.LastUpdated
    };
}