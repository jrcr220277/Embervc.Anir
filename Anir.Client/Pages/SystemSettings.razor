@page "/system/settings"
@attribute [Authorize]

@using Anir.Shared.Contracts.Common
@inject SystemSettingService SettingService
@inject MaintenanceService MaintenanceService
@inject BackupService BackupService
@inject IAlertService Alerts
@inject IJSRuntime JS

<PageTitle>Configuración del Sistema</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-3">

    @if (_isLoading)
    {
        <UiLoading Indeterminate="true" Message="Cargando configuración..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }

    <EditForm EditContext="_editContext" OnValidSubmit="HandleSaveAsync">
        <DataAnnotationsValidator />

        <!-- ENCABEZADO PROFESIONAL -->
        <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                
                <MudStack Column="true" Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.TwoTone.Settings" Size="Size.Medium" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Configuración del Sistema</MudText>
                    </MudStack>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-9">
                        Última actualización: @_formModel.LastUpdated.ToLocalTime().ToString("g")
                    </MudText>
                </MudStack>
                
                @if (_isDirty)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="HandleReset" Disabled="@_isSaving">
                            Descartar
                        </MudButton>
                        <MudButton Loading="@_isSaving" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" ButtonType="ButtonType.Submit">
                            Guardar
                        </MudButton>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        <!-- CONTENIDO DEL FORMULARIO -->
        <MudStack AlignItems="AlignItems.Center" Class="mb-4">
            <MudExpansionPanels Elevation="1" Rounded="true" Style="max-width: 900px; width: 100%;">

                @* ═══ 1. IDENTIDAD ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelIdentity">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Business" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Identidad de la Organización</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelIdentity ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" Class="d-flex justify-center">
                                <PhotoUploader Value="@(_formModel.ImageFile?.Url)" IsProfile="false" PixelSize="120" OnUploaded="HandleImageUploaded" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ShortName)" For="@(() => _formModel.ShortName)" @bind-Value="_formModel.ShortName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Name)" For="@(() => _formModel.Name)" @bind-Value="_formModel.Name" Variant="Variant.Outlined" Required="true" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.TaxId)" For="@(() => _formModel.TaxId)" @bind-Value="_formModel.TaxId" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.LegalRepresentative)" For="@(() => _formModel.LegalRepresentative)" @bind-Value="_formModel.LegalRepresentative" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.LegalRepresentativeTitle)" For="@(() => _formModel.LegalRepresentativeTitle)" @bind-Value="_formModel.LegalRepresentativeTitle" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>

                @* ═══ 2. CONTACTO ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelContact">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.ContactMail" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Información de Contacto</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelContact ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Address)" For="@(() => _formModel.Address)" @bind-Value="_formModel.Address" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Phone)" For="@(() => _formModel.Phone)" @bind-Value="_formModel.Phone" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Email)" For="@(() => _formModel.Email)" @bind-Value="_formModel.Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Website)" For="@(() => _formModel.Website)" @bind-Value="_formModel.Website" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>

                @* ═══ 3. REPORTES ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelReports">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Description" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Textos para Reportes</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelReports ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="3">
                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ReportHeaderText)" For="@(() => _formModel.ReportHeaderText)" @bind-Value="_formModel.ReportHeaderText" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" HelperText="Aparece en la parte superior de los reportes PDF y Excel" HelperTextOnFocus="true" />
                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ReportFooterText)" For="@(() => _formModel.ReportFooterText)" @bind-Value="_formModel.ReportFooterText" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" HelperText="Aparece en la parte inferior de los reportes" HelperTextOnFocus="true" />
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>

                @* ═══ 4. APARIENCIA ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelAppearance">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Palette" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Apariencia</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelAppearance ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                            <MudItem xs="12" md="4">
                                <MudStack Spacing="2" AlignItems="AlignItems.Start">
                                    <MudColorPicker Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.PrimaryColor)" @bind-Value="_primaryColor" Variant="Variant.Outlined" Margin="Margin.Dense" UpdateEvent="update:onchange" />
                                    <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" OnClick="ResetColor">
                                        Restablecer color original
                                    </MudButton>
                                </MudStack>
                            </MudItem>
                            <MudItem xs="12" md="8">
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Vista previa:</MudText>
                                    <MudChip T="string" Text="@(string.IsNullOrEmpty(_formModel.ShortName) ? _formModel.Name : _formModel.ShortName)" Variant="Variant.Filled" Style="@($"background-color: {_primaryColor.ToString()}; color: #fff;")" />
                                    <MudButton Variant="Variant.Filled" Style="@($"background-color: {_primaryColor.ToString()};")" DisableElevation="true" Size="Size.Small">Botón ejemplo</MudButton>
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    </ChildContent>
                </MudExpansionPanel>

                @* ═══ 5. MANTENIMIENTO Y RESPALDOS ═══ *@
                <MudExpansionPanel HideIcon="true" @bind-Expanded="_panelMaintenance">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="w-100">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.BuildCircle" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-medium">Mantenimiento y Respaldos</MudText>
                            </MudStack>
                            <MudIcon Icon="@(_panelMaintenance ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Color="Color.Secondary" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
        
                        @* INFO VISUAL DEL SISTEMA *@
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-4">
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                @($"App v{_systemInfo.AppVersion}")
                            </MudChip>
                            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">
                                @($"BD: {_systemInfo.LastMigration}")
                            </MudChip>
                        </MudStack>

                        @* INFRAESTRUCTURA *@
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mt-2 mb-3">Infraestructura</MudText>
                        <MudGrid Spacing="3">
                            <MudItem xs="12" md="8">
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.BackupToolPath)"
                                              For="@(() => _formModel.BackupToolPath)"
                                              @bind-Value="_formModel.BackupToolPath"
                                              Variant="Variant.Outlined" Margin="Margin.Dense"
                                              HelperText="Ej: C:\Program Files\PostgreSQL\16\bin\pg_dump.exe" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudNumericField T="int"
                                                 Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.MaxBackupFiles)"
                                                 For="@(() => _formModel.MaxBackupFiles)"
                                                 @bind-Value="_formModel.MaxBackupFiles"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" Min="1" Max="50" />
                            </MudItem>
                        </MudGrid>

                        <MudDivider Class="my-4" />

                        @* AUTOMATIZACIÓN (Hora primero, luego qué hacer) *@
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-3">Automatización</MudText>
                        <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                            <MudItem xs="12" md="3">
                                <MudTimePicker T="TimeSpan?"
                                               Label="Hora programada"
                                               @bind-Value="_formModel.ScheduledTime"
                                               Variant="Variant.Outlined" Margin="Margin.Dense"
                                               AmPm="false" OpenTo="OpenTo.Hours" />
                            </MudItem>
                            <MudItem xs="6" md="4" Class="d-flex justify-center">
                                <MudSwitch Label="Limpieza Auto" @bind-Value="_formModel.AutoMaintenanceEnabled" Color="Color.Primary" />
                            </MudItem>
                            <MudItem xs="6" md="5" Class="d-flex justify-center">
                                <MudSwitch Label="Respaldo Auto" @bind-Value="_formModel.AutoBackupEnabled" Color="Color.Primary" />
                            </MudItem>
                        </MudGrid>

                        <MudDivider Class="my-4" />

                        @* ACCIONES MANUALES (3 FABs compactos) *@
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-3">Acciones Manuales</MudText>
                        <MudStack Row="true" Justify="Justify.Center" Spacing="6" Class="my-6">

                            <MudTooltip Text="Limpiar archivos huérfanos">
                                <MudFab Color="Color.Inherit" StartIcon="@Icons.Material.Filled.CleaningServices" Size="Size.Small"
                                        OnClick="HandleCleanOrphans" Loading="@_isCleaning" Disabled="@_isCleaning" />
                            </MudTooltip>
            
                            <MudTooltip Text="Generar Respaldo">
                                <MudFab Color="Color.Inherit" StartIcon="@Icons.Material.Filled.Save" Size="Size.Small"
                                        OnClick="HandleCreateBackup" Loading="@_isCreatingBackup" Disabled="@_isCreatingBackup" />
                            </MudTooltip>
            
                            <MudTooltip Text="Restaurar desde ZIP">
                                <MudFileUpload T="IBrowserFile"
                                               Accept=".zip"
                                               FilesChanged="OnRestoreFileSelected">

                                    <CustomContent Context="uploader">
                                        <MudFab Color="Color.Error"
                                                StartIcon="@Icons.Material.Filled.Restore"
                                                Size="Size.Small"
                                                Disabled="@_isRestoring"
                                                Loading="@_isRestoring"
                                                OnClick="@uploader.OpenFilePickerAsync" />
                                    </CustomContent>

                                    <SelectedTemplate Context="file">
                                        @* vacío para eliminar template *@
                                    </SelectedTemplate>

                                </MudFileUpload>
                            </MudTooltip>
                        </MudStack>

                        <MudDivider Class="my-4" />

                        @* HISTORIAL DE RESPALDOS *@
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-3">Respaldos Disponibles en Servidor</MudText>
                        @if (_backups.Any())
                        {
                            <MudTable T="BackupResult" Items="@_backups" Hover="true" Elevation="0" Outlined="true" Dense="true">
                                <HeaderContent>
                                    <MudTh>Fecha</MudTh>
                                    <MudTh>Archivo</MudTh>
                                    <MudTh>Tamaño</MudTh>
                                    <MudTh Style="text-align:right">Acciones</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="item">
                                    <MudTd DataLabel="Fecha">@ExtractDateFromBackupName(item.FileName)</MudTd>
                                    <MudTd DataLabel="Archivo">@item.FileName</MudTd>
                                    <MudTd DataLabel="Tamaño">@item.FormattedSize</MudTd>
                                    <MudTd Style="text-align:right">
                                        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1">
                                            <MudTooltip Text="Descargar">
                                                <MudIconButton Icon="@Icons.Material.Filled.Download" Color="Color.Primary" Size="Size.Small"
                                                               OnClick="@(() => DownloadBackup(item.FileName))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Eliminar">
                                                <MudIconButton Icon="@Icons.Material.Filled.DeleteForever" Color="Color.Error" Size="Size.Small"
                                                               OnClick="@(() => DeleteBackup(item.FileName))" />
                                            </MudTooltip>
                                        </MudStack>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-2">
                                No hay respaldos generados actualmente.
                            </MudAlert>
                        }

                    </ChildContent>
                </MudExpansionPanel>

            </MudExpansionPanels>
        </MudStack>
        
    </EditForm>

</MudContainer>

@code {
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;

    private SystemSettingDto _formModel = new();
    private SystemSettingDto? _originalModel;
    private EditContext _editContext = new(new SystemSettingDto());
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isRestoring = false;
    private bool _isDirty;
    private BackupResult _systemInfo = new();
    private MudColor _primaryColor = new("#4A6FA5");

    private bool _panelIdentity = true;
    private bool _panelContact;
    private bool _panelReports;
    private bool _panelAppearance;
    private bool _panelMaintenance;

    // Mantenimiento y Backups
    private bool _isCleaning = false;
    private bool _isCreatingBackup = false;
    private List<BackupResult> _backups = new();

    protected override async Task OnInitializedAsync()
    {
        var result = await SettingService.GetAsync();

        if (result is not null)
        {
            _formModel = result;
            _originalModel = CloneDto(_formModel);
        }
        else
        {
            await Alerts.ShowError("Error", "No se pudo cargar la configuración del sistema.");
            _formModel = new SystemSettingDto();
            _originalModel = new SystemSettingDto();
        }

        if (!string.IsNullOrEmpty(_formModel.PrimaryColor))
            _primaryColor = new MudColor(_formModel.PrimaryColor);

        _editContext = new EditContext(_formModel);
        
        _editContext.OnFieldChanged += (sender, e) =>
        {
            _isDirty = true;
            StateHasChanged();
        };

        _isLoading = false;

        var infoResult = await BackupService.GetSystemInfoAsync();
        if (infoResult?.Value != null)
            _systemInfo = infoResult.Value;

        await LoadBackupsAsync();
    }

    private async Task HandleImageUploaded(FileResponse? file)
    {
        _formModel.ImageFile = file;
        _isDirty = true;
    }

    private void ResetColor()
    {
        _primaryColor = new MudColor("#4A6FA5");
        _formModel.PrimaryColor = null;
        _isDirty = true;
    }

    private void HandleReset()
    {
        if (_originalModel is null) return;
        
        _formModel.Name = _originalModel.Name;
        _formModel.ShortName = _originalModel.ShortName;
        _formModel.ImageFile = _originalModel.ImageFile;
        _formModel.TaxId = _originalModel.TaxId;
        _formModel.LegalRepresentative = _originalModel.LegalRepresentative;
        _formModel.LegalRepresentativeTitle = _originalModel.LegalRepresentativeTitle;
        _formModel.Address = _originalModel.Address;
        _formModel.Phone = _originalModel.Phone;
        _formModel.Email = _originalModel.Email;
        _formModel.Website = _originalModel.Website;
        _formModel.ReportHeaderText = _originalModel.ReportHeaderText;
        _formModel.ReportFooterText = _originalModel.ReportFooterText;
        _formModel.PrimaryColor = _originalModel.PrimaryColor;
        _formModel.BackupToolPath = _originalModel.BackupToolPath;
        _formModel.MaxBackupFiles = _originalModel.MaxBackupFiles;
        
        // ============================================================
        // FIX: CAMPOS FALTANTES EN EL RESET (Esto arregla el binding)
        // ============================================================
        _formModel.AutoBackupEnabled = _originalModel.AutoBackupEnabled;
        _formModel.AutoMaintenanceEnabled = _originalModel.AutoMaintenanceEnabled;
        _formModel.ScheduledTime = _originalModel.ScheduledTime;
        // ============================================================

        _formModel.LastUpdated = _originalModel.LastUpdated;

        if (!string.IsNullOrEmpty(_formModel.PrimaryColor))
            _primaryColor = new MudColor(_formModel.PrimaryColor);

        _isDirty = false;
        _editContext?.NotifyValidationStateChanged();
    }

    private async Task HandleSaveAsync()
    {
        if (_editContext is null || !_editContext.Validate()) return;

        _formModel.PrimaryColor = $"#{_primaryColor.R:X2}{_primaryColor.G:X2}{_primaryColor.B:X2}";

        _isSaving = true;
        try
        {
            var result = await SettingService.UpdateAsync(_formModel);

            if (result?.Value is null)
            {
                await Alerts.ShowError("Error", result?.ErrorMessage ?? "No se pudo guardar la configuración.");
                return;
            }

            _originalModel = CloneDto(result.Value);
            _formModel.LastUpdated = result.Value.LastUpdated;
            _isDirty = false;

            await Alerts.ShowSuccess("Configuración guardada", "Los cambios se aplicaron correctamente.");
        }
        catch (Exception ex)
        {
            await Alerts.ShowError("Error", $"Error guardando configuración: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
        }
    }

    // ============================================================
    // MÉTODOS DE MANTENIMIENTO Y RESPALDOS
    // ============================================================
    
    private async Task HandleCleanOrphans()
    {
        _isCleaning = true;
        try
        {
            var result = await MaintenanceService.CleanOrphansAsync();
            if (result?.Value != null)
            {
                await Alerts.ShowSuccess("Limpieza Completada", result.Value.Summary);
            }
            else
            {
                await Alerts.ShowError("Error", "No se pudo completar la limpieza.");
            }
        }
        finally
        {
            _isCleaning = false;
        }
    }

    private async Task HandleCreateBackup()
    {
        _isCreatingBackup = true;
        try
        {
            var result = await BackupService.CreateBackupAsync();
            if (result?.Value != null)
            {
                await Alerts.ShowSuccess("Respaldo Creado", result.Value.Message);
                await LoadBackupsAsync();
            }
            else
            {
                var errorMsg = result?.ErrorMessage ?? "No se pudo generar el respaldo. Verifique la configuración de la ruta de pg_dump.";
                await Alerts.ShowError("Error", errorMsg);
            }
        }
        catch (Exception ex)
        {
            await Alerts.ShowError("Error", $"Excepción al respaldar: {ex.Message}");
        }
        finally
        {
            _isCreatingBackup = false;
        }
    }

    private async Task DeleteBackup(string fileName)
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "Eliminar Respaldo",
            $"¿Está seguro de eliminar el archivo {fileName}? Esta acción no se puede deshacer.",
            type: "delete",
            confirmText: "Eliminar",
            centerMessage: true);

        if (!confirmed) return;

        try
        {
            var result = await BackupService.DeleteBackupAsync(fileName);
            if (result?.Value == true)
            {
                await Alerts.ShowSuccess("Eliminado", "Respaldo eliminado del servidor.");
                await LoadBackupsAsync(); // Refrescar tabla
            }
            else
            {
                await Alerts.ShowError("Error", result?.ErrorMessage ?? "No se pudo eliminar el respaldo.");
            }
        }
        catch (Exception ex)
        {
            await Alerts.ShowError("Error", $"Excepción al eliminar: {ex.Message}");
        }
    }

    // Helper para sacar la fecha del nombre del archivo y mostrarla bonita
    private string ExtractDateFromBackupName(string fileName)
    {
        try
        {
            // ANIR_Backup_20260426_113849_v1.0.0.0.zip
            var parts = fileName.Split('_');
            if (parts.Length >= 3)
            {
                var dateStr = parts[2]; // 20260426
                var timeStr = parts[3]; // 113849
                if (dateStr.Length == 8 && timeStr.Length >= 6)
                {
                    var year = dateStr.Substring(0, 4);
                    var month = dateStr.Substring(4, 2);
                    var day = dateStr.Substring(6, 2);
                    var hour = timeStr.Substring(0, 2);
                    var min = timeStr.Substring(2, 2);
                    return $"{day}/{month}/{year} {hour}:{min}";
                }
            }
        }
        catch { }
        return string.Empty;
    }

   
    private async Task OnRestoreFileSelected(IBrowserFile file)
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "⚠️ RESTAURACIÓN COMPLETA DEL SISTEMA",
            "¡ATENCIÓN! Esto sobreescribirá TODA la base de datos y todos los archivos actuales con el respaldo seleccionado. Esta acción no se puede deshacer. ¿Está absolutamente seguro?",
            type: "warning",
            confirmText: "SÍ, RESTAURAR SISTEMA",
            cancelText: "Cancelar",
            centerMessage: true);

        if (!confirmed) return;

        _isRestoring = true;
        try
        {
            var result = await BackupService.RestoreBackupAsync(file);
            if (result?.Value == true)
            {
                await Alerts.ShowSuccess("Éxito", "Sistema restaurado. La aplicación se recargará en unos segundos...");
            }
            else
            {
                await Alerts.ShowError("Error", result?.ErrorMessage ?? "No se pudo restaurar el sistema.");
            }
        }
        catch (Exception ex)
        {
            await Alerts.ShowError("Error", $"Excepción al restaurar: {ex.Message}");
        }
        finally
        {
            _isRestoring = false;
        }
    }

    private async Task LoadBackupsAsync()
    {
        var result = await BackupService.GetBackupsAsync();
        _backups = result?.Value ?? new List<BackupResult>();
    }

    private async Task DownloadBackup(string fileName)
    {
        try
        {
            var bytes = await BackupService.DownloadBackupAsync(fileName);
            if (bytes != null && bytes.Length > 0)
            {
                var base64 = Convert.ToBase64String(bytes);
                await JS.InvokeVoidAsync("downloadFile", fileName, "application/zip", base64);
            }
            else
            {
                await Alerts.ShowError("Error", "No se pudo descargar el archivo.");
            }
        }
        catch (Exception ex)
        {
            await Alerts.ShowError("Error", $"Error descargando: {ex.Message}");
        }
    }

