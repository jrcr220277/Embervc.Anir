@page "/anirworks"
@using Anir.Client.Components.Tables
@using Anir.Shared.Contracts.AnirWorks
@using Anir.Shared.Contracts.Common
@using Anir.Client.Services.AnirWorks
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="pa-3">

    @if (IsInitializingPage)
    {
        <UiLoading Indeterminate="true" Message="Cargando trabajos ANIR..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }

    <!-- ENCABEZADO (igual que Companies) -->
    <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Rounded="true" Color="Color.Primary">
                    <MudIcon Icon="@Icons.Material.TwoTone.Work" Size="Size.Medium" />
                </MudAvatar>
                <MudStack AlignItems="AlignItems.Start" Spacing="0">
                    <MudText Typo="Typo.h6" Class="font-weight-medium">Trabajos ANIR</MudText>
                    <MudText Typo="Typo.caption">Gestión de trabajos ANIR: búsqueda, filtros y acciones masivas</MudText>
                </MudStack>
            </MudStack>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudButton StartIcon="@Icons.Material.TwoTone.Add" Color="Color.Primary" Variant="Variant.Filled" OnClick="GoToCreate">
                    Agregar
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- ACCIONES MASIVAS -->
    <MudCollapse Expanded="@(SelectedItems.Any() || IsGlobalSelected)">
        <MudPaper Outlined="true" Elevation="0" Class="px-4 py-3 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTooltip Text="@(IsGlobalSelected ? "Cancelar selección global" : "Seleccionar global")" Arrow="true" Placement="Placement.Top">
                        <MudIconButton Icon="@(IsGlobalSelected ? Icons.Material.Filled.Deselect : Icons.Material.Filled.SelectAll)"
                                       Size="Size.Medium" Edge="Edge.Start"
                                       OnClick="@(() => ToggleGlobalSelection())" />
                    </MudTooltip>
                    <MudText Typo="Typo.body2" Class="font-weight-medium">@BulkSelectionText</MudText>
                </MudStack>

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudTooltip Text="Ver reporte pdf" Arrow="true" Placement="Placement.Top">
                        <MudIconButton OnClick="ViewPdf" Icon="@Icons.Custom.FileFormats.FilePdf" />
                    </MudTooltip>
                    <MudTooltip Text="Descargar reportes" Arrow="true" Placement="Placement.Top">
                        <MudMenu Icon="@Icons.Material.Outlined.SaveAlt" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            <MudMenuItem label="Descargar PDF" Icon="@Icons.Custom.FileFormats.FilePdf" OnClick="DownloadPdf" />
                            <MudDivider />
                            <MudMenuItem label="Descargar Excel" Icon="@Icons.Custom.FileFormats.FileExcel" OnClick="ExportExcel" />
                        </MudMenu>
                    </MudTooltip>
                    <MudTooltip Text="Eliminar registros seleccionados" Arrow="true" Placement="Placement.Top">
                        <MudIconButton OnClick="@(() => DeleteSelected())" Icon="@Icons.Material.Outlined.DeleteForever" Color="Color.Error" Edge="Edge.End" />
                    </MudTooltip>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudCollapse>

    <!-- TABLA PRINCIPAL -->
    <MudTable T="AnirWorkDto" ServerData="ServerReload" @ref="TableRef" Hover="true" Dense="true" MultiSelection="true" @bind-SelectedItems="SelectedItems" SelectOnRowClick="true" Loading="@IsLoadingTable" HorizontalScrollbar="true" Elevation="0" Outlined="true">
        
        <ToolBarContent>
            @if (_totalFilteredCount > 0)
            {
                <MudTooltip Text="Numero de registros en tabla" Arrow="true" Placement="Placement.Top">
                    <MudBadge Content="@_totalFilteredCount.ToString()" Color="Color.Primary" Overlap="true">
                        <MudIcon Icon="@Icons.Material.Rounded.TableRows" Size="Size.Medium" />
                    </MudBadge>
                </MudTooltip>
            }

            <MudSpacer />
            <MudTextField T="string"
                          Variant="Variant.Text"
                          Margin="Margin.Dense"
                          Class="flex-grow-1"
                          Value="@SearchText"
                          ValueChanged="OnSearchInput"
                          Immediate="true"
                          Clearable="true"
                          Placeholder="Buscar por título, número ANIR, empresa..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search" />
        </ToolBarContent>

        <HeaderContent>
            <MudTh><MudTableSortLabel T="AnirWorkDto" SortLabel="AnirNumber">Número</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="AnirWorkDto" SortLabel="Title">Título</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="AnirWorkDto" SortLabel="CompanyName">Empresa</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="AnirWorkDto" SortLabel="Date">Fecha</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="AnirWorkDto" SortLabel="EconomicImpact">Impacto Econ.</MudTableSortLabel></MudTh>
            
            <MudTh>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText>Social</MudText>
                    <ColumnFilter Options="_socialOptions"
                                  Value="@SocialFilterValue"
                                  ValueChanged="OnSocialFilterChanged"
                                  ActiveColor="Color.Primary" />
                </MudStack>
            </MudTh>

            <MudTh>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText>Económico</MudText>
                    <ColumnFilter Options="_economicOptions"
                                  Value="@EconomicFilterValue"
                                  ValueChanged="OnEconomicFilterChanged"
                                  ActiveColor="Color.Primary" />
                </MudStack>
            </MudTh>

            <MudTh>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudText>Generalización</MudText>
                    <ColumnFilter Options="_generalizationOptions"
                                  Value="@GeneralizationFilterValue"
                                  ValueChanged="OnGeneralizationFilterChanged"
                                  ActiveColor="Color.Primary" />
                </MudStack>
            </MudTh>

            <MudTh Style="width: 140px; text-align:end">Acciones</MudTh>
        </HeaderContent>

        <RowTemplate Context="work">
            <MudTd>@work.AnirNumber</MudTd>
            <MudTd>@work.Title</MudTd>
            <MudTd>@work.CompanyName</MudTd>
            <MudTd>@work.Date.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>@work.EconomicImpact.ToString("C")</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(work.HasSocialEffect ? Color.Success : Color.Error)" Variant="Variant.Text" Size="Size.Small">
                    @(work.HasSocialEffect ? "Sí" : "No")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="@(work.HasEconomicEffect ? Color.Info : Color.Default)" Variant="Variant.Text" Size="Size.Small">
                    @(work.HasEconomicEffect ? "Sí" : "No")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="@(work.Generalization == GeneralizationStatus.Si ? Color.Success : work.Generalization == GeneralizationStatus.No ? Color.Error : Color.Warning)" Variant="Variant.Text" Size="Size.Small">
                    @(work.Generalization == GeneralizationStatus.Si ? "Sí" : work.Generalization == GeneralizationStatus.No ? "No" : "Pendiente")
                </MudChip>
            </MudTd>
            <MudTd Style="width: 140px; text-align:end">
                <MudTooltip Text="Visualizar registro seleccionado" Arrow="true" Placement="Placement.Left">
                    <MudIconButton Icon="@Icons.Material.Rounded.Visibility" OnClick="@(() => ViewWork(work))" Size="Size.Small" />
                </MudTooltip>
                <MudTooltip Text="Editar registro seleccionado" Arrow="true" Placement="Placement.Left">
                    <MudIconButton Icon="@Icons.Material.Rounded.Edit" OnClick="@(() => EditWork(work))" Size="Size.Small" />
                </MudTooltip>
                <MudTooltip Text="Eliminar registro seleccionado" Arrow="true" Placement="Placement.Left">
                    <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" Variant="Variant.Text" OnClick="@(() => DeleteWork(work))" Size="Size.Small" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4 text-center">No se encontraron trabajos ANIR.</MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 5, 10, 15, 20, 50, 100, int.MaxValue }" RowsPerPageString="Registros por página:" InfoFormat="{first_item}-{last_item} de {all_items}" AllItemsText="Todos" HorizontalAlignment="HorizontalAlignment.Right" />
        </PagerContent>
    </MudTable>

</MudContainer>

@code {
    // ============================================================
    // DEPENDENCIAS
    // ============================================================
    [Inject] private IAnirWorkService WorkService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private ILogger<AnirWorkIndex> Logger { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    // ============================================================
    // ESTADO GENERAL
    // ============================================================
    private bool IsInitializingPage = true;
    private bool IsLoadingTable = false;
    private bool IsProcessingBulkAction = false;

    private MudTable<AnirWorkDto>? TableRef;
    private HashSet<AnirWorkDto> SelectedItems = new(new AnirWorkComparer());
    
    private bool IsGlobalSelected = false;
    private int _totalFilteredCount = 0;

    private string SearchText = string.Empty;
    private string SocialFilterValue = "Todos";
    private string EconomicFilterValue = "Todos";
    private string GeneralizationFilterValue = "Todos";

    private IReadOnlyList<AnirWorkDto> LastPageItems = Array.Empty<AnirWorkDto>();

    private readonly IReadOnlyList<string> _socialOptions = new List<string> { "Todos", "Sí", "No" };
    private readonly IReadOnlyList<string> _economicOptions = new List<string> { "Todos", "Sí", "No" };
    private readonly IReadOnlyList<string> _generalizationOptions = new List<string> { "Todos", "Sí", "No", "Pendiente" };

    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _serverReloadCts;

    // ============================================================
    // CICLO DE VIDA
    // ============================================================
    protected override Task OnInitializedAsync()
    {
        IsInitializingPage = false;
        return Task.CompletedTask;
    }

    // ============================================================
    // NAVEGACIÓN
    // ============================================================
    private void GoToCreate() => Nav.NavigateTo("/anirworks/create");
    private void EditWork(AnirWorkDto work) => Nav.NavigateTo($"/anirworks/edit/{work.Id}");
    private void ViewWork(AnirWorkDto work) => Nav.NavigateTo($"/anirworks/view/{work.Id}");

    // ============================================================
    // SERVER DATA
    // ============================================================
    private async Task<TableData<AnirWorkDto>> ServerReload(TableState state, CancellationToken token)
    {
        _serverReloadCts?.Cancel();
        _serverReloadCts = CancellationTokenSource.CreateLinkedTokenSource(token);
        var linkedToken = _serverReloadCts.Token;

        IsLoadingTable = true;

        try
        {
            var query = MapTableStateToQuery(state);
            var response = await WorkService.GetPagedAsync(query, linkedToken);

            if (response.Result == ResponseStatus.Success && response.Value != null)
            {
                LastPageItems = response.Value.Items.ToList().AsReadOnly();
                _totalFilteredCount = response.Value.TotalCount;

                if (SelectedItems.Any())
                {
                    var selectedIds = SelectedItems.Select(x => x.Id).ToHashSet();
                    SelectedItems = new HashSet<AnirWorkDto>(
                        response.Value.Items.Where(i => selectedIds.Contains(i.Id)),
                        new AnirWorkComparer()
                    );
                }

                return new TableData<AnirWorkDto>
                {
                    Items = response.Value.Items,
                    TotalItems = response.Value.TotalCount
                };
            }

            await AlertService.ShowError("Error", response.ErrorMessage ?? "Error cargando trabajos ANIR");
            return new TableData<AnirWorkDto>();
        }
        finally
        {
            IsLoadingTable = false;
        }
    }

    private AnirWorkQueryDto MapTableStateToQuery(TableState state)
    {
        var sortLabel = string.IsNullOrWhiteSpace(state.SortLabel)
            ? "Date"
            : state.SortLabel;

        var desc = state.SortDirection == SortDirection.Descending;

        return new AnirWorkQueryDto
        {
            Page = state.Page + 1,
            Size = state.PageSize,
            Sort = sortLabel,
            Desc = desc,
            Search = string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
            HasSocialEffect = SocialFilterValue switch { "Sí" => true, "No" => false, _ => null },
            HasEconomicEffect = EconomicFilterValue switch { "Sí" => true, "No" => false, _ => null },
            Generalization = GeneralizationFilterValue switch
            {
                "Sí" => GeneralizationStatus.Si,
                "No" => GeneralizationStatus.No,
                "Pendiente" => GeneralizationStatus.Pendiente,
                _ => null
            }
        };
    }

    // ============================================================
    // BÚSQUEDA
    // ============================================================
    private async Task OnSearchInput(string value)
    {
        SearchText = value;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(300, _searchDebounceCts.Token);
            if (TableRef != null) await TableRef.ReloadServerData();
        }
        catch (TaskCanceledException) { }
    }

    // ============================================================
    // FILTROS POR COLUMNA
    // ============================================================
    private async Task OnSocialFilterChanged(string value)
    {
        SocialFilterValue = value;
        if (TableRef != null) await TableRef.ReloadServerData();
    }

    private async Task OnEconomicFilterChanged(string value)
    {
        EconomicFilterValue = value;
        if (TableRef != null) await TableRef.ReloadServerData();
    }

    private async Task OnGeneralizationFilterChanged(string value)
    {
        GeneralizationFilterValue = value;
        if (TableRef != null) await TableRef.ReloadServerData();
    }

    // ============================================================
    // ELIMINAR INDIVIDUAL
    // ============================================================
    private async Task DeleteWork(AnirWorkDto work)
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "¿Está seguro de que desea eliminar este registro?",
            $"¿Eliminar el trabajo {work.AnirNumber}?",
            type: "Delete",
            confirmText: "Eliminar",
            centerMessage: true
        );

        if (!confirmed) return;

        var response = await WorkService.DeleteAsync(work.Id);

        if (response.Result == ResponseStatus.Success)
        {
            SelectedItems.RemoveWhere(c => c.Id == work.Id);
            if (TableRef != null) await TableRef.ReloadServerData();
            await AlertService.ShowSuccess("Éxito", "Trabajo ANIR eliminado correctamente.");
            return;
        }

        if (response.ValidationErrors != null && response.ValidationErrors.TryGetValue("Restricciones", out var ids))
        {
            await AlertService.ShowWarning("Borrado no completado", "Este registro tiene dependencias asociadas. La acción de borrado no se realizó.");
            return;
        }

        await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
    }

    // ============================================================
    // SELECCIÓN
    // ============================================================
    private void ToggleGlobalSelection()
    {
        IsGlobalSelected = !IsGlobalSelected;
        SelectedItems.Clear();
        if (IsGlobalSelected)
        {
            foreach (var item in LastPageItems)
                SelectedItems.Add(item);
        }
    }

    private string BulkSelectionText =>
        IsGlobalSelected
            ? $"Selección global: {_totalFilteredCount} trabajo{(SelectedItems.Count == 1 ? "" : "s")} seleccionado{(SelectedItems.Count == 1 ? "" : "s")} del resultado actual"
            : $"{SelectedItems.Count} trabajo{(SelectedItems.Count == 1 ? "" : "s")} seleccionado{(SelectedItems.Count == 1 ? "" : "s")} del resultado actual";

    // ============================================================
    // ACCIONES MASIVAS
    // ============================================================
    private async Task DeleteSelected()
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "¿Desea eliminar los registros seleccionados?",
            IsGlobalSelected
                ? $"¿Eliminar todos los {_totalFilteredCount} trabajos ANIR del filtro?"
                : $"¿Eliminar {SelectedItems.Count} trabajo(s) seleccionado(s)?",
            type: "Delete",
            confirmText: "Eliminar",
            centerMessage: true
        );

        if (!confirmed) return;

        IsProcessingBulkAction = true;
        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };

            var response = await WorkService.DeleteBatchAsync(request);

            if (response.Result == ResponseStatus.Success)
            {
                SelectedItems.Clear();
                IsGlobalSelected = false;
                if (TableRef != null) await TableRef.ReloadServerData();
                await AlertService.ShowSuccess("Éxito", "Trabajos ANIR eliminados correctamente.");
                return;
            }

            if (response.ValidationErrors != null && response.ValidationErrors.TryGetValue("Restricciones", out var ids))
            {
                await AlertService.ShowWarning("Borrado no completado", $"{ids.Length} registro(s) tienen dependencias asociadas. El borrado masivo no se realizó.");
                return;
            }

            await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
        }
        finally
        {
            IsProcessingBulkAction = false;
        }
    }

    private async Task ViewPdf()
    {
        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };
            var bytes = await WorkService.ExportPdfListAsync(request);
            await JS.InvokeVoidAsync("openPdfBlob", bytes, "Listado_AnirWorks.pdf");
        }
        catch (Exception ex)
        {
            await AlertService.ShowError("Error", $"No se pudo generar el PDF: {ex.Message}");
        }
    }

    private async Task DownloadPdf()
    {
        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };
            var bytes = await WorkService.ExportPdfListAsync(request);
            await JS.InvokeVoidAsync("downloadBlob", bytes, "Listado_AnirWorks.pdf", "application/pdf");
            await AlertService.ShowSuccess("Éxito", "PDF descargado correctamente.");
        }
        catch (Exception ex)
        {
            await AlertService.ShowError("Error", $"No se pudo generar el PDF: {ex.Message}");
        }
    }

    private async Task ExportExcel()
    {
        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };
            var bytes = await WorkService.ExportExcelListAsync(request);
            await JS.InvokeVoidAsync("downloadBlob", bytes, "Listado_AnirWorks.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
            await AlertService.ShowSuccess("Éxito", "Reporte Excel descargado correctamente.");
        }
        catch (Exception ex)
        {
            await AlertService.ShowError("Error", $"No se pudo generar el Excel: {ex.Message}");
        }
    }

    // ============================================================
    // LIMPIEZA
    // ============================================================
    public void Dispose()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _serverReloadCts?.Cancel();
        _serverReloadCts?.Dispose();
    }

    private class AnirWorkComparer : IEqualityComparer<AnirWorkDto>
    {
        public bool Equals(AnirWorkDto? x, AnirWorkDto? y) => x?.Id == y?.Id;
        public int GetHashCode(AnirWorkDto obj) => obj.Id.GetHashCode();
    }
}