@page "/anirworks/create"
@page "/anirworks/edit/{Id:int}"
@page "/anirworks/view/{Id:int}"

@using Anir.Client.Pages.AnirWork
@using MudBlazor
@using Anir.Shared.Contracts.AnirWorks
@using Anir.Client.Services.AnirWorks
@using Anir.Client.Services.Files
@using Anir.Client.Services

@inject IAnirWorkService WorkService
@inject CompanyService CompanyService
@inject IAlertService AlertService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">

    <!-- ============================================================
         ENCABEZADO PROFESIONAL
    ============================================================ -->
    <MudPaper Class="pa-3 mb-4" Elevation="1">

        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">

            <!-- IZQUIERDA: Icono + Títulos -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.TwoTone.Work" Style="font-size: 3rem;" />

                <MudStack>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">
                        @(IsViewMode ? "Ver Trabajo ANIR" : Id == null ? "Crear Trabajo ANIR" : "Editar Trabajo ANIR")
                    </MudText>

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Gestión integral de trabajos ANIR
                    </MudText>
                </MudStack>
            </MudStack>

            <!-- DERECHA: Chip de estado -->
            <MudStack Row="true" Spacing="1">
                <MudChip T="string"
                         Color="Color.Info"
                         Variant="Variant.Outlined">
                    @(IsViewMode ? "Modo lectura" : Id == null ? "Nuevo" : "Edición")
                </MudChip>
            </MudStack>

        </MudStack>


    </MudPaper>

    @if (IsLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height:200px;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        </MudStack>
    }
    else
    {
        <!-- ============================================================
             LAYOUT PRINCIPAL: SIDEBAR + CONTENIDO
        ============================================================ -->
        <EditForm Model="Model" OnValidSubmit="Save">
            <DataAnnotationsValidator />

            <MudGrid>

                <!-- ============================================================
                     SIDEBAR FIJO (columna izquierda)
                ============================================================ -->
                <MudItem xs="12" md="3">

                    <MudPaper Class="pa-3 rounded-lg" Elevation="1">

                        <!-- IMAGEN -->
                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-semibold">
                            Imagen
                        </MudText>

                        <PhotoUploader Value="@Model.ImageUrl"
                                       IsProfile="false"
                                       Size="140"
                                       OnChanged="HandleImageChanged"
                                       IsViewMode="IsViewMode" />

                        <MudDivider Class="my-3" />

                        <!-- PDF -->
                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-semibold">
                            Documento PDF
                        </MudText>

                        @if (!IsViewMode)
                        {
                            <PdfUpload Value="@Model.PdfUrl"
                                       OnChanged="HandlePdfChanged" />
                        }

                        @if (!string.IsNullOrEmpty(Model.PdfUrl))
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Outlined.PictureAsPdf"
                                       Href="@Model.PdfUrl"
                                       Target="_blank"
                                       Dense="true"
                                       Class="mt-1">
                                Ver PDF
                            </MudButton>

                            @if (!IsViewMode)
                            {
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Error"
                                           Dense="true"
                                           OnClick="DeletePdf">
                                    Eliminar
                                </MudButton>
                            }
                        }

                    </MudPaper>

                </MudItem>


                <!-- ============================================================
                     CONTENIDO PRINCIPAL (columna derecha)
                ============================================================ -->
                <MudItem xs="12" md="9">

                    <MudPaper Class="pa-3 rounded-lg" Elevation="1">

                        <MudTabs Vertical="true"
                                 ApplyEffectsToContainer="true"
                                 Border="true"
                                 TabPanelsClass="pa-4">

                            <!-- DATOS GENERALES -->
                            <MudTabPanel Text="Datos generales" Icon="@Icons.Material.Outlined.Info">

                                <MudGrid Spacing="2">

                                    <!-- Empresa -->
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="int"
                                                   Label="Empresa"
                                                   @bind-Value="Model.CompanyId"
                                                   Disabled="IsViewMode"
                                                   Required="true"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Class="w-100">
                                            @foreach (var c in Companies)
                                            {
                                                <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>

                                    <!-- Número ANIR -->
                                    <MudItem xs="12" md="6">
                                        <MudTextField Label="Número ANIR"
                                                      @bind-Value="Model.AnirNumber"
                                                      Disabled="IsViewMode"
                                                      Required="true"
                                                      Variant="Variant.Outlined"
                                                      Dense="true"
                                                      Class="w-100" />
                                    </MudItem>

                                    <!-- Fecha -->
                                    <MudItem xs="12" md="6">
                                        <MudDatePicker Label="Fecha"
                                                       Date="@Model.Date.ToDateTime(TimeOnly.MinValue)"
                                                       DateChanged="@(d => Model.Date = DateOnly.FromDateTime(d ?? DateTime.Now))"
                                                       Disabled="IsViewMode"
                                                       Variant="Variant.Outlined"
                                                       Dense="true"
                                                       Class="w-100" />
                                    </MudItem>

                                    <!-- Título -->
                                    <MudItem xs="12">
                                        <MudTextField Label="Título"
                                                      @bind-Value="Model.Title"
                                                      Disabled="IsViewMode"
                                                      Required="true"
                                                      Variant="Variant.Outlined"
                                                      Dense="true"
                                                      Class="w-100" />
                                    </MudItem>

                                    <!-- Descripción -->
                                    <MudItem xs="12">
                                        <MudTextField Label="Descripción"
                                                      @bind-Value="Model.Description"
                                                      Disabled="IsViewMode"
                                                      Variant="Variant.Outlined"
                                                      Dense="true"
                                                      Lines="3"
                                                      Class="w-100" />
                                    </MudItem>

                                    <!-- ============================
                                         CAMPOS ADMINISTRATIVOS
                                    ============================ -->

                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Checked="Model.HasSocialEffect"
                                                   Disabled="IsViewMode"
                                                   Color="Color.Success"
                                                   Dense="true">
                                            Efecto Social
                                        </MudSwitch>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Checked="Model.HasEconomicEffect"
                                                   Disabled="IsViewMode"
                                                   Color="Color.Success"
                                                   Dense="true">
                                            Efecto Económico
                                        </MudSwitch>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudSelect T="GeneralizationStatus"
                                                   Label="Generalización"
                                                   @bind-Value="Model.Generalization"
                                                   Disabled="IsViewMode"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Class="w-100">
                                            <MudSelectItem Value="GeneralizationStatus.Yes">Sí</MudSelectItem>
                                            <MudSelectItem Value="GeneralizationStatus.No">No</MudSelectItem>
                                            <MudSelectItem Value="GeneralizationStatus.Pending">Pendiente</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="decimal"
                                                         Label="Impacto Económico"
                                                         @bind-Value="Model.EconomicImpact"
                                                         Disabled="IsViewMode"
                                                         Variant="Variant.Outlined"
                                                         Dense="true"
                                                         Class="w-100" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField Label="Número de Resolución"
                                                      @bind-Value="Model.ResolutionNumber"
                                                      Disabled="IsViewMode"
                                                      Variant="Variant.Outlined"
                                                      Dense="true"
                                                      Class="w-100" />
                                    </MudItem>

                                </MudGrid>

                            </MudTabPanel>


                            <!-- PERSONAS -->
                            <MudTabPanel Text="Personas" Icon="@Icons.Material.Outlined.Group">
                                <AnirWorkPersonsSection Persons="Model.Persons" IsViewMode="IsViewMode" />
                            </MudTabPanel>

                            <!-- PRESENTACIONES -->
                            <MudTabPanel Text="Presentaciones" Icon="@Icons.Material.Outlined.PresentToAll">
                                <AnirWorkPresentationsSection Presentations="Model.Presentations" IsViewMode="IsViewMode" />
                            </MudTabPanel>

                            <!-- ADMINISTRATIVO (DETALLE) -->
                            <MudTabPanel Text="Administrativo" Icon="@Icons.Material.Outlined.AdminPanelSettings">

                                <MudTextField Label="Recomendaciones"
                                              @bind-Value="Model.Recommendations"
                                              Disabled="IsViewMode"
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              Lines="3"
                                              Class="w-100" />

                            </MudTabPanel>

                        </MudTabs>

                    </MudPaper>

                </MudItem>

            </MudGrid>

            <!-- ============================================================
                 FOOTER DE ACCIONES
            ============================================================ -->
            <MudStack Row="true"
                      Spacing="1"
                      Class="mt-4"
                      Justify="Justify.FlexEnd">

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Dense="true"
                           OnClick="Back">
                    @(IsViewMode ? "Volver" : "Cancelar")
                </MudButton>

                @if (!IsViewMode)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               ButtonType="ButtonType.Submit"
                               Dense="true">
                        Guardar
                    </MudButton>
                }
                <MudAlert Severity="Severity.Info">
                    Personas: @Model.Persons?.Count — Presentaciones: @Model.Presentations?.Count
                </MudAlert>

            </MudStack>

        </EditForm>
    }
</MudContainer>

@code {

    [Parameter] public int? Id { get; set; }

    private bool IsLoading = true;
    private bool IsViewMode => Nav.Uri.Contains("/view");

    private AnirWorkDto Model = new();
    private List<CompanyDto> Companies = new();

    protected override async Task OnInitializedAsync()
    {
        var query = new CompanyQueryDto
        {
            Page = 1,
            Size = 9999,
            Sort = "Name"
        };

        var companyResponse = await CompanyService.GetPagedAsync(query);

        if (companyResponse.Result == ResponseStatus.Success)
            Companies = companyResponse.Value!.Items.ToList();
        else
            await AlertService.ShowError("Error", "No se pudieron cargar las empresas.");

        if (Id is null)
        {
            Model = new AnirWorkDto
            {
                Persons = new(),
                Presentations = new()
            };
        }
        else
        {
            var response = await WorkService.GetByIdAsync(Id.Value);

            if (response?.Result == ResponseStatus.Success)
                Model = response.Value!;
            else
            {
                await AlertService.ShowError("Error", "No se pudo cargar el trabajo.");
                Nav.NavigateTo("/anirworks");
                return;
            }
        }
       
         IsLoading = false;
    }

    private void HandleImageChanged(FileResponse? file)
    {
        Model.ImageId = file?.Id;
        Model.ImageUrl = file?.Url;
    }

    private void HandlePdfChanged(FileResponse? file)
    {
        Model.PdfId = file?.Id;
        Model.PdfUrl = file?.Url;
    }

    private void DeletePdf()
    {
        Model.PdfId = null;
        Model.PdfUrl = null;
    }

    private async Task Save()
    {
        if (IsViewMode)
            return;

        ProcessResponse<AnirWorkDto>? response =
            Id is null
            ? await WorkService.CreateAsync(Model)
            : await WorkService.UpdateAsync(Model.Id, Model);

        if (response?.Result == ResponseStatus.Success)
        {
            await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
            Nav.NavigateTo("/anirworks");
        }
        else
        {
            await AlertService.ShowError("Error", response?.PrettyMessage ?? "Error al guardar.");
        }
    }

    private void Back() => Nav.NavigateTo("/anirworks");
}
