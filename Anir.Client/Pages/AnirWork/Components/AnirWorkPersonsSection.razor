@using MudBlazor
@using Anir.Shared.Contracts.AnirWorks.Persons
@namespace Anir.Client.Pages.AnirWork.Components


<MudPaper Class="pa-3" Outlined="true">

    <!-- TÍTULO -->
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIcon Icon="@Icons.Material.Outlined.Group" Size="Size.Small" />
        <MudText Typo="Typo.body2" Color="Color.Secondary">Personas asociadas</MudText>
    </MudStack>

    <!-- BOTÓN AGREGAR -->
    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.Add"
               OnClick="OpenAddDialog"
               Class="mb-3">
        Agregar persona
    </MudButton>

    <!-- TABLA -->
    <MudTable T="AnirWorkPersonDto"
              Items="Persons"
              Dense="true"
              Hover="true"
              Striped="true">

        <HeaderContent>
            <MudTh>Persona</MudTh>
            <MudTh>Participación (%)</MudTh>
            <MudTh Style="width: 120px; text-align:end">Acciones</MudTh>
        </HeaderContent>

        <RowTemplate Context="p">
            <MudTd>@p.PersonName</MudTd>
            <MudTd>@p.ParticipationPercentage</MudTd>

            <MudTd Style="width: 120px; text-align:end">
                <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                               Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(p))" />

                <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                               Size="Size.Small"
                               Color="Color.Error"
                               OnClick="@(() => RemovePerson(p))" />
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-2">No hay personas asociadas.</MudText>
        </NoRecordsContent>

    </MudTable>

</MudPaper>

@code {

    // ============================================================
    // PARAMETROS
    // ============================================================
    [Parameter] public List<AnirWorkPersonDto> Persons { get; set; } = new();

    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;

    // ============================================================
    // AGREGAR PERSONA
    // ============================================================
    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters
        {
            ["Model"] = new AnirWorkPersonDto()
        };

        var dialog = await DialogService.ShowAsync<AnirWorkPersonDialog>(
            "Agregar persona", parameters);

        var result = await dialog.Result;

        if (!result.Canceled && result.Data is AnirWorkPersonDto dto)
        {
            if (Persons.Any(x => x.PersonId == dto.PersonId))
            {
                await AlertService.ShowError("Error", "Esta persona ya está asociada.");
                return;
            }

            Persons.Add(dto);
        }
    }


    // ============================================================
    // EDITAR PERSONA
    // ============================================================
    private async Task OpenEditDialog(AnirWorkPersonDto person)
    {
        var parameters = new DialogParameters
        {
            ["Model"] = new AnirWorkPersonDto
            {
                Id = person.Id,
                PersonId = person.PersonId,
                PersonName = person.PersonName,
                ParticipationPercentage = person.ParticipationPercentage
            }
        };

        var dialog = await DialogService.ShowAsync<AnirWorkPersonDialog>(
            "Editar persona", parameters);

        var result = await dialog.Result;

        if (!result.Canceled && result.Data is AnirWorkPersonDto dto)
        {
            person.PersonId = dto.PersonId;
            person.PersonName = dto.PersonName;
            person.ParticipationPercentage = dto.ParticipationPercentage;
        }
    }


    // ============================================================
    // ELIMINAR PERSONA
    // ============================================================
    private async Task RemovePerson(AnirWorkPersonDto person)
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "Eliminar persona",
            $"¿Eliminar a {person.PersonName}?",
            type: "Delete",
            confirmText: "Eliminar",
            centerMessage: true
        );

        if (!confirmed)
            return;

        Persons.Remove(person);
    }
}
