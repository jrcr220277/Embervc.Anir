@namespace Anir.Client.Pages.AnirWork.Components
@using MudBlazor
@using Anir.Shared.Contracts.AnirWorks.Presentations

<MudDialog>

    <DialogContent>

        <EditForm Model="_local" OnValidSubmit="Submit">
            <DataAnnotationsValidator />

            <MudGrid Spacing="2">

                <MudItem xs="12">
                    <MudDatePicker Label="Fecha de presentación"
                                   Date="@_dateValue"
                                   DateChanged="OnDateChanged"
                                   Required="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   FullWidth="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField Label="Notas"
                                  @bind-Value="_local.Notes"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  Lines="3" />
                </MudItem>

            </MudGrid>

        </EditForm>

    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Guardar</MudButton>
    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public AnirWorkPresentationDto Model { get; set; } = new();

    private AnirWorkPresentationDto _local = new();

    protected override void OnParametersSet()
    {
        _local = new AnirWorkPresentationDto
        {
            Id = Model.Id,
            Notes = Model.Notes,
            PresentationDate = Model.PresentationDate
        };
    }

    private DateTime? _dateValue
    {
        get => _local.PresentationDate?.ToDateTime(TimeOnly.MinValue);
        set
        {
            if (value.HasValue)
                _local.PresentationDate = DateOnly.FromDateTime(value.Value);
        }
    }

    private Task OnDateChanged(DateTime? value)
    {
        if (value.HasValue)
            _local.PresentationDate = DateOnly.FromDateTime(value.Value);

        return Task.CompletedTask;
    }

    private void Cancel() => Dialog.Cancel();

    private void Submit()
    {
        Model.PresentationDate = _local.PresentationDate;
        Model.Notes = _local.Notes;

        Dialog.Close(DialogResult.Ok(Model));
    }
}
