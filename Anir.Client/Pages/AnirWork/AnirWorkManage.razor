@page "/anirworks/create"
@page "/anirworks/edit/{Id:int}"
@page "/anirworks/view/{Id:int}"

@using Anir.Client.Pages.AnirWork
@using Anir.Client.Services.Ueb
@using Anir.Shared.Contracts.Uebs
@using MudBlazor
@using Anir.Shared.Contracts.AnirWorks
@using Anir.Client.Services.AnirWorks

@using Anir.Client.Services
@using Anir.Client.Components.File


<MudContainer MaxWidth="MaxWidth.False" Class="px-3">

    <!-- ============================================================
         ENCABEZADO PROFESIONAL
    ============================================================ -->
    <MudGrid Class="mb-2">
        <MudItem xs="12">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.TwoTone.Work" Style="font-size: 3rem;" />
             
                <div class="ml-3">
                    <MudText Typo="Typo.h5" Class="font-weight-bold">
                        @(IsViewMode ? "Ver Trabajo ANIR" : Id == null ? "Crear Trabajo ANIR" : "Editar Trabajo ANIR")
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Gestión integral de trabajos ANIR
                    </MudText>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudDivider Class="mb-3" />
   
    @if (IsInitializingPage)
    {
        <UiLoading Indeterminate="true" Message="Cargando datos..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }
    else
    {
        <!-- ============================================================
             LAYOUT PRINCIPAL: SIDEBAR + CONTENIDO
        ============================================================ -->
        <EditForm Model="_formModel" OnValidSubmit="Save">
            <DataAnnotationsValidator />

            <MudGrid Spacing="3">

                <!-- ============================================================
                     SIDEBAR FIJO (columna izquierda)
                ============================================================ -->
                <MudItem xs="12" md="3">

                    <MudPaper Class="pa-3" Elevation="1" Outlined="true">

                        <!-- IMAGEN -->
                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-semibold">
                            Imagen
                        </MudText>
                        
                        <PhotoUploader @ref="PhotoUploaderRef"
                                       Value="@_formModel.ImageUrl"
                                       IsProfile="false"
                                       Size="250"
                                       OnChanged="HandleImageChanged"
                                       IsViewMode="IsViewMode" />


                        <MudDivider Class="my-3" />

                        <!-- PDF -->
                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-semibold">
                            Documento PDF
                        </MudText>

                        @if (!IsViewMode)
                        {
                            <PdfUploader Value="@_formModel.PdfUrl"
                                       OnChanged="HandlePdfChanged" />
                        }

                        @if (!string.IsNullOrEmpty(_formModel.PdfUrl))
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Outlined.PictureAsPdf"
                                       Href="@_formModel.PdfUrl"
                                       Target="_blank"
                                       Dense="true"
                                       Class="mt-1">
                                Ver PDF
                            </MudButton>

                            @if (!IsViewMode)
                            {
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Error"
                                           Dense="true"
                                           OnClick="DeletePdf">
                                    Eliminar
                                </MudButton>
                            }
                        }

                    </MudPaper>

                </MudItem>

                <!-- ============================================================
                     CONTENIDO PRINCIPAL (columna derecha)
                ============================================================ -->
                <MudItem xs="12" md="9">

                    <MudPaper Class="pa-3" Elevation="1" Outlined="true">

                        <MudTabs Vertical="true" ApplyEffectsToContainer="true" Border="true"  TabPanelsClass="pa-3">

                            <!-- DATOS GENERALES -->
                            <MudTabPanel Text="Datos generales" Icon="@Icons.Material.Outlined.Info">
                                           
                                <!-- ============================================================
                                         PAPER 1 — DATOS DE REGISTRO
                                 ============================================================ -->
                                <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                                    <MudText Typo="Typo.subtitle1" Class="mb-2 font-weight-bold">
                                        Datos de Registro
                                    </MudText>

                                    <MudGrid Spacing="2">

                                        <!-- ORGANIZACIÓN -->
                                        <!-- COMPANY -->
                                        <MudItem xs="12" md="6">
                                            <MudSelect T="int"
                                                       Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.CompanyId)"
                                                       Value="_formModel.CompanyId"
                                                       ValueChanged="OnCompanyChanged"
                                                       Variant="Variant.Outlined"
                                                       Required="true"
                                                       Strict="true"
                                                       FullWidth="true"
                                                       Margin="Margin.Dense"
                                                       Dense="true">
                                                <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                                @foreach (var item in AllCompanies)
                                                {
                                                    <MudSelectItem T="int" Value="@item.Id">
                                                        @($"{item.ShortName} – {item.Name}")
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>

                                        <!-- UEB -->
                                        <MudItem xs="12" md="6">
                                            <MudSelect T="int"
                                                       Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.UebId)"
                                                       @bind-Value="_formModel.UebId"
                                                       Variant="Variant.Outlined"
                                                       Required="true"
                                                       Strict="true"
                                                       FullWidth="true"
                                                       Margin="Margin.Dense"
                                                       Dense="true">
                                                <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                                @foreach (var item in FilteredUebs)
                                                {
                                                    <MudSelectItem T="int" Value="@item.Id">
                                                        @($"{item.Code} - {item.Name}")
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>


                                        <!-- DATOS BASE -->
                                        <MudItem xs="12" md="6">
                                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.AnirNumber)"
                                                          @bind-Value="_formModel.AnirNumber"
                                                          Variant="Variant.Outlined"
                                                          Required="true"
                                                          FullWidth="true"
                                                          Margin="Margin.Dense"
                                                          Clearable="true" />
                                        </MudItem>

                                        <MudItem xs="12" md="6">
                                            <MudDatePicker Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Date)"
                                                           Date="@_formModel.Date.ToDateTime(TimeOnly.MinValue)"
                                                           DateChanged="@(d => _formModel.Date = DateOnly.FromDateTime(d ?? DateTime.Now))"
                                                           Disabled="IsViewMode"
                                                           Variant="Variant.Outlined"
                                                           Required="true"
                                                           Margin="Margin.Dense"
                                                           Clearable="true" />
                                        </MudItem>
                                                
                                        <MudItem xs="12">
                                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Title)"
                                                          @bind-Value="_formModel.Title"
                                                          Variant="Variant.Outlined"
                                                          Required="true"
                                                          FullWidth="true"
                                                          Margin="Margin.Dense"
                                                          Clearable="true" />
                                        </MudItem>

                                        <MudItem xs="12">
                                            <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Description)"
                                                          @bind-Value="_formModel.Description"
                                                          Variant="Variant.Outlined"
                                                          FullWidth="true"
                                                          Margin="Margin.Dense"
                                                          Lines="3"
                                                          Clearable="true" />
                                        </MudItem>
                                   
                                    </MudGrid>
                                    
                                </MudPaper>

                                <!-- 🧩 PAPER 1 — ESTADO -->
                                <MudPaper Elevation="1" Class="pa-3 mt-4" Outlined="true">
                                    <MudGrid Spacing="2">
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Dictamen Tecnico</MudText>
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            <MudSelect T="JobState"
                                                       Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.State)"
                                                       @bind-Value="_formModel.State"
                                                       Variant="Variant.Outlined"
                                                       Required="true"
                                                       Strict="true"
                                                       FullWidth="true"
                                                       Margin="Margin.Dense"
                                                       Dense="true">
                                                @foreach (var value in Enum.GetValues<JobState>())
                                                {
                                                    <MudSelectItem Value="@value">@value.ToString()</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            <MudTextField Label="Número de Resolución"
                                                          @bind-Value="_formModel.ResolutionNumber"
                                                          Disabled="IsViewMode"
                                                          Variant="Variant.Outlined"
                                                          Margin="Margin.Dense"
                                                          Dense="true"
                                                          Class="w-100" />
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            <MudNumericField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.EconomicImpact)"
                                                             @bind-Value="_formModel.EconomicImpact"
                                                             Disabled="IsViewMode"
                                                             Variant="Variant.Outlined"
                                                             Margin="Margin.Dense"
                                                             Dense="true"
                                                             Clearable="true" />
                                        </MudItem>
                                                
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">Clasificacion</MudText>
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            <MudSelect T="JobCategory"
                                                       Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Category)"
                                                       @bind-Value="_formModel.Category"
                                                       Variant="Variant.Outlined"
                                                       Required="true"
                                                       Strict="true"
                                                       FullWidth="true"
                                                       Margin="Margin.Dense"
                                                       Dense="true">
                                                @foreach (var value in Enum.GetValues<JobCategory>())
                                                {
                                                    <MudSelectItem Value="@value">@value.ToString()</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                            
                                        <MudItem xs="12" md="2">
                                            <MudSwitch @bind-Value="_formModel.HasSocialEffect"
                                                       Disabled="IsViewMode"
                                                       LabelPlacement="Placement.End"
                                                       Dense="true">
                                                Efecto Social
                                            </MudSwitch>
                                        </MudItem>

                                        <MudItem xs="12" md="2">
                                            <MudSwitch @bind-Value="_formModel.HasEconomicEffect"
                                                       Disabled="IsViewMode"
                                                       LabelPlacement="Placement.End"
                                                       Dense="true">
                                                Efecto Económico
                                            </MudSwitch>
                                        </MudItem>

                                        <MudItem xs="12" md="4">
                                            <MudSelect T="GeneralizationStatus"
                                                       Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Generalization)"
                                                       @bind-Value="_formModel.Generalization"
                                                       Variant="Variant.Outlined"
                                                       Required="true"
                                                       Strict="true"
                                                       FullWidth="true"
                                                       Margin="Margin.Dense"
                                                       Dense="true">
                                                @foreach (var value in Enum.GetValues<GeneralizationStatus>())
                                                {
                                                    <MudSelectItem Value="@value">@value.ToString()</MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudText Typo="Typo.subtitle2" Class="mb-2 font-weight-bold">
                                                Experimental
                                            </MudText>
                                        </MudItem>
                                                                               

                                        <MudItem xs="12" md="4">
                                            <MudSwitch @bind-Value="_formModel.IsExperimental"
                                                       Disabled="IsViewMode"
                                                       LabelPlacement="Placement.End"
                                                       Dense="true">
                                                Es Experimental
                                            </MudSwitch>
                                        </MudItem>

                                        @if (_formModel.IsExperimental)
                                        {
                                            <MudItem xs="12" md="4">
                                                <MudDatePicker Label="Fecha Inicio Experimental"
                                                               Date="@_formModel.ExperimentalStartDate"
                                                               DateChanged="@(d => _formModel.ExperimentalStartDate = d)"
                                                               Disabled="IsViewMode"
                                                               Variant="Variant.Outlined"
                                                               Margin="Margin.Dense"
                                                               Dense="true"
                                                               Clearable="true" />
                                            </MudItem>

                                            <MudItem xs="12" md="4">
                                                <MudDatePicker Label="Fecha Fin Experimental"
                                                               Date="@_formModel.ExperimentalEndDate"
                                                               DateChanged="@(d => _formModel.ExperimentalEndDate = d)"
                                                               Disabled="IsViewMode"
                                                               Variant="Variant.Outlined"
                                                               Margin="Margin.Dense"
                                                               Dense="true"
                                                               Clearable="true" />
                                            </MudItem>
                                        }

    
                                    </MudGrid>         
                                </MudPaper>
                                                                     

                            </MudTabPanel>

                            <!-- PERSONAS -->
                            <MudTabPanel Text="Personas" Icon="@Icons.Material.Outlined.Group">
                                <AnirWorkPersonsSection Persons="_formModel.Persons" IsViewMode="IsViewMode" />
                            </MudTabPanel>

                            <!-- PRESENTACIONES -->
                            <MudTabPanel Text="Presentaciones" Icon="@Icons.Material.Outlined.PresentToAll">
                                <AnirWorkPresentationsSection Presentations="_formModel.Presentations" IsViewMode="IsViewMode" />
                            </MudTabPanel>

                            <!-- ADMINISTRATIVO (DETALLE) -->
                            <MudTabPanel Text="Administrativo" Icon="@Icons.Material.Outlined.AdminPanelSettings">

                                <MudTextField Label="Recomendaciones"
                                              @bind-Value="_formModel.Recommendations"
                                              Disabled="IsViewMode"
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              Lines="3"
                                              Class="w-100" />

                            </MudTabPanel>

                        </MudTabs>

                    </MudPaper>

                </MudItem>

            </MudGrid>

            <!-- ============================================================
                 FOOTER DE ACCIONES
            ============================================================ -->
            <MudStack Row="true"
                      Spacing="1"
                      Class="mt-4"
                      Justify="Justify.FlexEnd">

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Dense="true"
                           OnClick="Back">
                    @(IsViewMode ? "Volver" : "Cancelar")
                </MudButton>

                @if (!IsViewMode)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               ButtonType="ButtonType.Submit"
                               Dense="true">
                        Guardar
                    </MudButton>
                }
                <MudAlert Severity="Severity.Info">
                    Personas: @_formModel.Persons?.Count — Presentaciones: @_formModel.Presentations?.Count
                </MudAlert>

            </MudStack>

        </EditForm>
    }
</MudContainer>

@code {
    [Inject] private ICompanyService CompanyService { get; set; } = default!;
    [Inject] private IUebService UebService { get; set; } = default!;
    [Inject] private IAnirWorkService WorkService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private FileService FileService { get; set; } = default!;


    [Parameter] public int? Id { get; set; }
    
    private bool IsInitializingPage = true;
    private bool IsViewMode => Nav.Uri.Split('?')[0].EndsWith("/view");
    private PhotoUploader? PhotoUploaderRef;

    // ============================================================
    // UBICACIÓN
    // ============================================================
    private List<CompanyDto> AllCompanies = new();
    private List<UebDto> FilteredUebs = new();

    private AnirWorkDto _formModel = new();
    private List<CompanyDto> Companies = new();

    void OnExperimentalChanged(bool value)
    {
        _formModel.IsExperimental = value;
        StateHasChanged(); // 🔥 fuerza el re-render
    }

    protected override async Task OnInitializedAsync()
    {
        AllCompanies = await CompanyService.GetAllAsync() ?? new();

        var query = new CompanyQueryDto
        {
            Page = 1,
            Size = 9999,
            Sort = "Name"
        };

        var companyResponse = await CompanyService.GetPagedAsync(query);

        if (companyResponse.Result == ResponseStatus.Success)
            Companies = companyResponse.Value!.Items.ToList();
        else
            await AlertService.ShowError("Error", "No se pudieron cargar las empresas.");

        if (Id is null)
        {
            _formModel = new AnirWorkDto
            {
                Persons = new(),
                Presentations = new(),
                IsExperimental = false,
                ExperimentalStartDate = null,
                ExperimentalEndDate = null
            };
        }
        else
        {
            var response = await WorkService.GetByIdAsync(Id.Value);

            if (response?.Result == ResponseStatus.Success)
            {
                _formModel = response.Value!;
                // ⭐ Inicializar UEBs filtradas según la empresa ya guardada
                if (_formModel.CompanyId != 0)
                    FilteredUebs = await UebService.GetByCompanyIdAsync(_formModel.CompanyId) ?? new();
            }
            else
            {
                await AlertService.ShowError("Error", "No se pudo cargar el trabajo.");
                Nav.NavigateTo("/anirworks");
                return;
            }
        }
       
        IsInitializingPage = false;
    }

    private Task HandleImageChanged(FileResponse? file)
    {
        return Task.CompletedTask;
    }


    private void HandlePdfChanged(FileResponse? file)
    {
        _formModel.PdfId = file?.Id;
        _formModel.PdfUrl = file?.Url;
    }

    private void DeletePdf()
    {
        _formModel.PdfId = null;
        _formModel.PdfUrl = null;
    }

    private async Task OnCompanyChanged(int companyId)
    {
        _formModel.CompanyId = companyId;

        // Traer UEBs filtradas desde el backend
        FilteredUebs = await UebService.GetByCompanyIdAsync(companyId) ?? new();

        // Resetear selección si no corresponde
        if (!FilteredUebs.Any(u => u.Id == _formModel.UebId))
            _formModel.UebId = 0;

        StateHasChanged();
    }

    private async Task Save()
    {
        if (IsViewMode)
            return;

        // ⭐ 1. Subir imagen si hay una pendiente
        var pendingImage = PhotoUploaderRef?.GetPendingFile();
        if (pendingImage is not null)
        {
            var uploaded = await FileService.UploadAsync(pendingImage);
            _formModel.ImageId = uploaded.Id;
            _formModel.ImageUrl = uploaded.Url;
        }

        // ⭐ 2. Subir PDF si hay uno pendiente
        // var pendingPdf = PdfUploaderRef?.GetPendingFile();
        // if (pendingPdf is not null)
        // {
        //     var uploaded = await FileService.UploadAsync(pendingPdf);
        //     _formModel.PdfId = uploaded.Id;
        //     _formModel.PdfUrl = uploaded.Url;
        // }

        // ⭐ 3. Guardar la entidad
        ProcessResponse<AnirWorkDto>? response =
            Id is null
            ? await WorkService.CreateAsync(_formModel)
            : await WorkService.UpdateAsync(_formModel.Id, _formModel);

        if (response?.Result == ResponseStatus.Success)
        {
            await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
            Nav.NavigateTo("/anirworks");
        }
        else
        {
            await AlertService.ShowError("Error", response?.PrettyMessage ?? "Error al guardar.");
        }
    }


    private void Back() => Nav.NavigateTo("/anirworks");
}

