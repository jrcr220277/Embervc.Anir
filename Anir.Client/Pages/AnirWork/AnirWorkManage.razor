@page "/anirworks/create"
@page "/anirworks/edit/{Id:int}"
@page "/anirworks/view/{Id:int}"

@using Anir.Client.Services.Ueb
@using Anir.Shared.Contracts.Uebs
@using Anir.Shared.Enums
@using MudBlazor
@using Anir.Shared.Contracts.AnirWorks
@using Anir.Client.Services.AnirWorks
@using Anir.Client.Services
@using Anir.Client.Components.File

<style>
    .sticky-footer {
        position: sticky;
        bottom: 0;
        z-index: 10;
        background-color: var(--mud-palette-background);
        border-top: 1px solid var(--mud-palette-lines-default);
    }
</style>

<MudContainer MaxWidth="MaxWidth.False" Class="px-3 pb-6">

    <!-- ENCABEZADO -->
    <MudGrid Class="mb-2">
        <MudItem xs="12">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.TwoTone.Work" Style="font-size: 3rem;" />
                <div class="ml-3">
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@(IsViewMode ? "Ver Trabajo ANIR" : Id == null ? "Crear Trabajo ANIR" : "Editar Trabajo ANIR")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Gestión integral de trabajos ANIR</MudText>
                </div>
            </div>
        </MudItem>
    </MudGrid>
    <MudDivider Class="mb-4" />
   
    @if (IsInitializingPage)
    {
        <UiLoading Indeterminate="true" Message="Cargando datos..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }
    else
    {
        <EditForm Model="_formModel" OnValidSubmit="Save" id="anir-work-form">
            <DataAnnotationsValidator />
            
            <MudStack Spacing="3">
                
                <!-- SECCIÓN 1: DATOS GENERALES Y MULTIMEDIA -->
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <div class="d-flex align-center mb-3">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="mr-2" Color="Color.Primary" />
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Datos Generales</MudText>
                    </div>
                    
                    <MudGrid Spacing="4" AlignItems="AlignItems.Start">
                        
                        <!-- COLUMNA IZQUIERDA: ARCHIVOS -->
                        <MudItem xs="12" md="4">
                            <MudStack Spacing="3">
                                <div class="d-flex justify-center">
                                    <PhotoUploader Value="@(_formModel.ImageFile?.Url)" IsProfile="false" PixelSize="220" Folder="images/works" OnUploaded="HandleImageUploaded" IsViewMode="IsViewMode" />
                                </div>
                                
                                <div>
                                    <PdfUploader Label="Documento PDF" Value="@(_formModel.PdfFile?.Url)" OnUploaded="HandlePdfUploaded" Folder="docs/works" IsViewMode="IsViewMode" />
                                </div>
                            </MudStack>
                        </MudItem>

                        <!-- COLUMNA DERECHA: CAMPOS DE TEXTO -->
                        <MudItem xs="12" md="8">
                            <MudGrid Spacing="2">
                                <MudItem xs="12" md="6">
                                    <MudSelect T="int" Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.CompanyId)" Value="_formModel.CompanyId" ValueChanged="OnCompanyChanged" Variant="Variant.Outlined" Required="true" Strict="true" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode">
                                        <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                        @foreach (var item in AllCompanies)
                                        {
                                            <MudSelectItem T="int" Value="@item.Id">@($"{item.ShortName} – {item.Name}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudSelect T="int" Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.UebId)" @bind-Value="_formModel.UebId" Variant="Variant.Outlined" Required="true" Strict="true" FullWidth="true" Margin="Margin.Dense" Disabled="@(_formModel.CompanyId == 0 || IsViewMode || _isLoadingUebs)" Loader="@(_isLoadingUebs && _formModel.CompanyId != 0)">
                                        <MudSelectItem T="int" Value="0">@(_isLoadingUebs ? "Cargando..." : "- Seleccionar -")</MudSelectItem>
                                        @foreach (var item in FilteredUebs)
                                        {
                                            <MudSelectItem T="int" Value="@item.Id">@($"{item.Code} - {item.Name}")</MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.AnirNumber)" @bind-Value="_formModel.AnirNumber" Variant="Variant.Outlined" Required="true" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode" Clearable="true" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudDatePicker Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Date)" Date="@_formModel.Date.ToDateTime(TimeOnly.MinValue)" DateChanged="@(d => _formModel.Date = DateOnly.FromDateTime(d ?? DateTime.Now))" Disabled="IsViewMode" Variant="Variant.Outlined" Required="true" Margin="Margin.Dense" Clearable="true" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Title)" @bind-Value="_formModel.Title" Variant="Variant.Outlined" Required="true" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode" Clearable="true" />
                                </MudItem>
                                <MudItem xs="12">
                                    <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Description)" @bind-Value="_formModel.Description" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" Lines="5" Disabled="IsViewMode" Clearable="true" />
                                </MudItem>
                            </MudGrid>
                        </MudItem>

                    </MudGrid>
                </MudPaper>

                <!-- SECCIÓN 2: TÉCNICO Y EVALUACIÓN -->
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudGrid Spacing="4">
                        
                        <!-- Columna Izquierda: Técnicas -->
                        <MudItem xs="12" md="6">
                            <div class="d-flex align-center mb-3">
                                <MudIcon Icon="@Icons.Material.Outlined.Science" Class="mr-2" Color="Color.Secondary" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Características Técnicas</MudText>
                            </div>
                            <MudStack Spacing="2">
                                <MudSwitch Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.HasSocialEffect)" Color="Color.Success" @bind-Value="_formModel.HasSocialEffect" Disabled="IsViewMode" />
                                <MudSwitch Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.HasEconomicEffect)" Color="Color.Info" @bind-Value="_formModel.HasEconomicEffect" Disabled="IsViewMode" />
                                <MudSelect T="JobCategory" Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Category)" @bind-Value="_formModel.Category" Variant="Variant.Outlined" Required="true" Strict="true" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode">
                                    @foreach (var value in Enum.GetValues<JobCategory>())
                                    {
                                        <MudSelectItem Value="@value">@value.ToString()</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudSelect T="GeneralizationStatus" Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Generalization)" @bind-Value="_formModel.Generalization" Variant="Variant.Outlined" Required="true" Strict="true" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode">
                                    @foreach (var value in Enum.GetValues<GeneralizationStatus>())
                                    {
                                        <MudSelectItem Value="@value">@value.ToString()</MudSelectItem>
                                    }
                                </MudSelect>
                                
                                <MudDivider Class="my-2" />
                                
                                <MudSwitch Label="¿Es experimental?" Color="Color.Warning" @bind-Value="_formModel.IsExperimental" Disabled="IsViewMode" />
                                <MudGrid Spacing="2">
                                    <MudItem xs="6">
                                        <MudDatePicker Label="Fecha Inicio" Date="@_formModel.ExperimentalStartDate" Disabled="@(!_formModel.IsExperimental || IsViewMode)" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" />
                                    </MudItem>
                                    <MudItem xs="6">
                                        <MudDatePicker Label="Fecha Fin" Date="@_formModel.ExperimentalEndDate" Disabled="@(!_formModel.IsExperimental || IsViewMode)" Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Clearable="true" />
                                    </MudItem>
                                </MudGrid>
                            </MudStack>
                        </MudItem>

                        <!-- Columna Derecha: Evaluación y Economía -->
                        <MudItem xs="12" md="6">
                            <div class="d-flex align-center mb-3">
                                <MudIcon Icon="@Icons.Material.Outlined.AttachMoney" Class="mr-2" Color="Color.Secondary" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">Evaluación y Economía</MudText>
                            </div>
                            <MudStack Spacing="2">
                                <MudSelect T="JobState" Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.State)" @bind-Value="_formModel.State" Variant="Variant.Outlined" Required="true" Strict="true" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode">
                                    @foreach (var value in Enum.GetValues<JobState>())
                                    {
                                        <MudSelectItem Value="@value">@value.ToString()</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ResolutionNumber)" @bind-Value="_formModel.ResolutionNumber" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode" Clearable="true" />
                                <MudNumericField T="decimal" Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.EconomicImpact)" @bind-Value="_formModel.EconomicImpact" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" Disabled="IsViewMode" Min="0" />
                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Recommendations)" @bind-Value="_formModel.Recommendations" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" Lines="5" Disabled="IsViewMode" Clearable="true" />
                            </MudStack>
                        </MudItem>

                    </MudGrid>
                </MudPaper>

                <!-- SECCIÓN 3: RELACIONES -->
                <MudPaper Elevation="0" Outlined="true" Class="pa-4">
                    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">
                        <MudTabPanel Text="Personas" Icon="@Icons.Material.Outlined.Group">
                            @if (_formModel.Persons != null)
                            {
                                <AnirWorkPersonsSection Persons="_formModel.Persons" IsViewMode="IsViewMode" />
                            }
                        </MudTabPanel>
                        <MudTabPanel Text="Presentaciones" Icon="@Icons.Material.Outlined.PresentToAll">
                            @if (_formModel.Presentations != null)
                            {
                                <AnirWorkPresentationsSection Presentations="_formModel.Presentations" IsViewMode="IsViewMode" />
                            }
                        </MudTabPanel>
                    </MudTabs>
                </MudPaper>

            </MudStack>

            <!-- FOOTER PEGAJOSO -->
            <div class="sticky-footer pa-3 mt-4">
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" AlignItems="AlignItems.Center">
                    <MudButton Variant="Variant.Text" OnClick="Back" Disabled="_isSaving">
                        @(IsViewMode ? "Volver" : "Cancelar")
                    </MudButton>
                    @if (!IsViewMode)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Disabled="_isSaving || !AllCompanies.Any()" Size="Size.Large">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Guardando...</span>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Save" Class="mr-2" />
                                <span>Guardar Trabajo</span>
                            }
                        </MudButton>
                    }
                </MudStack>
            </div>
            
        </EditForm>
    }
</MudContainer>

@code {
    [Inject] private ICompanyService CompanyService { get; set; } = default!;
    [Inject] private IUebService UebService { get; set; } = default!;
    [Inject] private IAnirWorkService WorkService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    [Parameter] public int? Id { get; set; }

    private bool IsInitializingPage = true;
    private bool IsViewMode => Nav.ToBaseRelativePath(Nav.Uri).StartsWith("view", StringComparison.OrdinalIgnoreCase);

    private bool _isSaving = false;
    private bool _isLoadingUebs = false;

    private List<CompanyDto> AllCompanies = new();
    private List<UebDto> FilteredUebs = new();
    private AnirWorkDto _formModel = new();

    protected override async Task OnInitializedAsync()
    {
        // Usamos CancellationToken.None por simplicidad, pero se podría propagar
        var companyResponse = await CompanyService.GetPagedAsync(new CompanyQueryDto { Page = 1, Size = 9999, Sort = "Name" });
        if (companyResponse.Result == ResponseStatus.Success && companyResponse.Value != null)
            AllCompanies = companyResponse.Value.Items.ToList();
        else
            await AlertService.ShowError("Error", "No se pudieron cargar las empresas. No se puede continuar.");

        if (Id is null)
        {
            _formModel = new AnirWorkDto { Persons = new(), Presentations = new(), IsExperimental = false };
        }
        else
        {
            var response = await WorkService.GetByIdAsync(Id.Value);
            if (response?.Result == ResponseStatus.Success)
            {
                _formModel = response.Value!;
                if (_formModel.CompanyId != 0)
                    FilteredUebs = await UebService.GetByCompanyIdAsync(_formModel.CompanyId) ?? new();
            }
            else
            {
                await AlertService.ShowError("Error", "No se pudo cargar el trabajo.");
                Nav.NavigateTo("/anirworks");
                return;
            }
        }
        IsInitializingPage = false;
    }

    private Task HandleImageUploaded(FileResponse? file)
    {
        _formModel.ImageFile = file;
        return Task.CompletedTask;
    }
    
    private Task HandlePdfUploaded(FileResponse? file)
    {
        _formModel.PdfFile = file;
        return Task.CompletedTask;
    }

    private async Task Save()
    {
        if (!AllCompanies.Any())
        {
            await AlertService.ShowError("Error", "No hay empresas cargadas. Recargue la página.");
            return;
        }

        _isSaving = true;
        try
        {
            var res = Id is null ? await WorkService.CreateAsync(_formModel) : await WorkService.UpdateAsync(Id.Value, _formModel);
            if (res?.Result == ResponseStatus.Success)
            {
                await AlertService.ShowSuccess("Éxito", Id is null ? "Trabajo creado correctamente." : "Trabajo actualizado correctamente.");
                Nav.NavigateTo("/anirworks");
            }
            else
            {
                await AlertService.ShowError("Error", res?.ErrorMessage ?? res?.PrettyMessage ?? "Error al guardar.");
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task OnCompanyChanged(int companyId)
    {
        _formModel.CompanyId = companyId;
        _formModel.UebId = 0;
        FilteredUebs = new();
        if (companyId > 0)
        {
            _isLoadingUebs = true;
            try
            {
                FilteredUebs = await UebService.GetByCompanyIdAsync(companyId) ?? new();
            }
            catch
            {
                await AlertService.ShowError("Error", "No se pudieron cargar las UEBs.");
            }
            finally
            {
                _isLoadingUebs = false;
            }
        }
    }

    private void Back() => Nav.NavigateTo("/anirworks");
}