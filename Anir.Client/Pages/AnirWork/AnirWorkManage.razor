@page "/anirworks/create"
@page "/anirworks/edit/{Id:int}"
@page "/anirworks/view/{Id:int}"

@using Anir.Client.Pages.AnirWork
@using Anir.Client.Services.Ueb
@using Anir.Shared.Contracts.Uebs
@using MudBlazor
@using Anir.Shared.Contracts.AnirWorks
@using Anir.Client.Services.AnirWorks
@using Anir.Client.Services.Files
@using Anir.Client.Services

@inject IAnirWorkService WorkService

@inject IAlertService AlertService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.False" Class="px-3">

    <!-- ============================================================
         ENCABEZADO PROFESIONAL
    ============================================================ -->
    <MudGrid Class="mb-2">
        <MudItem xs="12">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.TwoTone.Work" Style="font-size: 3rem;" />
             
                <div class="ml-3">
                    <MudText Typo="Typo.h5" Class="font-weight-bold">
                        @(IsViewMode ? "Ver Trabajo ANIR" : Id == null ? "Crear Trabajo ANIR" : "Editar Trabajo ANIR")
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Gestión integral de trabajos ANIR
                    </MudText>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudDivider Class="mb-3" />
   
    @if (IsInitializingPage)
    {
        <UiLoading Indeterminate="true" Message="Cargando datos..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }
    else
    {
        <!-- ============================================================
             LAYOUT PRINCIPAL: SIDEBAR + CONTENIDO
        ============================================================ -->
        <EditForm Model="_formModel" OnValidSubmit="Save">
            <DataAnnotationsValidator />

            <MudGrid Spacing="3">

                <!-- ============================================================
                     SIDEBAR FIJO (columna izquierda)
                ============================================================ -->
                <MudItem xs="12" md="3">

                    <MudPaper Class="pa-3" Elevation="1" Outlined="true">

                        <!-- IMAGEN -->
                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-semibold">
                            Imagen
                        </MudText>

                        <PhotoUploader Value="@_formModel.ImageUrl"
                                       IsProfile="false"
                                       Size="350"
                                       OnChanged="HandleImageChanged"
                                       IsViewMode="IsViewMode" />

                        <MudDivider Class="my-3" />

                        <!-- PDF -->
                        <MudText Typo="Typo.subtitle2" Class="mb-1 font-weight-semibold">
                            Documento PDF
                        </MudText>

                        @if (!IsViewMode)
                        {
                            <PdfUploader Value="@_formModel.PdfUrl"
                                       OnChanged="HandlePdfChanged" />
                        }

                        @if (!string.IsNullOrEmpty(_formModel.PdfUrl))
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Outlined.PictureAsPdf"
                                       Href="@_formModel.PdfUrl"
                                       Target="_blank"
                                       Dense="true"
                                       Class="mt-1">
                                Ver PDF
                            </MudButton>

                            @if (!IsViewMode)
                            {
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Error"
                                           Dense="true"
                                           OnClick="DeletePdf">
                                    Eliminar
                                </MudButton>
                            }
                        }

                    </MudPaper>

                </MudItem>

                <!-- ============================================================
                     CONTENIDO PRINCIPAL (columna derecha)
                ============================================================ -->
                <MudItem xs="12" md="9">

                    <MudPaper Class="pa-3" Elevation="1" Outlined="true">

                        <MudTabs Vertical="true"
                                 ApplyEffectsToContainer="true"
                                 Border="true"
                                 TabPanelsClass="pa-3">

                            <!-- DATOS GENERALES -->
                            <MudTabPanel Text="Datos generales" Icon="@Icons.Material.Outlined.Info">

                                <MudGrid Spacing="2">

                                    <!-- Empresa -->
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="int"
                                                   Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.CompanyId)"
                                                   @bind-Value="_formModel.CompanyId"
                                                   Variant="Variant.Outlined"
                                                   Required="true"
                                                   Strict="true"
                                                   FullWidth="true"
                                                   Margin="Margin.Dense"
                                                   Dense="true">

                                            @foreach (var item in AllCompanies)
                                            {
                                                <MudSelectItem T="int" Value="@item.Id">
                                                    @($"{item.ShortName} – {item.Name}")
                                                </MudSelectItem>
                                            }
                                        </MudSelect>


                                    </MudItem>

                                    <!-- Esptablecimiento -->
                                    <MudItem xs="12" md="6">
                                        <MudSelect T="int"
                                                   Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.UebId)"
                                                   For="@(() => _formModel.UebId)"
                                                   @bind-Value="_formModel.UebId"
                                                   Variant="Variant.Outlined"
                                                   Strict="true"
                                                   Required="true"
                                                   FullWidth="true"
                                                   Margin="Margin.Dense"
                                                   Dense="true">

                                            @foreach (var item in AllUebs)
                                            {
                                                <MudSelectItem T="int?" Value="@item.Id">
                                                    @($"{item.Code} - {item.Name}")
                                                </MudSelectItem>
                                            }
                                        </MudSelect>

                                    </MudItem>

                                    <!-- Número ANIR -->
                                    <MudItem xs="12" md="6">
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.AnirNumber)"
                                                      For="@(() => _formModel.AnirNumber)"
                                                      @bind-Value="_formModel.AnirNumber"
                                                      InputType="InputType.Text"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true" />
                                                                                             
                                    </MudItem>

                                    <!-- Fecha -->
                                    <MudItem xs="12" md="6">
                                        <MudDatePicker Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Date)"
                                                       Date="@_formModel.Date.ToDateTime(TimeOnly.MinValue)"
                                                       DateChanged="@(d => _formModel.Date = DateOnly.FromDateTime(d ?? DateTime.Now))"
                                                       Disabled="IsViewMode"
                                                       Variant="Variant.Outlined"
                                                       Required="true"
                                                       Margin="Margin.Dense"
                                                       Clearable="true" />
                                    </MudItem>

                                    <!-- Título -->
                                    <MudItem xs="12">
                                        <MudTextField Label="Título"
                                                      @bind-Value="_formModel.Title"
                                                      Disabled="IsViewMode"
                                                      Required="true"
                                                      Variant="Variant.Outlined"
                                                      Dense="true"
                                                      Class="w-100" />
                                    </MudItem>

                                    <!-- Descripción -->
                                    <MudItem xs="12">
                                        <MudTextField Label="Descripción"
                                                      @bind-Value="_formModel.Description"
                                                      Disabled="IsViewMode"
                                                      Variant="Variant.Outlined"
                                                      Dense="true"
                                                      Lines="3"
                                                      Class="w-100" />
                                    </MudItem>

                                    <!-- ============================
                                         CAMPOS ADMINISTRATIVOS
                                    ============================ -->

                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Checked="_formModel.HasSocialEffect"
                                                   Disabled="IsViewMode"
                                                   Color="Color.Success"
                                                   Dense="true">
                                            Efecto Social
                                        </MudSwitch>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudSwitch T="bool" @bind-Checked="_formModel.HasEconomicEffect"
                                                   Disabled="IsViewMode"
                                                   Color="Color.Success"
                                                   Dense="true">
                                            Efecto Económico
                                        </MudSwitch>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudSelect T="GeneralizationStatus"
                                                   Label="Generalización"
                                                   @bind-Value="_formModel.Generalization"
                                                   Disabled="IsViewMode"
                                                   Variant="Variant.Outlined"
                                                   Dense="true"
                                                   Class="w-100">
                                            <MudSelectItem Value="GeneralizationStatus.Si">Sí</MudSelectItem>
                                            <MudSelectItem Value="GeneralizationStatus.No">No</MudSelectItem>
                                            <MudSelectItem Value="GeneralizationStatus.Pendiente">Pendiente</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudNumericField T="decimal"
                                                         Label="Impacto Económico"
                                                         @bind-Value="_formModel.EconomicImpact"
                                                         Disabled="IsViewMode"
                                                         Variant="Variant.Outlined"
                                                         Dense="true"
                                                         Class="w-100" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudTextField Label="Número de Resolución"
                                                      @bind-Value="_formModel.ResolutionNumber"
                                                      Disabled="IsViewMode"
                                                      Variant="Variant.Outlined"
                                                      Dense="true"
                                                      Class="w-100" />
                                    </MudItem>

                                </MudGrid>

                            </MudTabPanel>


                            <!-- PERSONAS -->
                            <MudTabPanel Text="Personas" Icon="@Icons.Material.Outlined.Group">
                                <AnirWorkPersonsSection Persons="_formModel.Persons" IsViewMode="IsViewMode" />
                            </MudTabPanel>

                            <!-- PRESENTACIONES -->
                            <MudTabPanel Text="Presentaciones" Icon="@Icons.Material.Outlined.PresentToAll">
                                <AnirWorkPresentationsSection Presentations="_formModel.Presentations" IsViewMode="IsViewMode" />
                            </MudTabPanel>

                            <!-- ADMINISTRATIVO (DETALLE) -->
                            <MudTabPanel Text="Administrativo" Icon="@Icons.Material.Outlined.AdminPanelSettings">

                                <MudTextField Label="Recomendaciones"
                                              @bind-Value="_formModel.Recommendations"
                                              Disabled="IsViewMode"
                                              Variant="Variant.Outlined"
                                              Dense="true"
                                              Lines="3"
                                              Class="w-100" />

                            </MudTabPanel>

                        </MudTabs>

                    </MudPaper>

                </MudItem>

            </MudGrid>

            <!-- ============================================================
                 FOOTER DE ACCIONES
            ============================================================ -->
            <MudStack Row="true"
                      Spacing="1"
                      Class="mt-4"
                      Justify="Justify.FlexEnd">

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Dense="true"
                           OnClick="Back">
                    @(IsViewMode ? "Volver" : "Cancelar")
                </MudButton>

                @if (!IsViewMode)
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               ButtonType="ButtonType.Submit"
                               Dense="true">
                        Guardar
                    </MudButton>
                }
                <MudAlert Severity="Severity.Info">
                    Personas: @_formModel.Persons?.Count — Presentaciones: @_formModel.Presentations?.Count
                </MudAlert>

            </MudStack>

        </EditForm>
    }
</MudContainer>

@code {
    [Inject] private ICompanyService CompanyService { get; set; } = default!;
    [Inject] private IUebService UebService { get; set; } = default!;

    [Parameter] public int? Id { get; set; }
    
    private bool IsInitializingPage = true;
    private bool IsViewMode => Nav.Uri.Contains("/view");

    // ============================================================
    // UBICACIÓN
    // ============================================================
    private List<CompanyDto> AllCompanies = new();
    private List<UebDto> AllUebs = new();

    private AnirWorkDto _formModel = new();
    private List<CompanyDto> Companies = new();


    protected override async Task OnInitializedAsync()
    {
        AllCompanies = await CompanyService.GetAllAsync() ?? new();
        AllUebs = await UebService.GetAllAsync() ?? new();

        var query = new CompanyQueryDto
        {
            Page = 1,
            Size = 9999,
            Sort = "Name"
        };

        var companyResponse = await CompanyService.GetPagedAsync(query);

        if (companyResponse.Result == ResponseStatus.Success)
            Companies = companyResponse.Value!.Items.ToList();
        else
            await AlertService.ShowError("Error", "No se pudieron cargar las empresas.");

        if (Id is null)
        {
            _formModel = new AnirWorkDto
            {
                Persons = new(),
                Presentations = new()
            };
        }
        else
        {
            var response = await WorkService.GetByIdAsync(Id.Value);

            if (response?.Result == ResponseStatus.Success)
                _formModel = response.Value!;
            else
            {
                await AlertService.ShowError("Error", "No se pudo cargar el trabajo.");
                Nav.NavigateTo("/anirworks");
                return;
            }
        }
       
        IsInitializingPage = false;
    }

    private void HandleImageChanged(FileResponse? file)
    {
        _formModel.ImageId = file?.Id;
        _formModel.ImageUrl = file?.Url;
    }

    private void HandlePdfChanged(FileResponse? file)
    {
        _formModel.PdfId = file?.Id;
        _formModel.PdfUrl = file?.Url;
    }

    private void DeletePdf()
    {
        _formModel.PdfId = null;
        _formModel.PdfUrl = null;
    }

    private async Task Save()
    {
        if (IsViewMode)
            return;

        ProcessResponse<AnirWorkDto>? response =
            Id is null
            ? await WorkService.CreateAsync(_formModel)
            : await WorkService.UpdateAsync(_formModel.Id, _formModel);

        if (response?.Result == ResponseStatus.Success)
        {
            await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
            Nav.NavigateTo("/anirworks");
        }
        else
        {
            await AlertService.ShowError("Error", response?.PrettyMessage ?? "Error al guardar.");
        }
    }

    private void Back() => Nav.NavigateTo("/anirworks");
}
