@page "/uebs"
@using Anir.Client.Services.Ueb
@using Anir.Shared.Contracts.Companies
@using Anir.Shared.Contracts.Common
@using Anir.Client.Services.Company
@using Anir.Shared.Contracts.Uebs
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="pa-3">

    @if (IsInitializingPage)
    {
        <UiLoading Indeterminate="true" Message="Cargando datos..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }

    <!-- ============================================================
     ENCABEZADO PRINCIPAL (Profesional, limpio, con jerarquía)
     ============================================================ -->
    <MudGrid Class="mb-2">
        <MudItem xs="12">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.TwoTone.Factory" Style="font-size: 3rem;" />
             
                <div class="ml-3">
                    <MudText Typo="Typo.h5" Class="fw-bold">Clasificador de Establecimientos</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Gestión de establecimientos: búsqueda, filtros y acciones masivas
                    </MudText>
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudDivider Class="mb-3" />

    <!-- ============================================================
     ACTION BAR (Profesional, alineada, con peso visual)
     ============================================================ -->
    <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-3">

        <MudGrid AlignItems="Center">

            <!-- IZQUIERDA (3 columnas) -->
            <MudItem xs="12" sm="3">
                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Rounded.AddCircleOutline"
                           OnClick="OpenAddModal">
                    Agregar
                </MudButton>
            </MudItem>

            <!-- CENTRO (6 columnas, centrado REAL) -->
            <MudItem xs="12" sm="6" Class="d-flex justify-center align-end">
                <MudTextField T="string"
                              Value="@SearchText"
                              ValueChanged="OnSearchInput"
                              Immediate="true"
                              Clearable="true"
                              Placeholder="Buscar..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Rounded.Search" />
            </MudItem>

            <!-- DERECHA (3 columnas, alineado a la derecha) -->
            <MudItem xs="12" sm="3" Class="d-flex justify-end align-end">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@Icons.Material.Rounded.FilterAlt" Size="Size.Medium" />
                    <MudSelect T="string"
                               Value="@StatusFilterValue"
                               ValueChanged="OnStatusFilterChanged"
                               Style="width: 100px;">
                        
                        <MudSelectItem Value=@("Todos")>Todos</MudSelectItem>
                        <MudSelectItem Value=@("Activo")>Activo</MudSelectItem>
                        <MudSelectItem Value=@("Inactivo")>Inactivo</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </MudItem>

        </MudGrid>

    </MudPaper>


    <!-- ============================================================
         ACCIONES MASIVAS (Banner profesional)
         ============================================================ -->
    <MudCollapse Expanded="@(SelectedItems.Any() || IsGlobalSelected)">
        <MudPaper Outlined="true" Elevation="0"
                  Class="px-4 mb-3 d-flex align-center justify-space-between flex-wrap gap-2">

            <!-- IZQUIERDA: Icono + texto corto -->
            <div class="d-flex align-center">

                <MudTooltip Text="@(IsGlobalSelected ? "Cancelar selección global" : "Seleccionar global")" Arrow="true">
                    <MudIconButton Icon="@(IsGlobalSelected
                                                                                                              ? Icons.Material.Filled.Deselect
                                                                                                      : Icons.Material.Filled.SelectAll)"
                                   Edge="Edge.Start"
                                   Color="Color.Primary"
                                   Size="Size.Medium"
                                   OnClick="@(() => ToggleGlobalSelection())" />
                </MudTooltip>

                <MudText Typo="Typo.body2" Class="ml-2 font-weight-medium">
                    @BulkSelectionText
                </MudText>

            </div>


            <!-- DERECHA: Acciones -->
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">

                <MudTooltip Text="Exportar PDF" Arrow="true">
                    <MudIconButton OnClick="@(() => ExportPdf())"
                                   Icon="@Icons.Custom.FileFormats.FilePdf"
                                   Color="Color.Default"
                                   Size="Size.Medium"
                                   aria-label="PDF"
                                   Variant="Variant.Text" />
                </MudTooltip>

                <MudTooltip Text="Exportar Excel" Arrow="true">
                    <MudIconButton OnClick="@(() => ExportExcel())"
                                   Icon="@Icons.Custom.FileFormats.FileExcel"
                                   Color="Color.Default"
                                   Size="Size.Medium"
                                   aria-label="Excel" />
                </MudTooltip>

                <MudTooltip Text="Eliminar seleccionados" Arrow="true">
                    <MudIconButton OnClick="@(() => DeleteSelected())"
                                   Icon="@Icons.Material.Rounded.DeleteForever"
                                   Color="Color.Error"
                                   Size="Size.Medium"
                                   Edge="Edge.End"
                                   aria-label="Eliminar" />
                </MudTooltip>

            </MudStack>

        </MudPaper>
    </MudCollapse>



    <!-- ============================================================
         TABLA PRINCIPAL (Respira, se ve limpia)
     ============================================================ -->
    <MudTable T="UebDto"
              ServerData="ServerReload"
              @ref="TableRef"
              Hover="true"
              Striped="true"
              Dense="true"
              MultiSelection="true"
              @bind-SelectedItems="SelectedItems"
              SelectOnRowClick="false"
              Loading="@IsLoadingTable" 
              HorizontalScrollbar="true" Elevation="0" Outlined="true">

        <HeaderContent>
            <MudTh><MudTableSortLabel T="UebDto" SortLabel="CompanyName">Empresa</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="UebDto" SortLabel="Code">Código</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="UebDto" SortLabel="Name">Nombre</MudTableSortLabel></MudTh>
            @* <MudTh><MudTableSortLabel T="UebDto" SortLabel="Municipality.Province.Name">Provincia</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="UebDto" SortLabel="Municipality.Name">Municipio</MudTableSortLabel></MudTh> *@
            <MudTh><MudTableSortLabel T="UebDto" SortLabel="Active">Estado</MudTableSortLabel></MudTh>
            <MudTh Style="width: 120px; text-align:end">Acciones</MudTh>
        </HeaderContent>

        <RowTemplate Context="Ueb">
            <MudTd>@Ueb.CompanyName</MudTd>
            <MudTd>@Ueb.Code</MudTd>
         
            <MudTd>@Ueb.Name</MudTd>
           @*  <MudTd>@company.ProvinceName</MudTd>
            <MudTd>@company.MunicipalityName</MudTd> *@
            <MudTd>
                <MudChip T="string" Color="@(Ueb.Active? Color.Success: Color.Error)" Variant="Variant.Text" Size="Size.Small">
                    @(Ueb.Active ? "Activa" : "Inactiva")
                </MudChip>
            </MudTd>
            <MudTd Style="width: 120px; text-align:end">
                <MudIconButton Icon="@Icons.Material.Rounded.Visibility" OnClick="@(() => ViewCompany(Ueb))" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Rounded.Edit" OnClick="@(() => EditCompany(Ueb))" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" OnClick="@(() => DeleteCompany(Ueb))" Size="Size.Small" />
            </MudTd>
        </RowTemplate>

        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4 text-center">
                No se encontraron datos para mostrar.
            </MudText>
        </NoRecordsContent>

        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 5, 10, 15, 20, 50, 100, int.MaxValue }"
                           RowsPerPageString="Registros por página:"
                           InfoFormat="{first_item}-{last_item} de {all_items}"
                           AllItemsText="Todos"
                           HorizontalAlignment="HorizontalAlignment.Right" />


        </PagerContent>

    </MudTable>

</MudContainer>



@code {
    // ============================================================
    // DEPENDENCIAS
    // ============================================================
    [Inject] private IUebService UebService { get; set; } = default!;
    [Inject] private ICompanyService CompanyService { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private IConfiguration Config { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [Inject] private ILogger<UebIndex> Logger { get; set; } = default!;
    [Inject] IJSRuntime JS { get; set; } = default!;

    // ============================================================
    // ESTADO GENERAL
    // ============================================================
    private bool IsInitializingPage = true;
    private bool IsLoadingTable = false;
    private bool IsProcessingBulkAction = false;

    private MudTable<UebDto>? TableRef;
    private HashSet<UebDto> SelectedItems = new(new UebDtoComparer());
    
    private bool IsGlobalSelected = false;
    private int _totalFilteredCount = 0;

    private string SearchText = string.Empty;
    private string StatusFilterValue = "Todos";

    private IReadOnlyList<UebDto> LastPageItems = Array.Empty<UebDto>();

    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _serverReloadCts;

   
    protected override Task OnInitializedAsync()
    {
        IsInitializingPage = false;
        return Task.CompletedTask;
    }

    // ============================================================
    // SERVER DATA (Paginación + Orden + Filtros)
    // ============================================================
    private async Task<TableData<UebDto>> ServerReload(TableState state, CancellationToken token)
    {
        _serverReloadCts?.Cancel();
        _serverReloadCts = CancellationTokenSource.CreateLinkedTokenSource(token);
        var linkedToken = _serverReloadCts.Token;

        IsLoadingTable = true;

        try
        {
            var query = MapTableStateToQuery(state);

            var response = await UebService.GetPagedAsync(query, linkedToken);

            if (response.Result == ResponseStatus.Success && response.Value != null)
            {
                LastPageItems = response.Value.Items.ToList().AsReadOnly();
                _totalFilteredCount = response.Value.TotalCount;

                return new TableData<UebDto>
                {
                    Items = response.Value.Items,
                    TotalItems = response.Value.TotalCount
                };
            }

            await AlertService.ShowError("Error", response.ErrorMessage ?? "Error cargando empresas");
            return new TableData<UebDto>();
        }
        finally
        {
            IsLoadingTable = false;
        }
    }

    private UebQueryDto MapTableStateToQuery(TableState state)
    {
        var sortLabel = string.IsNullOrWhiteSpace(state.SortLabel)
            ? "Code"
            : state.SortLabel;

        var desc = state.SortDirection switch
        {
            SortDirection.Descending => true,
            _ => false // None y Ascending → ASC
        };

        // Si el usuario seleccionó "Todas"
        var pageSize = state.PageSize == int.MaxValue
              ? Math.Max(_totalFilteredCount, 1)
              : state.PageSize;

        return new UebQueryDto
        {
            Page = state.Page + 1,
            Size = state.PageSize,
            Sort = sortLabel,
            Desc = desc,
            Search = string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
            ActiveFilter = StatusFilterValue switch
            {
                "Activo" => true,
                "Inactivo" => false,
                _ => null
            }
        };
    }


    // ============================================================
    // BÚSQUEDA CON DEBOUNCE
    // ============================================================
    private void OnSearchInput(string value)
    {
        SearchText = value;

        _searchDebounceCts?.Cancel();
        _searchDebounceCts = new CancellationTokenSource();

        var token = _searchDebounceCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(300, token);
                if (!token.IsCancellationRequested && TableRef != null)
                    await TableRef.ReloadServerData();
            }
            catch { }
        });
    }

    // ============================================================
    // FILTRO DE ESTADO
    // ============================================================
    private async Task OnStatusFilterChanged(string value)
    {
        StatusFilterValue = value;
        if (TableRef != null) await TableRef.ReloadServerData();
    }

    // ============================================================
    // CRUD: MODALES
    // ============================================================
    private async Task OpenAddModal()
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = UebModal.ModalMode.Add,
            ["Ueb"] = null
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = false,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<UebModal>(
            "Nuevo Establecimiento", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled && TableRef != null)
            await TableRef.ReloadServerData();
    }

    private async Task EditCompany(UebDto dto)
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = UebModal.ModalMode.Edit,
            ["Ueb"] = dto
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = false,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<UebModal>(
            "Editar Establecimiento", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled && TableRef != null)
            await TableRef.ReloadServerData();
    }

    private async Task ViewCompany(UebDto ueb)
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = UebModal.ModalMode.View,
            ["Ueb"] = ueb
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = true,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        await DialogService.ShowAsync<UebModal>(
            "Detalle Establecimiento", parameters, options);
    }
    
    // ============================================================
    // CRUD: ELIMINAR INDIVIDUAL
    // ============================================================
    private async Task DeleteCompany(UebDto dto)
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "¿Está seguro de que desea eliminar este registro?",
            $"¿Eliminar {dto.Code}?",
            type: "Delete",
            confirmText: "Eliminar",
            centerMessage: true
        );

        if (!confirmed)
            return;

        var response = await CompanyService.DeleteAsync(dto.Id);

        if (response.Result == ResponseStatus.Success)
        {
            SelectedItems.RemoveWhere(c => c.Id == dto.Id);

            if (TableRef != null)
                await TableRef.ReloadServerData();

            await AlertService.ShowSuccess("Éxito", "Registro eliminado correctamente.");
            return;
        }

        // Error genérico (incluye FK violation del middleware)
        await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
    }


    // ============================================================
    // SELECCIÓN
    // ============================================================
    private void SelectAllVisible()
    {
        SelectedItems.Clear();
        foreach (var item in LastPageItems)
            SelectedItems.Add(item);
    }

    private void ToggleGlobalSelection()
    {
        IsGlobalSelected = !IsGlobalSelected;
        SelectedItems.Clear();
    }

    /// <summary>
    /// Texto dinámico para mostrar la selección:
    /// - Local: cuántos elementos en SelectedItems.
    /// - Global: cuántos registros en el filtro.
    /// - Ninguno: mensaje claro.
    /// </summary>
    private string BulkSelectionText =>
        IsGlobalSelected
            ? $"Selección global: {_totalFilteredCount}registro{(SelectedItems.Count == 1 ? "" : "s")} seleccionado{(SelectedItems.Count == 1 ? "" : "s")} del resultado actual"
            : $"{SelectedItems.Count} registro{(SelectedItems.Count == 1 ? "" : "s")} seleccionado{(SelectedItems.Count == 1 ? "" : "s")} del resultado actual";

    // ============================================================
    // ACCIONES MASIVAS
    // ============================================================
    private async Task DeleteSelected()
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "¿Desea eliminar los registros seleccionados?",
            IsGlobalSelected
                ? $"¿Eliminar todos los {_totalFilteredCount} registros del filtro?"
                : $"¿Eliminar {SelectedItems.Count} registro(s) seleccionados?",
            type: "Delete",
            confirmText: "Eliminar",
            centerMessage: true
        );

        if (!confirmed)
            return;

        IsProcessingBulkAction = true;

        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected
                    ? new List<int>()
                    : SelectedItems.Select(x => x.Id).ToList()
            };

            var response = await UebService.DeleteBatchAsync(request);

            if (response.Result == ResponseStatus.Success)
            {
                SelectedItems.Clear();
                IsGlobalSelected = false;

                if (TableRef != null)
                    await TableRef.ReloadServerData();

                await AlertService.ShowSuccess("Éxito", "Registros eliminados correctamente.");
                return;
            }

            // Error genérico (incluye FK violation del middleware)
            await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
        }
        finally
        {
            IsProcessingBulkAction = false;
        }
    }


    private async Task ExportPdf()
    {
        var request = new BulkSelectionRequest
        {
            SelectAll = IsGlobalSelected,
            Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
        };

        var response = await CompanyService.ExportPdfAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("openPdfBlob", bytes);
        }
        else
        {
            await AlertService.ShowError("Error", "No se pudo generar el PDF.");
        }
    }

    private async Task ExportExcel()
    {
        var request = new BulkSelectionRequest
        {
            SelectAll = IsGlobalSelected,
            Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
        };

        var response = await CompanyService.ExportExcelAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("downloadFile", "CompaniesReport.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
        }
        else
        {
            await AlertService.ShowError("Error", "No se pudo generar el Excel.");
        }
    }

    // ============================================================
    // LIMPIEZA DE RECURSOS
    // ============================================================
    public void Dispose()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _serverReloadCts?.Cancel();
        _serverReloadCts?.Dispose();
    }

    // ============================================================
    // COMPARER PARA SELECCIÓN ESTABLE
    // ============================================================
    private class UebDtoComparer : IEqualityComparer<UebDto>
    {
        public bool Equals(UebDto? x, UebDto? y) => x?.Id == y?.Id;
        public int GetHashCode(UebDto obj) => obj.Id.GetHashCode();
    }
}

    