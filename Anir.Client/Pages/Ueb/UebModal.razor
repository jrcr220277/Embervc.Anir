@using Anir.Client.Services
@using Anir.Client.Services.Company
@using Anir.Client.Services.Ueb
@using Anir.Shared.Contracts.Uebs
@using Anir.Shared.Enums
@using MudBlazor
@using Anir.Shared.Contracts
@using Anir.Shared.Contracts.Companies
@using System.ComponentModel.DataAnnotations

<MudDialog Elevation="24" Style="width: 780px; max-width: 95vw;">

    <!-- ============================
     TÍTULO DEL MODAL 
     ============================ -->
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">

           
                <MudIcon Icon="@(CurrentMode == ModalMode.Add ? Icons.Material.TwoTone.AddCircle
                                                                                              : CurrentMode == ModalMode.Edit
                                                                                                  ? Icons.Material.TwoTone.Edit
                                                                                                  : Icons.Material.TwoTone.Visibility)"
                         Size="Size.Large" />
          

            <MudStack Spacing="0">
                <MudText Typo="Typo.h6" Class="font-weight-medium">
                    @(CurrentMode == ModalMode.Add ? "Crear Establecimiento" :
                      CurrentMode == ModalMode.Edit ? "Editar Establecimiento" :
                      "Detalle del Establecimiento")
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(CurrentMode == ModalMode.Add ? "Complete los datos para registrar un nuevo establecimiento" :
                      CurrentMode == ModalMode.Edit ? "Modifique los datos del establecimineto seleccionado" :
                      "Visualización de la información del establecimiento")
                </MudText>
            </MudStack>

        </MudStack>
    </TitleContent>

    <!-- ============================
         CONTENIDO DEL MODAL
    ============================ -->
    <DialogContent>

        @if (_isLoading)
        {
            <UiLoading Indeterminate="true" Message="Cargando..." Size="Size.Medium" />
        }
        else
        {
            <EditForm Model="_formModel" OnValidSubmit="HandleSubmitAsync" id="form-entity">
                <DataAnnotationsValidator />

                <MudGrid Spacing="3">
                    <!-- NIVEL SUPERIOR -->
                    <MudItem xs="12">
                        <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Domain" Color="Color.Default" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Nivel Superior</MudText>
                            </MudStack>

                            <MudItem xs="12" sm="12">
                                @if (IsViewMode)
                                {
                                    <MudStack>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @ModelMetadataHelper.GetDisplayName(() => _formModel.CompanyId)
                                        </MudText>
                                        <MudText Typo="Typo.body1">
                                            @{
                                                var company = AllCompanies.FirstOrDefault(o => o.Id == _formModel.CompanyId);
                                            }
                                            @(company != null ? $"{company.ShortName} – {company.Name}" : "-")
                                        </MudText>
                                    </MudStack>
                                }
                                else
                                {
                                    <MudSelect T="int"
                                               Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.CompanyId)"
                                               For="@(() => _formModel.CompanyId)"
                                               @bind-Value="_formModel.CompanyId"
                                               Variant="Variant.Outlined"
                                               Required="true"
                                               FullWidth="true"
                                               Margin="Margin.Dense"
                                               Dense="true">
                                        <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                        @foreach (var item in AllCompanies)
                                        {
                                            <MudSelectItem T="int" Value="@item.Id">
                                                @($"{item.ShortName} – {item.Name}")
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                            </MudItem>
                                                                       
                        </MudPaper>
                    </MudItem>
                    <!-- DATOS BÁSICOS -->
                    <MudItem xs="12">
                        <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Factory" Color="Color.Default" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Datos básicos</MudText>
                            </MudStack>

                            <MudGrid Spacing="2">
                                <MudItem xs="12" sm="3">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @ModelMetadataHelper.GetDisplayName(() => _formModel.Code)
                                            </MudText>
                                            <MudText Typo="Typo.body1">@_formModel.Code</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Code)"
                                                      For="@(() => _formModel.Code)"
                                                      @bind-Value="_formModel.Code"
                                                      InputType="InputType.Text"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true" />
                                    }
                                </MudItem>              

                                <!-- Abreviatura -->
                                <MudItem xs="12" sm="9">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @ModelMetadataHelper.GetDisplayName(() => _formModel.Name)
                                            </MudText>
                                            <MudText Typo="Typo.body1">@_formModel.Name</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Name)"
                                                      For="@(() => _formModel.Name)"
                                                      @bind-Value="_formModel.Name"
                                                      InputType="InputType.Text"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true"
                                                      Class="mb-0"/>
                                    }
                                </MudItem>

                                <!-- Nombre -->
                                <MudItem xs="12" sm="12">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @ModelMetadataHelper.GetDisplayName(() => _formModel.Address)
                                            </MudText>
                                            <MudText Typo="Typo.body1">@_formModel.Address</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Address)"
                                                      For="@(() => _formModel.Address)"
                                                      @bind-Value="_formModel.Address"
                                                      InputType="InputType.Text"
                                                      Variant="Variant.Outlined"     
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true" />
                                    }
                                </MudItem>
                           
                                <!-- Telefono -->
                                <MudItem xs="12" sm="4">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                                                @ModelMetadataHelper.GetDisplayName(() => _formModel.Phone)
                                            </MudText>
                                            <MudText Typo="Typo.body1">@_formModel.Phone</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Phone)"
                                                      For="@(() => _formModel.Phone)"
                                                      @bind-Value="_formModel.Phone"
                                                      InputType="InputType.Telephone"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.Phone"
                                                      Clearable="true" />
                                    }
                                </MudItem>
                            
                                <!-- Email -->
                                <MudItem xs="12" sm="8">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Correo Electronico</MudText>
                                            <MudText Typo="Typo.body1">@_formModel.Email</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Email)"
                                                      For="@(() => _formModel.Email)"
                                                      @bind-Value="_formModel.Email"
                                                      InputType="InputType.Email"
                                                      HelperText="@ModelMetadataHelper.GetHelperText(() => _formModel.Email)"
                                                      HelperTextOnFocus="true"
                                                      Variant="Variant.Outlined"
                                                      Required="true"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                                      Clearable="true" />
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>         
                    <!-- UBICACIÓN -->
                    <MudItem xs="12">
                        <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.LocationOn" Color="Color.Default" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Ubicación</MudText>
                            </MudStack>

                            <MudGrid Spacing="2">
                                <!-- Provincia -->
                                <MudItem xs="12" sm="6">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Provincia</MudText>
                                            <MudText Typo="Typo.body1">
                                                @(AllProvinces.FirstOrDefault(p => p.Id == SelectedProvinceId)?.Name ?? "-")
                                            </MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudSelect T="int"
                                                   Label="Provincia"
                                                   Value="SelectedProvinceId"
                                                   ValueChanged="OnProvinceChanged"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   FullWidth="true"
                                                   Dense="true">
                                            <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                            @foreach (var item in AllProvinces)
                                            {
                                                <MudSelectItem T="int" Value="@item.Id">@item.Name</MudSelectItem>
                                            }
                                        </MudSelect>

                                    }
                                </MudItem>

                                <!-- Municipio -->
                                <MudItem xs="12" sm="6">
                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Municipio</MudText>
                                            <MudText Typo="Typo.body1">
                                                @(FilteredMunicipalities.FirstOrDefault(m => m.Id == _formModel.MunicipalityId)?.Name ?? "-")
                                            </MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudSelect T="int?"
                                                   Label="Municipio"
                                                   @bind-Value="_formModel.MunicipalityId"
                                                   Variant="Variant.Outlined"
                                                   Margin="Margin.Dense"
                                                   FullWidth="true"
                                                   Dense="true">
                                            <MudSelectItem T="int?" Value="@((int?)null)">- Seleccionar -</MudSelectItem>
                                            @foreach (var item in FilteredMunicipalities)
                                            {
                                                <MudSelectItem T="int?" Value="@item.Id">@item.Name</MudSelectItem>
                                            }
                                        </MudSelect>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudPaper>
                    </MudItem>
                    <!-- ESTADO DE LA EMPRESA -->
                    <MudItem xs="12">
                        <MudPaper Class="pa-3" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.Verified" Color="Color.Default" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Estado de la empresa</MudText>
                            </MudStack>

                            @if (IsViewMode)
                            {
                                <MudChip T="string"
                                         Color="@(_formModel.Active ? Color.Success : Color.Error)"
                                         Variant="Variant.Filled">
                                    @(_formModel.Active ? "Activo" : "Inactivo")
                                </MudChip>
                            }
                            else
                            {
                                <MudSwitch T="bool"
                                           @bind-Value="_formModel.Active"
                                           Color="Color.Primary"
                                           ThumbIcon="@(_formModel.Active ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                           ThumbIconColor="@(_formModel.Active ? Color.Success : Color.Default)"
                                           Label="@(_formModel.Active ? "Activo" : "Inactivo")" />
                            }
                        </MudPaper>
                    </MudItem>

                </MudGrid>
            </EditForm>
        }

    </DialogContent>

    <!-- ============================
         BOTONES
         ============================ -->
    <DialogActions>

        @if (!IsViewMode)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       ButtonType="ButtonType.Submit"
                       Form="form-entity"
                       Disabled="@_isSaving">

                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }

                @(CurrentMode == ModalMode.Add
                    ? "Crear"
                    : CurrentMode == ModalMode.Edit
                        ? "Actualizar"
                        : "Guardar")
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Size="Size.Medium"
                       OnClick="Close">
                Cerrar
            </MudButton>
        }

    </DialogActions>

</MudDialog>


@code {

    // ============================================================
    // INYECCIONES
    // ============================================================
   
    [Inject] private ICompanyService CompanyService { get; set; } = default!;
    [Inject] private IUebService UebService { get; set; } = default!;
    [Inject] private ProvinceService ProvinceService { get; set; } = default!;
    [Inject] private MunicipalityService MunicipalityService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    // ============================================================
    // PARÁMETROS
    // ============================================================
    [Parameter] public ModalMode CurrentMode { get; set; }
    [Parameter] public UebDto? Ueb { get; set; }
    [Parameter] public EventCallback OnListUpdated { get; set; }

    public enum ModalMode { Add, Edit, View }

    // ============================================================
    // ESTADO
    // ============================================================
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool IsViewMode => CurrentMode == ModalMode.View;

    // ============================================================
    // FORMULARIO
    // ============================================================
    private UebDto _formModel = new() { MunicipalityId = 0, Active = true };
    
    void Close()
    {
        Dialog.Close();
    }

    // ============================================================
    // UBICACIÓN
    // ============================================================
    private List<CompanyDto> AllCompanies = new();
    private List<ProvinceDto> AllProvinces = new();
    private List<MunicipalityDto> AllMunicipalities = new();
    private List<MunicipalityDto> FilteredMunicipalities = new();

    private int SelectedProvinceId;

    // ============================================================
    // CARGA INICIAL
    // ============================================================
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        AllCompanies = await CompanyService.GetAllAsync() ?? new();
        AllProvinces = await ProvinceService.GetAllAsync() ?? new();
        AllMunicipalities = await MunicipalityService.GetAllAsync() ?? new();

        // Cargar modelo AQUÍ (no en OnParametersSet)
        if (Ueb != null)
        {
            _formModel = new UebDto
            {
                Id = Ueb.Id,
                Code = Ueb.Code,
                Name = Ueb.Name ?? string.Empty,
                Address = Ueb.Address ?? string.Empty,
                Phone = Ueb.Phone ?? string.Empty,
                Email = Ueb.Email ?? string.Empty,
                CompanyId = Ueb.CompanyId,
                CompanyName = Ueb.CompanyName,
                ProvinceName = Ueb.ProvinceName,
                MunicipalityId = Ueb.MunicipalityId,
                MunicipalityName = Ueb.MunicipalityName, 
                Active = Ueb.Active
            };

            SelectedProvinceId = AllMunicipalities
                .FirstOrDefault(item => item.Id == _formModel.MunicipalityId)
                ?.ProvinceId ?? 0;
        }
        else
        {
            _formModel = new UebDto { Active = true, MunicipalityId = 0, CompanyId = 0 }; 
            SelectedProvinceId = 0;
        }


       
        FilterMunicipalities();

        _isLoading = false;
        StateHasChanged();
    }

   
    // ============================================================
    // CAMBIO DE PROVINCIA
    // ============================================================
    private void OnProvinceChanged(int value)
    {
        SelectedProvinceId = value;
        FilterMunicipalities();
    }

    // ============================================================
    // FILTRAR MUNICIPIOS
    // ============================================================
    private void FilterMunicipalities()
    {
        FilteredMunicipalities = AllMunicipalities
            .Where(item => item.ProvinceId == SelectedProvinceId)
            .OrderBy(item => item.Name)
            .ToList();

        if (!FilteredMunicipalities.Any(item => item.Id == _formModel.MunicipalityId))
            _formModel.MunicipalityId = null;
    }

    // ============================================================
    // GUARDAR
    // ============================================================
    private async Task HandleSubmitAsync()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            ProcessResponse<UebDto>? response;

            if (CurrentMode == ModalMode.Add)
            {
                response = await UebService.CreateAsync(_formModel);
            }
            else
            {
                response = await UebService.UpdateAsync(_formModel.Id, _formModel);
            }

            if (response?.Result == ResponseStatus.Success)
            {
                await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
                await OnListUpdated.InvokeAsync();
                Dialog.Close(DialogResult.Ok(true));
                return;
            }

            await AlertService.ShowError("Error", response?.ErrorMessage ?? response?.PrettyMessage ?? "Error al guardar.");
        }
        catch
        {
            await AlertService.ShowError("Error", "Error de conexión.");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }



}
