
@using Anir.Client.Services
@using Anir.Client.Services.Company
@using Anir.Shared.Enums
@using MudBlazor
@using Anir.Shared.Contracts
@using Anir.Shared.Contracts.Companies
@using System.ComponentModel.DataAnnotations

<MudDialog Elevation="24" Style="width: 1020px; max-width: 95vw;">

    <!-- =========================================================
         TÍTULO DEL MODAL
    ========================================================== -->
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">

            <MudAvatar Size="Size.Large" Variant="Variant.Filled">
                <MudIcon Icon="@(CurrentMode == ModalMode.Add ? Icons.Material.TwoTone.AddCircle
                                                     : CurrentMode == ModalMode.Edit
                                                         ? Icons.Material.TwoTone.Edit
                                                         : Icons.Material.TwoTone.Visibility)"
                         Size="Size.Large" />
            </MudAvatar>

            <MudStack Spacing="0">
                <MudText Typo="Typo.h6" Class="font-weight-semibold">
                    @(CurrentMode == ModalMode.Add ? "Crear Persona" :
                      CurrentMode == ModalMode.Edit ? "Editar Persona" :
                      "Detalle de la Persona")
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(CurrentMode == ModalMode.Add ? "Complete los datos para registrar una nueva persona" :
                      CurrentMode == ModalMode.Edit ? "Modifique los datos de la persona seleccionada" :
                      "Visualización de la información de la persona")
                </MudText>
            </MudStack>

        </MudStack>
    </TitleContent>

    <!-- =========================================================
     CONTENIDO ENTERPRISE PULIDO (MudGrid)
    ========================================================== -->
   <DialogContent>

    @if (_isLoading)
    {
        <UiLoading Indeterminate="true" Message="Cargando..." Size="Size.Medium" />
    }
    else
    {
        <EditForm Model="_formModel" OnValidSubmit="HandleSubmitAsync" id="form-entity">
            <DataAnnotationsValidator />

            <!-- GRID PRINCIPAL -->
            <MudGrid Spacing="3">

                <!-- FOTO -->
                <MudItem xs="12" sm="3">
                    <MudPaper Elevation="1" Class="pa-3 rounded-lg" Style="background:var(--mud-palette-background);">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.PermContactCalendar" Color="Color.Info" Size="Size.Small" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Imagen de usuario</MudText>
                        </MudStack>

                            <PhotoUploader Value="@_formModel.ImagenUrl"
                                           IsProfile="true"
                                           Size="150"
                                           OnChanged="OnPhotoChanged"
                                           IsViewMode="IsViewMode" />

                    </MudPaper>
                </MudItem>

                <!-- DATOS PRIMARIOS + DESCRIPCIÓN -->
                <MudItem xs="12" sm="9">
                    <MudGrid Spacing="3">

                        <!-- DATOS BÁSICOS -->
                        <MudItem xs="12">
                            <MudPaper Elevation="1" Class="pa-3 rounded-lg" Outlined="true">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Badge" Color="Color.Info" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Datos básicos</MudText>
                                </MudStack>

                                <MudGrid Spacing="1">

                                        <!-- DNI -->
                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">DNI</MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.Dni</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="DNI"
                                                              @bind-Value="_formModel.Dni"
                                                              Variant="Variant.Outlined"
                                                              Required="true"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                        <!-- Nombre -->
                                        <MudItem xs="12" sm="7">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Nombre</MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.FullName</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="Nombre"
                                                              @bind-Value="_formModel.FullName"
                                                              Variant="Variant.Outlined"
                                                              Required="true"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                        <!-- Teléfono -->
                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Teléfono</MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.CellPhone</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="Teléfono"
                                                              @bind-Value="_formModel.CellPhone"
                                                              Variant="Variant.Outlined"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                    <!-- Email -->
                                    <MudItem xs="12" sm="7">
                                        @if (IsViewMode)
                                        {
                                            <MudStack>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Email</MudText>
                                                <MudText Typo="Typo.body1">@_formModel.Email</MudText>
                                            </MudStack>
                                        }
                                        else
                                        {
                                            <MudTextField Label="Email"
                                                          @bind-Value="_formModel.Email"
                                                          Variant="Variant.Outlined"
                                                          FullWidth="true"
                                                          Margin="Margin.Dense"
                                                          Clearable="true" />
                                        }
                                    </MudItem>
                                                                       

                                </MudGrid>
                            </MudPaper>
                        </MudItem>

                        <!-- INFORMACIÓN ADICIONAL -->
                        <MudItem xs="12">
                            <MudPaper Class="pa-3 rounded-lg" Outlined="true">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Description" Color="Color.Default" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Información adicional</MudText>
                                </MudStack>

                                @if (IsViewMode)
                                {
                                    <MudStack>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Descripción</MudText>
                                        <MudText Typo="Typo.body1">@_formModel.Description</MudText>
                                    </MudStack>
                                }
                                else
                                {
                                    <MudTextField Label="Descripción"
                                                  @bind-Value="_formModel.Description"
                                                  Variant="Variant.Outlined"
                                                  FullWidth="true"
                                                  Margin="Margin.Dense"
                                                  Lines="3"
                                                  Clearable="true" />
                                }
                            </MudPaper>
                        </MudItem>

                        <!-- ESTADO DEL USUARIO -->
                        <MudItem xs="12">
                            <MudPaper Class="pa-3 rounded-lg" Outlined="true">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Verified" Color="Color.Default" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Estado del usuario</MudText>
                                </MudStack>

                                @if (IsViewMode)
                                {
                                        <MudChip T="string"
                                                 Color="@(_formModel.Active ? Color.Success : Color.Error)"
                                                 Variant="Variant.Filled">
                                            @(_formModel.Active ? "Activo" : "Inactivo")
                                        </MudChip>

                                }
                                else
                                {
                                    <MudSwitch T="bool"
                                               @bind-Value="_formModel.Active"
                                               Color="Color.Primary"
                                               Label="@(_formModel.Active ? "Activo" : "Inactivo")" />
                                }
                            </MudPaper>
                        </MudItem>

                    </MudGrid>
                </MudItem>

            </MudGrid>
        </EditForm>
    }

</DialogContent>



    <!-- =========================================================
         BOTONERA ENTERPRISE PULIDA
    ========================================================== -->
    <DialogActions>

        @if (!IsViewMode)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       ButtonType="ButtonType.Submit"
                       Form="form-entity"
                       Disabled="@_isSaving">

                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }

                @(CurrentMode == ModalMode.Add
                    ? "Crear"
                    : CurrentMode == ModalMode.Edit
                        ? "Actualizar"
                        : "Guardar")
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Size="Size.Medium"
                       OnClick="Close">
                Cerrar
            </MudButton>
        }

    </DialogActions>


</MudDialog>


@code {

    // ============================================================
    // INYECCIONES
    // ============================================================
    [Inject] private PersonService PersonService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    // ============================================================
    // PARÁMETROS
    // ============================================================
    [Parameter] public ModalMode CurrentMode { get; set; }
    [Parameter] public PersonDto? Person { get; set; }
    [Parameter] public EventCallback OnListUpdated { get; set; }
   
    public enum ModalMode { Add, Edit, View }

    // ============================================================
    // ESTADO
    // ============================================================
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool IsViewMode => CurrentMode == ModalMode.View;
    

    // ============================================================
    // FORMULARIO
    // ============================================================
    private PersonDto _formModel = new();
       
    void Close()
    {
        Dialog.Close();
    }

    
    // ============================================================
    // CARGA INICIAL
    // ============================================================
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        // Cargar modelo AQUÍ (no en OnParametersSet)
        if (Person != null)
        {
            _formModel = new PersonDto
            {
                Id = Person.Id,
                ImagenId = Person.ImagenId,
                ImagenUrl = Person.ImagenUrl,
                Dni = Person.Dni,
                FullName = Person.FullName,
                CellPhone = Person.CellPhone,
                Email = Person.Email,
                Description = Person.Description,
                Active = Person.Active
            };
                     
        }
        
        _isLoading = false;
        StateHasChanged();
    }

    private void OnPhotoChanged(FileResponse? file)
    {
        _formModel.ImagenId = file?.Id;
        _formModel.ImagenUrl = file?.Url;
    }

    // ============================================================
    // GUARDAR
    // ============================================================
    private async Task HandleSubmitAsync()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            ProcessResponse<PersonDto>? response;

            if (CurrentMode == ModalMode.Add)
            {
                response = await PersonService.CreateAsync(_formModel);
            }
            else
            {
                response = await PersonService.UpdateAsync(_formModel.Id, _formModel);
            }

            if (response?.Result == ResponseStatus.Success)
            {
                await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
                await OnListUpdated.InvokeAsync();
                Dialog.Close(DialogResult.Ok(true));
                return;
            }

            await AlertService.ShowError("Error", response?.ErrorMessage ?? response?.PrettyMessage ?? "Error al guardar.");
        }
        catch
        {
            await AlertService.ShowError("Error", "Error de conexión.");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }



}
