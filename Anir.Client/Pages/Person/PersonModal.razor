@using Anir.Client.Services
@using Anir.Client.Services.Company
@using Anir.Shared.Enums
@using Anir.Shared.Helpers @* <-- ASEGÚRATE DE TENER ESTE USING *@
@using MudBlazor
@using Anir.Shared.Contracts
@using Anir.Shared.Contracts.Companies
@using Anir.Shared.Contracts.Persons
@using Anir.Shared.Contracts.Common
@using Anir.Client.Components.File
@using System.ComponentModel.DataAnnotations

<MudDialog Elevation="24" Style="width: 1020px; max-width: 95vw;">

    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@(CurrentMode == ModalMode.Add ? Icons.Material.TwoTone.AddCircle
                                                                                                                                                        : CurrentMode == ModalMode.Edit
                                                                                                                                                            ? Icons.Material.TwoTone.Edit
                                                                                                                                                            : Icons.Material.TwoTone.Visibility)"
                     Size="Size.Large" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6" Class="font-weight-semibold">
                    @(CurrentMode == ModalMode.Add ? "Crear Anirista" :
                      CurrentMode == ModalMode.Edit ? "Editar Anirista" :
                      "Detalle del Anirista")
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(CurrentMode == ModalMode.Add ? "Complete los datos para registrar una nuevo anirista" :
                      CurrentMode == ModalMode.Edit ? "Modifique los datos del anirista seleccionado" :
                      "Visualización de la información del anirista")
                </MudText>
            </MudStack>
        </MudStack>
    </TitleContent>

    <DialogContent>
        @if (_isLoading)
        {
            <UiLoading Indeterminate="true" Message="Cargando datos..." Size="Size.Medium" />
        }
        else
        {
            <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmitAsync" id="form-entity">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <MudGrid Spacing="3">
                    <!-- FOTO -->
                    <MudItem xs="12" sm="3">
                        <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Outlined.PermContactCalendar" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Imagen de perfil</MudText>
                            </MudStack>

                            <div class="d-flex justify-center">
                                <PhotoUploader Value="@(_formModel.ImageFile?.Url)"
                                               IsProfile="true"
                                               PixelSize="150"
                                               Folder="images/persons"
                                               OnUploaded="HandleImageUploaded"
                                               IsViewMode="IsViewMode" />
                            </div>
                        </MudPaper>
                    </MudItem>

                    <!-- DATOS PRIMARIOS + DESCRIPCIÓN -->
                    <MudItem xs="12" sm="9">
                        <MudGrid Spacing="3">
                            <!-- DATOS BÁSICOS -->
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Hail" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Datos básicos</MudText>
                                    </MudStack>

                                    <MudGrid Spacing="1">
                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.Dni)</MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.Dni</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Dni)"
                                                              For="@(() => _formModel.Dni)"
                                                              @bind-Value="_formModel.Dni"
                                                              Variant="Variant.Outlined"
                                                              Required="true"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                        <MudItem xs="12" sm="7">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.FullName)</MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.FullName</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.FullName)"
                                                              For="@(() => _formModel.FullName)"
                                                              @bind-Value="_formModel.FullName"
                                                              Variant="Variant.Outlined"
                                                              Required="true"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.CellPhone)</MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.CellPhone</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.CellPhone)"
                                                              For="@(() => _formModel.CellPhone)"
                                                              @bind-Value="_formModel.CellPhone"
                                                              InputType="InputType.Telephone"
                                                              Variant="Variant.Outlined"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                        <MudItem xs="12" sm="7">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.Email)</MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.Email</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Email)"
                                                              For="@(() => _formModel.Email)"
                                                              @bind-Value="_formModel.Email"
                                                              InputType="InputType.Email"
                                                              Variant="Variant.Outlined"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>
                                   
                                        <!-- SEXO -->
                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.Sex)</MudText>
                                                    <MudText Typo="Typo.body1">@ModelMetadataHelper.GetEnumDisplayName(_formModel.Sex)</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudSelect T="int"
                                                           Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Sex)"
                                                           @bind-Value="_sexValue"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense="true"
                                                           FullWidth="true">
                                                    <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)Sex.F)">Femenino</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)Sex.M)">Masculino</MudSelectItem>
                                                </MudSelect>
                                            }
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            </MudItem>

                            <!-- ═══════════════════════════════════════════════════════════ -->
                            <!-- INFORMACIÓN ADICIONAL -->
                            <!-- ═══════════════════════════════════════════════════════════ -->
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Badge" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Información adicional</MudText>
                                    </MudStack>

                                    <MudGrid Spacing="1">
                                        <!-- AFILIACIÓN (Corregido con patrón int) -->
                                        <MudItem xs="12" sm="3">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.Affiliation)</MudText>
                                                    <MudText Typo="Typo.body1">@ModelMetadataHelper.GetEnumDisplayName(_formModel.Affiliation)</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudSelect T="int"
                                                           Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Affiliation)"
                                                           @bind-Value="_affiliationValue"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense="true"
                                                           FullWidth="true">
                                                    <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                                    @foreach (var value in Enum.GetValues<Affiliation>())
                                                    {
                                                        <MudSelectItem T="int" Value="@((int)value)">@value.ToString()</MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                        </MudItem>

                                        <!-- NIVEL ESCOLAR -->
                                        <MudItem xs="12" sm="3">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.SchoolLevel)</MudText>
                                                    <MudText Typo="Typo.body1">@ModelMetadataHelper.GetEnumDisplayName(_formModel.SchoolLevel)</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudSelect T="int"
                                                           Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.SchoolLevel)"
                                                           @bind-Value="_schoolLevelValue"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense="true"
                                                           FullWidth="true">
                                                    <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)SchoolLevel.ES)">ES</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)SchoolLevel.EMS)">EMS</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)SchoolLevel.Twelve)">12mo Grado</MudSelectItem>
                                                </MudSelect>
                                            }
                                        </MudItem>

                                        <!-- MILITANCIA -->
                                        <MudItem xs="12" sm="3">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.Militancy)</MudText>
                                                    <MudText Typo="Typo.body1">@ModelMetadataHelper.GetEnumDisplayName(_formModel.Militancy)</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudSelect T="int"
                                                           Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Militancy)"
                                                           @bind-Value="_militancyValue"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense="true"
                                                           FullWidth="true">
                                                    <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)Militancy.PCC)">PCC</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)Militancy.UJC)">UJC</MudSelectItem>
                                                </MudSelect>
                                            }
                                        </MudItem>

                                        <!-- CARGO EJECUTIVO -->
                                        <MudItem xs="12" sm="3">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.ExecutiveRole)</MudText>
                                                    <MudText Typo="Typo.body1">@ModelMetadataHelper.GetEnumDisplayName(_formModel.ExecutiveRole)</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudSelect T="int"
                                                           Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.ExecutiveRole)"
                                                           @bind-Value="_executiveRoleValue"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense="true"
                                                           FullWidth="true">
                                                    <MudSelectItem T="int" Value="0">- Seleccionar -</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)ExecutiveRole.Presidente)">Presidente</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)ExecutiveRole.Vicepresidente)">Vicepresidente</MudSelectItem>
                                                    <MudSelectItem T="int" Value="@((int)ExecutiveRole.Miembro)">Miembro</MudSelectItem>
                                                </MudSelect>
                                            }
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            </MudItem>
                            <!-- ═══════════════════════════════════════════════════════════ -->
                            <!-- DESCRIPCIÓN -->
                            <MudItem xs="12">
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Description" Color="Color.Default" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Descripción</MudText>
                                    </MudStack>

                                    @if (IsViewMode)
                                    {
                                        <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.Description)</MudText>
                                            <MudText Typo="Typo.body1">@_formModel.Description</MudText>
                                        </MudStack>
                                    }
                                    else
                                    {
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Description)"
                                                      For="@(() => _formModel.Description)"
                                                      @bind-Value="_formModel.Description"
                                                      Variant="Variant.Outlined"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Lines="3"
                                                      Clearable="true" />
                                    }
                                </MudPaper>
                            </MudItem>

                            <!-- ESTADO -->
                            <MudItem xs="12">
                                <MudPaper Class="pa-3" Outlined="true">
                                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Verified" Color="Color.Default" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@ModelMetadataHelper.GetDisplayName(() => _formModel.Active)</MudText>
                                    </MudStack>

                                    @if (IsViewMode)
                                    {
                                        <MudChip T="string" Color="@(_formModel.Active ? Color.Success : Color.Error)" Variant="Variant.Filled">
                                            @(_formModel.Active ? "Activo" : "Inactivo")
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudSwitch T="bool"
                                                   @bind-Value="_formModel.Active"
                                                   Color="Color.Primary"
                                                   Label="@(_formModel.Active ? "Activo" : "Inactivo")" />
                                    }
                                </MudPaper>
                            </MudItem>

                        </MudGrid>
                    </MudItem>
                </MudGrid>
            </EditForm>
        }
    </DialogContent>

    <DialogActions>
        @if (!IsViewMode)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       ButtonType="ButtonType.Submit"
                       Form="form-entity"
                       Disabled="@_isSaving">
                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @(CurrentMode == ModalMode.Add ? "Crear" : CurrentMode == ModalMode.Edit ? "Actualizar" : "Guardar")
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Medium" OnClick="Close">
                Cerrar
            </MudButton>
        }
    </DialogActions>

</MudDialog>


@code {
    // INYECCIONES
    [Inject] private IPersonService PersonService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    [Parameter] public ModalMode CurrentMode { get; set; }
    [Parameter] public PersonDto? Person { get; set; }
    [Parameter] public EventCallback OnListUpdated { get; set; }
   
    public enum ModalMode { Add, Edit, View }
    private EditContext? _editContext;

    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool IsViewMode => CurrentMode == ModalMode.View;
    private PersonDto _formModel = new();

    // ═══════════════════════════════════════════════════════════════════════
    // PROPIEDADES AUXILIARES (Patrón int para evitar bug de MudBlazor)
    // ═══════════════════════════════════════════════════════════════════════
    private int _affiliationValue = 0;
    private int _sexValue = 0;
    private int _schoolLevelValue = 0;
    private int _militancyValue = 0;
    private int _executiveRoleValue = 0;
    // ═══════════════════════════════════════════════════════════════════════
       
    void Close() => Dialog.Close();

    protected override async Task OnInitializedAsync()
    {
        _editContext = new EditContext(_formModel);
        _isLoading = true;

        if (Person != null)
        {
            _formModel = new PersonDto
            {
                Id = Person.Id,
                ImageFile = Person.ImageFile,
                Dni = Person.Dni,
                FullName = Person.FullName,
                CellPhone = Person.CellPhone,
                Email = Person.Email,
                Affiliation = Person.Affiliation,
                SchoolLevel = Person.SchoolLevel,
                Sex = Person.Sex,
                ExecutiveRole = Person.ExecutiveRole,
                Militancy = Person.Militancy,
                Description = Person.Description,
                Active = Person.Active
            };

            // ═══════════════════════════════════════════════════════════
            // SINCRONIZAR: Modelo (Enum?) → UI (int)
            // ═══════════════════════════════════════════════════════════
            _affiliationValue = (int?)Person.Affiliation ?? 0;
            _sexValue = (int?)Person.Sex ?? 0;
            _schoolLevelValue = (int?)Person.SchoolLevel ?? 0;
            _militancyValue = (int?)Person.Militancy ?? 0;
            _executiveRoleValue = (int?)Person.ExecutiveRole ?? 0;
            // ═══════════════════════════════════════════════════════════
        }
        
        _isLoading = false;
        StateHasChanged();
    }

    private Task HandleImageUploaded(FileResponse? file)
    {
        _formModel.ImageFile = file;
        return Task.CompletedTask;
    }

    private async Task HandleSubmitAsync()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            // ═══════════════════════════════════════════════════════════
            // SINCRONIZAR: UI (int) → Modelo (Enum?)
            // ═══════════════════════════════════════════════════════════
            _formModel.Affiliation = _affiliationValue == 0 ? null : (Affiliation)_affiliationValue;
            _formModel.Sex = _sexValue == 0 ? null : (Sex)_sexValue;
            _formModel.SchoolLevel = _schoolLevelValue == 0 ? null : (SchoolLevel)_schoolLevelValue;
            _formModel.Militancy = _militancyValue == 0 ? null : (Militancy)_militancyValue;
            _formModel.ExecutiveRole = _executiveRoleValue == 0 ? null : (ExecutiveRole)_executiveRoleValue;
            // ═══════════════════════════════════════════════════════════

            ProcessResponse<PersonDto>? response;

            if (CurrentMode == ModalMode.Add)
                response = await PersonService.CreateAsync(_formModel);
            else
                response = await PersonService.UpdateAsync(_formModel.Id, _formModel);

            if (response?.Result == ResponseStatus.Success)
            {
                await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
                await OnListUpdated.InvokeAsync();
                Dialog.Close(DialogResult.Ok(true));
                return;
            }

            await AlertService.ShowError("Error", response?.ErrorMessage ?? response?.PrettyMessage ?? "Error al guardar.");
        }
        catch
        {
            await AlertService.ShowError("Error", "Error de conexión.");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }
}