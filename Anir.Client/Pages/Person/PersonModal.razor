
@using Anir.Client.Services
@using Anir.Client.Services.Company
@using Anir.Shared.Enums
@using MudBlazor
@using Anir.Shared.Contracts
@using Anir.Shared.Contracts.Companies
@using System.ComponentModel.DataAnnotations

<MudDialog Elevation="24" Style="width: 1020px; max-width: 95vw;">

    <!-- =========================================================
         TÍTULO DEL MODAL
    ========================================================== -->
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">

           
           <MudIcon Icon="@(CurrentMode == ModalMode.Add ? Icons.Material.TwoTone.AddCircle
                                                     : CurrentMode == ModalMode.Edit
                                                         ? Icons.Material.TwoTone.Edit
                                                         : Icons.Material.TwoTone.Visibility)"
                   Size="Size.Large" />
           

            <MudStack Spacing="0">
                <MudText Typo="Typo.h6" Class="font-weight-semibold">
                    @(CurrentMode == ModalMode.Add ? "Crear Anirista" :
                      CurrentMode == ModalMode.Edit ? "Editar Anirista" :
                      "Detalle del Anirista")
                </MudText>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @(CurrentMode == ModalMode.Add ? "Complete los datos para registrar una nuevo anirista" :
                      CurrentMode == ModalMode.Edit ? "Modifique los datos del anirista seleccionado" :
                      "Visualización de la información del anirista")
                </MudText>
            </MudStack>

        </MudStack>
    </TitleContent>

    <!-- =========================================================
     CONTENIDO ENTERPRISE PULIDO (MudGrid)
    ========================================================== -->
   <DialogContent>

    @if (_isLoading)
    {
        <UiLoading Indeterminate="true" Message="Cargando datos..." Size="Size.Medium" />
    }
    else
    {
        <EditForm Model="_formModel" OnValidSubmit="HandleSubmitAsync" id="form-entity">
            <DataAnnotationsValidator />

            <!-- GRID PRINCIPAL -->
            <MudGrid Spacing="3">

                    <!-- FOTO  Style="background:var(--mud-palette-background);" -->
                <MudItem xs="12" sm="3">
                        <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                        <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Outlined.PermContactCalendar" Size="Size.Small" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Imagen de perfil</MudText>
                        </MudStack>

                            <PhotoUploader Value="@_formModel.ImagenUrl"
                                           IsProfile="true"
                                           Size="150"
                                           OnChanged="OnPhotoChanged"
                                           IsViewMode="IsViewMode" />

                    </MudPaper>
                </MudItem>

                <!-- DATOS PRIMARIOS + DESCRIPCIÓN -->
                <MudItem xs="12" sm="9">
                    <MudGrid Spacing="3">

                        <!-- DATOS BÁSICOS -->
                        <MudItem xs="12">
                            <MudPaper Elevation="1" Class="pa-3" Outlined="true">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                        <MudIcon Icon="@Icons.Material.Outlined.Hail" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Datos básicos</MudText>
                                </MudStack>

                                <MudGrid Spacing="1">

                                        <!-- DNI -->
                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @ModelMetadataHelper.GetDisplayName(() => _formModel.Dni)
                                                    </MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.Dni</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Dni)"
                                                              For="@(() => _formModel.Dni)"
                                                              @bind-Value="_formModel.Dni"
                                                              InputType="InputType.Text"
                                                              Variant="Variant.Outlined"
                                                              Required="true"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                                
                                            }
                                        </MudItem>

                                        <!-- Nombre -->
                                        <MudItem xs="12" sm="7">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @ModelMetadataHelper.GetDisplayName(() => _formModel.FullName)"
                                                    </MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.FullName</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.FullName)"
                                                              For="@(() => _formModel.FullName)"
                                                              @bind-Value="_formModel.FullName"
                                                              InputType="InputType.Text"
                                                              Variant="Variant.Outlined"
                                                              Required="true"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                        <!-- Teléfono -->
                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @ModelMetadataHelper.GetDisplayName(() => _formModel.CellPhone)"
                                                    </MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.CellPhone</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.CellPhone)"
                                                              For="@(() => _formModel.CellPhone)"
                                                              @bind-Value="_formModel.CellPhone"
                                                              InputType="InputType.Telephone"
                                                              Variant="Variant.Outlined"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                            }
                                        </MudItem>

                                    <!-- Email -->
                                    <MudItem xs="12" sm="7">
                                        @if (IsViewMode)
                                        {
                                            <MudStack>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @ModelMetadataHelper.GetDisplayName(() => _formModel.Email)"
                                                </MudText>
                                                <MudText Typo="Typo.body1">@_formModel.Email</MudText>
                                            </MudStack>
                                        }
                                        else
                                        {
                                                <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Email)"
                                                              For="@(() => _formModel.Email)"
                                                              @bind-Value="_formModel.Email"
                                                              InputType="InputType.Email"
                                                              Variant="Variant.Outlined"
                                                              FullWidth="true"
                                                              Margin="Margin.Dense"
                                                              Clearable="true" />
                                        }
                                    </MudItem>
                                                                       
                                        <!-- DNI -->
                                        <MudItem xs="12" sm="5">
                                            @if (IsViewMode)
                                            {
                                                <MudStack>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @ModelMetadataHelper.GetDisplayName(() => _formModel.Affiliation)
                                                    </MudText>
                                                    <MudText Typo="Typo.body1">@_formModel.Affiliation</MudText>
                                                </MudStack>
                                            }
                                            else
                                            {
                                                <MudSelect T="PersonAffiliation"
                                                           Label="Afiliación"
                                                           @bind-Value="_formModel.Affiliation"
                                                           Variant="Variant.Outlined"
                                                           Margin="Margin.Dense"
                                                           Dense="true"
                                                           FullWidth="true">
                                                    @foreach (var value in Enum.GetValues<PersonAffiliation>())
                                                    {
                                                        <MudSelectItem Value="@value">@value.ToString()</MudSelectItem>
                                                    }
                                                </MudSelect>

                                                
                                            }
                                        </MudItem>
                                </MudGrid>
                            </MudPaper>
                        </MudItem>

                        <!-- INFORMACIÓN ADICIONAL -->
                        <MudItem xs="12">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Start" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Description" Color="Color.Default" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Información adicional</MudText>
                                </MudStack>

                                @if (IsViewMode)
                                {
                                    <MudStack>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @ModelMetadataHelper.GetDisplayName(() => _formModel.Description)"
                                            </MudText>
                                        <MudText Typo="Typo.body1">@_formModel.Description</MudText>
                                    </MudStack>
                                }
                                else
                                {
                                        <MudTextField Label="@ModelMetadataHelper.GetDisplayName(() => _formModel.Description)"
                                                      For="@(() => _formModel.Description)"
                                                      @bind-Value="_formModel.Description"
                                                      InputType="InputType.Text"
                                                      Variant="Variant.Outlined"
                                                      FullWidth="true"
                                                      Margin="Margin.Dense"
                                                      Clearable="true" />
                                }
                            </MudPaper>
                        </MudItem>

                        <!-- ESTADO DEL USUARIO -->
                        <MudItem xs="12">
                            <MudPaper Class="pa-3" Outlined="true">
                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudIcon Icon="@Icons.Material.Outlined.Verified" Color="Color.Default" Size="Size.Small" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @ModelMetadataHelper.GetDisplayName(() => _formModel.Active)"
                                        </MudText>
                                </MudStack>

                                @if (IsViewMode)
                                {
                                        <MudChip T="string"
                                                 Color="@(_formModel.Active ? Color.Success : Color.Error)"
                                                 Variant="Variant.Filled">
                                            @(_formModel.Active ? "Activo" : "Inactivo")
                                        </MudChip>

                                }
                                else
                                {
                                    <MudSwitch T="bool"
                                               @bind-Value="_formModel.Active"
                                               Color="Color.Primary"
                                               Label="@(_formModel.Active ? "Activo" : "Inactivo")" />
                                }
                            </MudPaper>
                        </MudItem>

                    </MudGrid>
                </MudItem>

            </MudGrid>
        </EditForm>
    }

</DialogContent>



    <!-- =========================================================
         BOTONERA ENTERPRISE PULIDA
    ========================================================== -->
    <DialogActions>

        @if (!IsViewMode)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Medium"
                       ButtonType="ButtonType.Submit"
                       Form="form-entity"
                       Disabled="@_isSaving">

                @if (_isSaving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                }

                @(CurrentMode == ModalMode.Add
                    ? "Crear"
                    : CurrentMode == ModalMode.Edit
                        ? "Actualizar"
                        : "Guardar")
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Secondary"
                       Size="Size.Medium"
                       OnClick="Close">
                Cerrar
            </MudButton>
        }

    </DialogActions>


</MudDialog>


@code {

    // ============================================================
    // INYECCIONES
    // ============================================================
    [Inject] private PersonService PersonService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    // ============================================================
    // PARÁMETROS
    // ============================================================
    [Parameter] public ModalMode CurrentMode { get; set; }
    [Parameter] public PersonDto? Person { get; set; }
    [Parameter] public EventCallback OnListUpdated { get; set; }
   
    public enum ModalMode { Add, Edit, View }

    // ============================================================
    // ESTADO
    // ============================================================
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool IsViewMode => CurrentMode == ModalMode.View;
    

    // ============================================================
    // FORMULARIO
    // ============================================================
    private PersonDto _formModel = new();
       
    void Close()
    {
        Dialog.Close();
    }

    
    // ============================================================
    // CARGA INICIAL
    // ============================================================
    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;

        // Cargar modelo AQUÍ (no en OnParametersSet)
        if (Person != null)
        {
            _formModel = new PersonDto
            {
                Id = Person.Id,
                ImagenId = Person.ImagenId,
                ImagenUrl = Person.ImagenUrl,
                Dni = Person.Dni,
                FullName = Person.FullName,
                CellPhone = Person.CellPhone,
                Email = Person.Email,
                Affiliation = Person.Affiliation,
                Description = Person.Description,
                Active = Person.Active
            };
                     
        }
        
        _isLoading = false;
        StateHasChanged();
    }

    private void OnPhotoChanged(FileResponse? file)
    {
        _formModel.ImagenId = file?.Id;
        _formModel.ImagenUrl = file?.Url;
    }

    // ============================================================
    // GUARDAR
    // ============================================================
    private async Task HandleSubmitAsync()
    {
        _isSaving = true;
        StateHasChanged();

        try
        {
            ProcessResponse<PersonDto>? response;

            if (CurrentMode == ModalMode.Add)
            {
                response = await PersonService.CreateAsync(_formModel);
            }
            else
            {
                response = await PersonService.UpdateAsync(_formModel.Id, _formModel);
            }

            if (response?.Result == ResponseStatus.Success)
            {
                await AlertService.ShowSuccess("Éxito", "Guardado correctamente.");
                await OnListUpdated.InvokeAsync();
                Dialog.Close(DialogResult.Ok(true));
                return;
            }

            await AlertService.ShowError("Error", response?.ErrorMessage ?? response?.PrettyMessage ?? "Error al guardar.");
        }
        catch
        {
            await AlertService.ShowError("Error", "Error de conexión.");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }



}
