@page "/persons"
@using Anir.Client.Components.Tables
@using Anir.Shared.Contracts.Persons
@using Anir.Shared.Contracts.Common
@using Anir.Client.Services.Person
@using Anir.Shared.Enums
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="pa-3">

    @if (IsInitializingPage)
    {
        <UiLoading Indeterminate="true" Message="Cargando datos..." ContainerHeight="100vh" Size="Size.Large" />
        return;
    }

    <!-- ENCABEZADO (igual que Companies) -->
    <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        
            <!-- Icono + título/subtítulo -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Rounded="true" Color="Color.Primary">
                    <MudIcon Icon="@Icons.Material.TwoTone.Hail" Size="Size.Medium" />
                </MudAvatar>
            
                <MudStack AlignItems="AlignItems.Start" Spacing="0">
                    <MudText Typo="Typo.h6" Class="font-weight-medium">Clasificador de Aniristas</MudText>
                    <MudText Typo="Typo.caption">Gestión de aniristas: búsqueda, filtros y acciones masivas</MudText>
                </MudStack>
            </MudStack>
        
            <!-- Botón Agregar a la derecha -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudButton StartIcon="@Icons.Material.TwoTone.Add" Color="Color.Primary" Variant="Variant.Filled" OnClick="OpenAddModal">
                    Agregar
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- ACCIONES MASIVAS (MudCollapse con tooltips Placement.Top) -->
    <MudCollapse Expanded="@(SelectedItems.Any() || IsGlobalSelected)">
        <MudPaper Outlined="true" Elevation="0" Class="px-4 py-3 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTooltip Text="@(IsGlobalSelected ? "Cancelar selección global" : "Seleccionar global")" Arrow="true" Placement="Placement.Top">
                        <MudIconButton Icon="@(IsGlobalSelected ? Icons.Material.Filled.Deselect : Icons.Material.Filled.SelectAll)"
                                       Size="Size.Medium" Edge="Edge.Start"
                                       OnClick="@(() => ToggleGlobalSelection())" />
                    </MudTooltip>
                    <MudText Typo="Typo.body2" Class="font-weight-medium">@BulkSelectionText</MudText>
                </MudStack>

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    <MudTooltip Text="Ver reporte pdf" Arrow="true" Placement="Placement.Top">
                        <MudIconButton OnClick="ViewPdf" Icon="@Icons.Custom.FileFormats.FilePdf" />
                    </MudTooltip>
                    <MudTooltip Text="Descargar reportes" Arrow="true" Placement="Placement.Top">
                        <MudMenu Icon="@Icons.Material.Outlined.SaveAlt" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            <MudMenuItem label="Descargar PDF" Icon="@Icons.Custom.FileFormats.FilePdf" OnClick="DownloadPdf" />
                            <MudDivider />
                            <MudMenuItem label="Descargar Excel" Icon="@Icons.Custom.FileFormats.FileExcel" OnClick="ExportExcel" />
                        </MudMenu>
                    </MudTooltip>
                    <MudTooltip Text="Eliminar registros seleccionados" Arrow="true" Placement="Placement.Top">
                        <MudIconButton OnClick="@(() => DeleteSelected())" Icon="@Icons.Material.Outlined.DeleteForever" Color="Color.Error" Edge="Edge.End" />
                    </MudTooltip>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudCollapse>

    <!-- TABLA PRINCIPAL -->
    <MudTable T="PersonDto" ServerData="ServerReload" @ref="TableRef" Hover="true" Dense="true" MultiSelection="true" @bind-SelectedItems="SelectedItems" SelectOnRowClick="true" Loading="@IsLoadingTable" HorizontalScrollbar="true" Elevation="0" Outlined="true">
        
        <ToolBarContent>
            <!-- Contador de registros con tooltip Top -->
            @if (_totalFilteredCount > 0)
            {
                <MudTooltip Text="Numero de registros en tabla" Arrow="true" Placement="Placement.Top">
                    <MudBadge Content="@_totalFilteredCount.ToString()" Color="Color.Primary" Overlap="true">
                        <MudIcon Icon="@Icons.Material.Rounded.TableRows" Size="Size.Medium" />
                    </MudBadge>
                </MudTooltip>
            }

            <MudSpacer />
            <MudTextField T="string"
                          Variant="Variant.Text"
                          Margin="Margin.Dense"
                          Class="flex-grow-1"
                          Value="@SearchText"
                          ValueChanged="OnSearchInput"
                          Immediate="true"
                          Clearable="true"
                          Placeholder="Buscar por valores de la tabla..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search" />
        </ToolBarContent>

        <HeaderContent>
            <MudTh>Foto</MudTh>
            <MudTh><MudTableSortLabel T="PersonDto" SortLabel="Dni">CI</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="PersonDto" SortLabel="Name">Nombre</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="PersonDto" SortLabel="Sex">Sexo</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="PersonDto" SortLabel="SchoolLevel">Nivel Escolar</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="PersonDto" SortLabel="Militancy">Militancia</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="PersonDto" SortLabel="ExecutiveRole">Cargo Ejec.</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="PersonDto" SortLabel="Affiliation">Afiliación</MudTableSortLabel></MudTh>
            <MudTh>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTableSortLabel T="PersonDto" SortLabel="Active">Estado</MudTableSortLabel>
                    <ColumnFilter Options="_statusOptions"
                                  Value="@StatusFilterValue"
                                  ValueChanged="OnStatusFilterChanged"
                                  ActiveColor="Color.Primary" />
                </MudStack>
            </MudTh>
            <MudTh Style="width: 120px; text-align:end">Acciones</MudTh>
        </HeaderContent>
        
        <RowTemplate Context="person">
            <MudTd>
                @if (person.ImageFile != null && !string.IsNullOrWhiteSpace(person.ImageFile.Url))
                {
                    <MudAvatar Size="Size.Medium" Color="Color.Surface">
                        <MudImage Src="@person.ImageFile.Url" Style="width:100%; height:100%; object-fit:cover;" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Color="Color.Surface" Size="Size.Medium">
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                    </MudAvatar>
                }
            </MudTd>
            <MudTd>@person.Dni</MudTd>
            <MudTd>@person.FullName</MudTd>
            <MudTd>
                @if (person.Sex.HasValue)
                {
                    <MudChip T="string"
                             Color="@(person.Sex == Sex.F ? Color.Default : Color.Info)"
                             Variant="Variant.Text"
                             Size="Size.Small">
                        @(person.Sex == Sex.F ? "Femenino" : "Masculino")
                    </MudChip>
                }
            </MudTd>
            <MudTd>
                @if (person.SchoolLevel.HasValue)
                {
                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Size="Size.Small">
                        @GetSchoolLevelDisplay(person.SchoolLevel.Value)
                    </MudChip>
                }
            </MudTd>
            <MudTd>
                @if (person.Militancy.HasValue)
                {
                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Text" Size="Size.Small">
                        @person.Militancy.Value.ToString()
                    </MudChip>
                }
            </MudTd>
            <MudTd>
                @if (person.ExecutiveRole.HasValue)
                {
                    <MudChip T="string" Color="Color.Tertiary" Variant="Variant.Text" Size="Size.Small">
                        @GetExecutiveRoleDisplay(person.ExecutiveRole.Value)
                    </MudChip>
                }
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="Color.Info" Variant="Variant.Text" Size="Size.Small">
                    @person.Affiliation.ToString()
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="@(person.Active ? Color.Success : Color.Error)" Variant="Variant.Text" Size="Size.Small">
                    @(person.Active ? "Activo" : "Inactivo")
                </MudChip>
            </MudTd>
            <MudTd Style="width: 120px; text-align:end">
                <MudTooltip Text="Visualizar registro seleccionado" Arrow="true" Placement="Placement.Left">
                    <MudIconButton Icon="@Icons.Material.Rounded.Visibility" OnClick="@(() => ViewPerson(person))" Size="Size.Small" />
                </MudTooltip>
                <MudTooltip Text="Editar registro seleccionado" Arrow="true" Placement="Placement.Left">
                    <MudIconButton Icon="@Icons.Material.Rounded.Edit" OnClick="@(() => EditPerson(person))" Size="Size.Small" />
                </MudTooltip>
                <MudTooltip Text="Eliminar registro seleccionado" Arrow="true" Placement="Placement.Left">
                    <MudIconButton Icon="@Icons.Material.Rounded.Delete" Color="Color.Error" Variant="Variant.Text" OnClick="@(() => DeletePerson(person))" Size="Size.Small" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4 text-center">No se encontraron datos para mostrar.</MudText>
        </NoRecordsContent>
        
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 5, 10, 15, 20, 50, 100, int.MaxValue }" RowsPerPageString="Registros por página:" InfoFormat="{first_item}-{last_item} de {all_items}" AllItemsText="Todos" HorizontalAlignment="HorizontalAlignment.Right" />
        </PagerContent>
    </MudTable>

</MudContainer>

@code {
    // ============================================================
    // DEPENDENCIAS
    // ============================================================
    [Inject] private IPersonService PersonService { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private IConfiguration Config { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
    [Inject] private IAlertService AlertService { get; set; } = default!;
    [Inject] private ILogger<PersonIndex> Logger { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    // ============================================================
    // ESTADO GENERAL
    // ============================================================
    private bool IsInitializingPage = true;
    private bool IsLoadingTable = false;
    private bool IsProcessingBulkAction = false;

    private MudTable<PersonDto>? TableRef;
    private HashSet<PersonDto> SelectedItems = new(new PersonDtoComparer());
    private readonly IReadOnlyList<string> _statusOptions = new List<string> { "Todos", "Activo", "Inactivo" };
    
    private bool IsGlobalSelected = false;
    private int _totalFilteredCount = 0;

    private string SearchText = string.Empty;
    private string StatusFilterValue = "Todos";

    private IReadOnlyList<PersonDto> LastPageItems = Array.Empty<PersonDto>();

    private CancellationTokenSource? _searchDebounceCts;
    private CancellationTokenSource? _serverReloadCts;

    protected override Task OnInitializedAsync()
    {
        IsInitializingPage = false;
        return Task.CompletedTask;
    }

    // ============================================================
    // HELPER METHODS PARA DISPLAY DE ENUMS
    // ============================================================
    private static string GetSchoolLevelDisplay(SchoolLevel level) => level switch
    {
        SchoolLevel.ES => "ES",
        SchoolLevel.EMS => "EMS",
        SchoolLevel.Twelve => "12mo",
        _ => level.ToString()
    };

    private static string GetExecutiveRoleDisplay(ExecutiveRole role) => role switch
    {
        ExecutiveRole.Presidente => "Presidente",
        ExecutiveRole.Vicepresidente => "Vicepresidente",
        ExecutiveRole.Miembro => "Miembro",
        _ => role.ToString()
    };

    // ============================================================
    // SERVER DATA (Paginación + Orden + Filtros)
    // ============================================================
    private async Task<TableData<PersonDto>> ServerReload(TableState state, CancellationToken token)
    {
        _serverReloadCts?.Cancel();
        _serverReloadCts = CancellationTokenSource.CreateLinkedTokenSource(token);
        var linkedToken = _serverReloadCts.Token;

        IsLoadingTable = true;

        try
        {
            var query = MapTableStateToQuery(state);

            var response = await PersonService.GetPagedAsync(query, linkedToken);

            if (response.Result == ResponseStatus.Success && response.Value != null)
            {
                LastPageItems = response.Value.Items.ToList().AsReadOnly();
                _totalFilteredCount = response.Value.TotalCount;

                return new TableData<PersonDto>
                {
                    Items = response.Value.Items,
                    TotalItems = response.Value.TotalCount
                };
            }

            await AlertService.ShowError("Error", response.ErrorMessage ?? "Error cargando registros");
            return new TableData<PersonDto>();
        }
        finally
        {
            IsLoadingTable = false;
        }
    }

    private PersonQueryDto MapTableStateToQuery(TableState state)
    {
        var sortLabel = string.IsNullOrWhiteSpace(state.SortLabel)
            ? "Dni"
            : state.SortLabel;

        var desc = state.SortDirection switch
        {
            SortDirection.Descending => true,
            _ => false
        };

        return new PersonQueryDto
        {
            Page = state.Page + 1,
            Size = state.PageSize,
            Sort = sortLabel,
            Desc = desc,
            Search = string.IsNullOrWhiteSpace(SearchText) ? null : SearchText,
            ActiveFilter = StatusFilterValue switch
            {
                "Activo" => true,
                "Inactivo" => false,
                _ => null
            }
        };
    }

    // ============================================================
    // BÚSQUEDA CON DEBOUNCE
    // ============================================================
    private void OnSearchInput(string value)
    {
        SearchText = value;

        _searchDebounceCts?.Cancel();
        _searchDebounceCts = new CancellationTokenSource();

        var token = _searchDebounceCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(300, token);
                if (!token.IsCancellationRequested && TableRef != null)
                    await TableRef.ReloadServerData();
            }
            catch { }
        });
    }

    // ============================================================
    // FILTRO DE ESTADO
    // ============================================================
    private async Task OnStatusFilterChanged(string value)
    {
        StatusFilterValue = value;
        if (TableRef != null) await TableRef.ReloadServerData();
    }

    // ============================================================
    // CRUD: MODALES
    // ============================================================
    private async Task OpenAddModal()
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = PersonModal.ModalMode.Add,
            ["Person"] = null
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = false,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<PersonModal>(
            "Nuevo Anirista", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled && TableRef != null)
            await TableRef.ReloadServerData();
    }

    private async Task EditPerson(PersonDto person)
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = PersonModal.ModalMode.Edit,
            ["Person"] = person
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = false,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<PersonModal>(
            "Editar Anirista", parameters, options);

        var result = await dialog.Result;

        if (!result.Canceled && TableRef != null)
            await TableRef.ReloadServerData();
    }

    private async Task ViewPerson(PersonDto person)
    {
        var parameters = new DialogParameters
        {
            ["CurrentMode"] = PersonModal.ModalMode.View,
            ["Person"] = person
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            BackdropClick = true,
            BackgroundClass = "pa-4",
            Position = DialogPosition.Center
        };

        await DialogService.ShowAsync<PersonModal>(
            "Detalle del Anirista", parameters, options);
    }

    // ============================================================
    // CRUD: ELIMINAR INDIVIDUAL
    // ============================================================
    private async Task DeletePerson(PersonDto person)
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "¿Está seguro de que desea eliminar este registro?",
            $"¿Eliminar {person.Dni}?",
            type: "Delete",
            confirmText: "Eliminar",
            centerMessage: true
        );

        if (!confirmed)
            return;

        var response = await PersonService.DeleteAsync(person.Id);

        if (response.Result == ResponseStatus.Success)
        {
            SelectedItems.RemoveWhere(c => c.Id == person.Id);

            if (TableRef != null)
                await TableRef.ReloadServerData();

            await AlertService.ShowSuccess("Éxito", "Registro eliminado correctamente.");
            return;
        }

        // Manejo de restricciones de FK (igual que en Companies)
        if (response.ValidationErrors != null &&
            response.ValidationErrors.TryGetValue("Restricciones", out var ids))
        {
            await AlertService.ShowWarning(
                "Borrado no completado",
                "Este registro tiene dependencias asociadas. La acción de borrado no se realizó."
            );
            return;
        }

        await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
    }

    // ============================================================
    // SELECCIÓN
    // ============================================================
    private void ToggleGlobalSelection()
    {
        IsGlobalSelected = !IsGlobalSelected;
        SelectedItems.Clear();

        if (IsGlobalSelected)
        {
            foreach (var item in LastPageItems)
                SelectedItems.Add(item);
        }
    }

    private string BulkSelectionText =>
        IsGlobalSelected
            ? $"Selección global: {_totalFilteredCount} registro{(SelectedItems.Count == 1 ? "" : "s")} seleccionado{(SelectedItems.Count == 1 ? "" : "s")} del resultado actual"
            : $"{SelectedItems.Count} registro{(SelectedItems.Count == 1 ? "" : "s")} seleccionado{(SelectedItems.Count == 1 ? "" : "s")} del resultado actual";

    // ============================================================
    // ACCIONES MASIVAS (PDF, EXCEL, ELIMINAR)
    // ============================================================
    private async Task DeleteSelected()
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "¿Desea eliminar los registros seleccionados?",
            IsGlobalSelected
                ? $"¿Eliminar todos los {_totalFilteredCount} registros del filtro?"
                : $"¿Eliminar {SelectedItems.Count} registro(s) seleccionados?",
            type: "Delete",
            confirmText: "Eliminar",
            centerMessage: true
        );

        if (!confirmed)
            return;

        IsProcessingBulkAction = true;

        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };

            var response = await PersonService.DeleteBatchAsync(request);

            if (response.Result == ResponseStatus.Success)
            {
                SelectedItems.Clear();
                IsGlobalSelected = false;

                if (TableRef != null)
                    await TableRef.ReloadServerData();

                await AlertService.ShowSuccess("Éxito", "Registros eliminados correctamente.");
                return;
            }

            if (response.ValidationErrors != null && response.ValidationErrors.TryGetValue("Restricciones", out var ids))
            {
                await AlertService.ShowWarning(
                    "Borrado no completado",
                    $"{ids.Length} registro(s) tienen dependencias asociadas. El borrado masivo no se realizó y todos los cambios fueron revertidos."
                );
                return;
            }

            await AlertService.ShowError("Error", response.ErrorMessage ?? "No se pudo eliminar.");
        }
        finally
        {
            IsProcessingBulkAction = false;
        }
    }

    private async Task ViewPdf()
    {
        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };

            var response = await PersonService.ExportPdfAsync(request);
            response.EnsureSuccessStatusCode();

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"') ?? "Listado_Aniristas.pdf";

            await JS.InvokeVoidAsync("openPdfBlob", bytes, fileName);
        }
        catch (Exception)
        {
            await AlertService.ShowError("Error", "Ocurrió un error al generar el PDF.");
        }
    }

    private async Task DownloadPdf()
    {
        try
        {
            var request = new BulkSelectionRequest
            {
                SelectAll = IsGlobalSelected,
                Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
            };

            var response = await PersonService.ExportPdfAsync(request);
            response.EnsureSuccessStatusCode();

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var fileName = response.Content.Headers.ContentDisposition?.FileName?.Trim('"') ?? "Listado_Aniristas.pdf";

            await JS.InvokeVoidAsync("downloadBlob", bytes, fileName, "application/pdf");
            await AlertService.ShowSuccess("Éxito", $"PDF '{fileName}' descargado correctamente.");
        }
        catch (Exception)
        {
            await AlertService.ShowError("Error", "Ocurrió un error al generar el PDF.");
        }
    }

    private async Task ExportExcel()
    {
        var request = new BulkSelectionRequest
        {
            SelectAll = IsGlobalSelected,
            Ids = IsGlobalSelected ? new List<int>() : SelectedItems.Select(x => x.Id).ToList()
        };

        var response = await PersonService.ExportExcelAsync(request);
        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            await JS.InvokeVoidAsync("downloadFile", "AniristasReport.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                Convert.ToBase64String(bytes));
            await AlertService.ShowSuccess("Éxito", "Reporte Excel descargado correctamente.");
        }
        else
        {
            await AlertService.ShowError("Error", "No se pudo generar el Excel.");
        }
    }

    // ============================================================
    // LIMPIEZA DE RECURSOS
    // ============================================================
    public void Dispose()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _serverReloadCts?.Cancel();
        _serverReloadCts?.Dispose();
    }

    // ============================================================
    // COMPARER PARA SELECCIÓN ESTABLE
    // ============================================================
    private class PersonDtoComparer : IEqualityComparer<PersonDto>
    {
        public bool Equals(PersonDto? x, PersonDto? y) => x?.Id == y?.Id;
        public int GetHashCode(PersonDto obj) => obj.Id.GetHashCode();
    }
}