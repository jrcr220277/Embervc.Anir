@implements IDisposable

<MudMenu @ref="_menuRef"
         AnchorOrigin="Origin.BottomRight"
         TransformOrigin="Origin.TopRight"
         OffsetY="true">

    <ActivatorContent Context="context">
        <MudButton Variant="Variant.Text"
                   Class="p-0"
                   Style="min-width:0; padding:0;"
                   OnClick="@((e)=>context.ToggleAsync(e))">

            <!-- MudAvatar tiene la propiedad Image nativa, es más limpio que usar MudImage por dentro -->
            <MudAvatar Size="Size.Medium"
                       Image="@AvatarUrl"
                       Class="pa-0"
                       Color="Color.Surface"
                       Style="cursor:pointer;"
                       Alt="@UserState.DisplayName">
                @UserState.Initials
            </MudAvatar>

        </MudButton>
    </ActivatorContent>

    <ChildContent>

        <MudMenuItem>
            <MudStack Spacing="0">
                <MudText Typo="Typo.subtitle2">@UserState.DisplayName</MudText>

                @if (!string.IsNullOrWhiteSpace(UserState.Email))
                {
                    <MudText Typo="Typo.caption" Class="text-secondary">
                        @UserState.Email
                    </MudText>
                }
            </MudStack>
        </MudMenuItem>

        <MudDivider />

        <MudMenuItem Icon="@Icons.Material.Filled.AccountCircle"
                     OnClick="@(()=>Nav.NavigateTo("/account/profile"))">
            Mi perfil
        </MudMenuItem>

        <MudMenuItem Icon="@Icons.Material.Filled.LockReset"
                     OnClick="@(()=>Nav.NavigateTo("/change-password"))">
            Cambiar contraseña
        </MudMenuItem>

        <MudDivider />

        <MudMenuItem Icon="@Icons.Material.Filled.Logout"
                     OnClick="ConfirmLogout">
            Cerrar sesión
        </MudMenuItem>

    </ChildContent>
</MudMenu>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] IDialogService DialogService { get; set; } = default!;
    [Inject] IAlertService AlertService { get; set; } = default!;
    [Inject] IAuthService AuthService { get; set; } = default!;
    [Inject] ILogger<UserMenu> Logger { get; set; } = default!;
    [Inject] UserState UserState { get; set; } = default!;

    private MudMenu? _menuRef;

    // CORREGIDO: Extraer la URL del nuevo objeto FileResponse
    private string? AvatarUrl => UserState.ImageFile?.Url;

    protected override void OnInitialized()
    {
        UserState.OnChange += StateHasChanged;
        Logger?.LogInformation("UserMenu inicializado. DisplayName={Name}", UserState.DisplayName);
    }

    public void Dispose()
    {
        UserState.OnChange -= StateHasChanged;
    }

    private async Task ConfirmLogout()
    {
        var confirmed = await ConfirmDialog.Show(
            DialogService,
            "Cerrar sesión",
            "¿Deseas cerrar sesión?",
            type: "info",
            confirmText: "Cerrar",
            centerMessage: true
        );

        if (!confirmed)
            return;

        await LogoutAsync();
    }

    private async Task LogoutAsync()
    {
        try
        {
            await AuthService.LogoutAsync();
            await AlertService.ShowSuccess("Sesión cerrada", "Has cerrado sesión correctamente.");
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Logout error");
            await AlertService.ShowError("Error", "No se pudo cerrar sesión.");
        }
    }
}