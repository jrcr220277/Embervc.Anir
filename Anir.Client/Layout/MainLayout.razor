        BackgroundGray = "#E7E9EC",      // Gris más oscuro — headers, secciones
        DrawerBackground = "#F3F4F6",    // Igual que Background — menú limpio y moderno

        DrawerText = "#1F2937",          // Gris carbón — texto del menú
        DrawerIcon = "#1F2937",          // Íconos del menú

        // ============================================================
        // CAPA 2 — SUPERFICIES (tarjetas, tablas, modales)
        // ============================================================
        Surface = "#FFFFFF",             // Blanco puro — tarjetas y modales
                                         // (contraste perfecto con Background)

        // ============================================================
        // APPBAR
        // ============================================================
        AppbarBackground = "#FFFFFF",    // Igual que Surface — barra superior limpia
        AppbarText = "#1F2937",          // Gris carbón — texto del AppBar

        // ============================================================
        // PRIMARY (Ubuntu Accent)
        // ============================================================
        Primary = "#E95420",             // Naranja Ubuntu — acento cálido y profesional
        PrimaryDarken = "#C34114",       // Naranja quemado — hover/active
        PrimaryLighten = "#FF8A5C",      // Naranja claro — estados suaves

        // ============================================================
        // SECUNDARIOS
        // ============================================================
        Secondary = "#6D6D6D",           // Gris neutro — botones secundarios
