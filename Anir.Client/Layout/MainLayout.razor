@using System
@using System.Security.Claims
@inherits LayoutComponentBase
@using Anir.Shared.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthProvider
@inject Anir.Client.Services.Auth.IAuthService AuthService
@inject Anir.Client.Services.Auth.UserState UserState
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject ILogger<MainLayout> Logger
@inject IDialogService DialogService

<MudThemeProvider Theme="@_theme" IsDarkMode="IsDarkMode" />

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    @if (_isAuthenticated)
    {
        <MudDrawer @bind-Open="_drawerOpen"
                   Anchor="Anchor.Start"
                   Color="Color.Inherit"
                   ClipMode="DrawerClipMode.Never"
                   Variant="DrawerVariant.Mini"
                   Elevation="2"
                   Width="240px">
            <NavMenu DrawerOpen="_drawerOpen" />
        </MudDrawer>
    }

    <MudMainContent>
        <MudAppBar Elevation="0" Dense="true">
            @if (_isAuthenticated)
            {
                <MudIconButton Icon="@(_drawerOpen? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                               Color="Color.Inherit"
                               OnClick="DrawerToggle"
                               Class="ml-0" />
            }
            
            
           @*  <MudSpacer />
            <MudText Typo="Typo.h6" Class="ml-2">Sistema ANIR</MudText>
            <MudText Typo="Typo.body2">Empresa: EMBERVC</MudText> *@
            <MudSpacer />

            @if (_isAuthenticated)
            {
                <UserMenu />
            }
            else
            {
                <MudTooltip Text="Entrar al sistema" Arrow="true">
                    <MudIconButton Icon="@(Icons.Material.Filled.Login)"
                                   Color="Color.Inherit"
                                   OnClick="OpenLogin" />
                </MudTooltip>

                <MudTooltip Text="Cambiar tema" Arrow="true">
                    <MudIconButton Icon="@DarkLightModeButtonIcon"
                                   Color="Color.Inherit"
                                   OnClick="DarkModeToggle" />
                </MudTooltip>
            }
        </MudAppBar>

        <MudContainer MaxWidth="MaxWidth.False">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>






<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    // ============================================================
    // ESTADO Y DEPENDENCIAS
    // ============================================================

    // Indica si el usuario está autenticado
    private bool _isAuthenticated = false;

    // Estado del drawer lateral
    private bool _drawerOpen = true;

    // Modo de tema actual (por defecto Auto)
    private ThemeMode _themeMode = ThemeMode.Auto;

    // Preferencia del sistema operativo (true = dark)
    private bool prefersDarkScheme = true;

    // Tema MudBlazor con paletas personalizadas
    private MudTheme? _theme = null;


    // ============================================================
    // CICLO DE VIDA
    // ============================================================
    protected override async Task OnInitializedAsync()
    {
        // Escuchar cambios de autenticación
        AuthProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;

        // ============================================================
        // 1) Cargar tema cuando NO hay usuario autenticado
        //    Se usa localStorage (tema público)
        // ============================================================
        try
        {
            var savedTheme = await JS.InvokeAsync<string>("localStorage.getItem", "themeMode");

            if (!string.IsNullOrWhiteSpace(savedTheme) &&
                Enum.TryParse<ThemeMode>(savedTheme, out var mode))
            {
                _themeMode = mode;
            }
            else
            {
                // Si no hay nada guardado → Auto (tema del sistema)
                _themeMode = ThemeMode.Auto;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No se pudo leer themeMode desde localStorage");
            _themeMode = ThemeMode.Auto;
        }

        // Crear el tema con tus paletas personalizadas (usando paletas explícitas)
        _theme = new()
        {
            PaletteLight = _lightPalette,
            PaletteDark = _darkPalette,
            LayoutProperties = new LayoutProperties()
        };

        // ============================================================
        // 2) Verificar si el usuario YA está autenticado
        // ============================================================
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;

        if (_isAuthenticated)
        {
            // Cargar datos del usuario (incluye ThemeMode)
            await TryPopulateUserState();

            // ============================================================
            // 3) Aplicar el tema del usuario autenticado
            // ============================================================
            ApplyTheme(UserState.ThemeMode);
        }
        else
        {
            // Si no está autenticado → aplicar tema público
            ApplyTheme(_themeMode);

        }

        // ============================================================
        // 4) Escuchar cambios en UserState (nombre, imagen, tema)
        // ============================================================
        // Registrar handler en una variable para poder desuscribir correctamente en Dispose
        _userStateOnChangeHandler = () => ApplyTheme(UserState.ThemeMode);
        UserState.OnChange += _userStateOnChangeHandler;
    }


    public void Dispose()
    {
        // Limpieza de eventos
        AuthProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        if (_userStateOnChangeHandler != null)
            UserState.OnChange -= _userStateOnChangeHandler;
    }


    // ============================================================
    // EVENTOS DE AUTENTICACIÓN
    // ============================================================
    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            var state = await task;
            var isAuth = state.User.Identity?.IsAuthenticated ?? false;

            if (isAuth && !_isAuthenticated)
            {
                // Usuario acaba de iniciar sesión
                _isAuthenticated = true;

                await TryPopulateUserState();

                // Aplicar tema del usuario
                ApplyTheme(UserState.ThemeMode);
            }
            else if (!isAuth && _isAuthenticated)
            {
                // Usuario cerró sesión
                _isAuthenticated = false;

                UserState.Clear();
                _drawerOpen = false;

                // Volver al tema público
                ApplyTheme(_themeMode);

            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error en OnAuthenticationStateChanged");
        }
    }


    private async Task TryPopulateUserState()
    {
        try
        {
            // MeAsync() actualiza UserState internamente
            await AuthService.MeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No se pudo poblar UserState tras autenticación");
        }
    }


    // ============================================================
    // ACCIONES
    // ============================================================
    public void OpenLogin() => NavManager.NavigateTo("/login");

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;


    // Botón de cambiar tema cuando NO hay usuario autenticado
    private async Task DarkModeToggle()
    {
        _themeMode = _themeMode switch
        {
            ThemeMode.Light => ThemeMode.Dark,
            ThemeMode.Dark => ThemeMode.Auto,
            ThemeMode.Auto => ThemeMode.Light,
            _ => ThemeMode.Auto
        };

        if (_isAuthenticated)
        {
            // Si quieres guardar en servidor, aquí va
        }
        else
        {
            // Guardar preferencia pública
            await JS.InvokeVoidAsync("localStorage.setItem", "themeMode", _themeMode.ToString());
        }

        // Aplicar tema inmediatamente
        ApplyTheme(_themeMode);

    }


    // ============================================================
    // APLICAR TEMA
    // ============================================================
    private void ApplyTheme(ThemeMode mode)
    {
        _themeMode = mode;
        StateHasChanged();
    }


    // ============================================================
    // PROPIEDADES
    // ============================================================
    private bool IsDarkMode =>
        _themeMode switch
        {
            ThemeMode.Light => false,
            ThemeMode.Dark => true,
            ThemeMode.Auto => prefersDarkScheme,
            _ => false
        };

    public string DarkLightModeButtonIcon =>
        _themeMode switch
        {
            ThemeMode.Light => Icons.Material.Filled.LightMode,
            ThemeMode.Dark => Icons.Material.Filled.DarkMode,
            ThemeMode.Auto => Icons.Material.Filled.Brightness4,
            _ => Icons.Material.Filled.LightMode
        };


    // ============================================================
    // PALETAS (versión explícita, manteniendo primary dorado)
    // ============================================================
    // Handler almacenado para poder desuscribirlo correctamente
    private Action? _userStateOnChangeHandler;

    private readonly PaletteLight _lightPalette = new()
    {
        // FONDOS (Perfectos, no toqué nada)
        Background = "#F3F4F6",
        BackgroundGray = "#E7E9EC",
        DrawerBackground = "#F3F4F6",
        DrawerText = "#1F2937",
        DrawerIcon = "#1F2937",

        // SUPERFICIES (Perfectos)
        Surface = "#FFFFFF",

        // APPBAR
        AppbarBackground = "#FFFFFF",
        AppbarText = "#1F2937",

        // ============================================================
        // PRIMARY (CAMBIO RADICAL PERO NECESARIO)
        // Antes: #E95420 (Naranja) -> Ahora: #475569 (Slate 600)
        // Esto da el look "Sistema Serio" sin perder elegancia.
        // ============================================================
        Primary = "#4A6FA5",             // Para rellenos (Botones, Tabs) - No se toca, está perfecto
        PrimaryDarken = "#345280",       // Para el hover de los botones - No se toca
        PrimaryLighten = "#5B9BD5",      // 🚨 NUEVO: Azul acero MÁS VIVO y brillante (Para iconos/bordes)

        // SECUNDARIOS (Perfectos)
        Secondary = "#6D6D6D",
        SecondaryDarken = "#4F4F4F",
        SecondaryLighten = "#9E9E9E",

        // TEXTO (Perfectos)
        TextPrimary = "#1A1A1A",
        TextSecondary = "#555555",
        TextDisabled = "#999999",

        // LÍNEAS (Perfectos)
        Divider = "#D1D5DB",
        DividerLight = "rgba(0,0,0,0.06)",
        LinesDefault = "#D1D5DB",
        LinesInputs = "rgba(0,0,0,0.25)",
        TableLines = "#D1D5DB",

        // TABLAS (Perfectos)
        TableStriped = "rgba(0,0,0,0.02)",
        TableHover = "rgba(0,0,0,0.06)",

        // OVERLAYS
        OverlayDark = "rgba(0,0,0,0.40)",
        OverlayLight = "rgba(255,255,255,0.50)",

        // ESTADOS (Los tuyos de Light están bien, pero los pulí un poco)
        Success = "#16A34A",             // Verde 600 (Un poco más vibrante que el tuyo)
        SuccessDarken = "#15803D",
        SuccessLighten = "#4ADE80",

        Warning = "#CA8A04",             // Amarillo 600 (Menos "enfantasme" que el anterior)
        WarningDarken = "#A16207",
        WarningLighten = "#FDE047",

        Error = "#DC2626",               // Rojo 600 (El estándar moderno de error)
        ErrorDarken = "#B91C1C",
        ErrorLighten = "#FCA5A5",

        Info = "#2563EB",                // Azul 600
        InfoDarken = "#1D4ED8",
        InfoLighten = "#93C5FD",

        // GRAYS (Perfectos)
        GrayDefault = "#9CA3AF",
        GrayLight = "#D1D5DB",
        GrayLighter = "#E5E7EB",
        GrayDark = "#6B7280",
        GrayDarker = "#4B5563"
    };

    private readonly PaletteDark _darkPalette = new()
    {
        // FONDOS (Perfectos)
        Background = "#1B2433",
        BackgroundGray = "#2A3244",
        DrawerBackground = "#1E293B",
        DrawerText = "rgba(255,255,255,0.75)",
        DrawerIcon = "rgba(255,255,255,0.75)",

        // SUPERFICIES (Perfecto)
        Surface = "#273447",

        // APPBAR (Perfecto)
        AppbarBackground = "#1B2433",
        AppbarText = "rgba(255,255,255,0.85)",

        // ============================================================
        // PRIMARY DARK (Debe ser claro para contrastar, no el mismo de Light)
        // ============================================================
        Primary = "#4A6FA5",             // Para rellenos - No se toca
        PrimaryDarken = "#345280",       // Para hover - No se toca
        PrimaryLighten = "#7EB8E0",      // Un poco más brillante para que resalte en la oscuridad

        // SECUNDARIOS
        Secondary = "#A0A0A0",
        SecondaryDarken = "#7A7A7A",
        SecondaryLighten = "#C8C8C8",

        // TEXTO
        TextPrimary = "#FFFFFF",
        TextSecondary = "#C0C0C0",
        TextDisabled = "#7A7A7A",

        // LÍNEAS
        Divider = "#4B5563",
        DividerLight = "rgba(255,255,255,0.10)",
        LinesDefault = "#4B5563",
        LinesInputs = "rgba(255,255,255,0.40)",
        TableLines = "#4B5563",

        // TABLAS
        TableStriped = "rgba(255,255,255,0.03)",
        TableHover = "rgba(255,255,255,0.16)",

        // OVERLAYS
        OverlayDark = "rgba(0,0,0,0.55)",
        OverlayLight = "rgba(255,255,255,0.50)",

        // ============================================================
        // ESTADOS DARK (CORREGIDOS - "Pastelizados" para no quemar la vista)
        // ============================================================
        Success = "#4ADE80",             // Verde pastel (Ojo: no #4CAF50 que es muy fuerte)
        SuccessDarken = "#22C55E",
        SuccessLighten = "#86EFAC",

        Warning = "#FACC15",             // Amarillo pastel
        WarningDarken = "#EAB308",
        WarningLighten = "#FDE047",

        Error = "#FCA5A5",               // Rojo pastel (Ojo: no #EF5350)
        ErrorDarken = "#F87171",
        ErrorLighten = "#FECACA",

        Info = "#93C5FD",                // Azul pastel (Ojo: no #2196F3)
        InfoDarken = "#60A5FA",
        InfoLighten = "#BFDBFE",

        // GRAYS
        GrayDefault = "#9CA3AF",
        GrayLight = "#D1D5DB",
        GrayLighter = "#E5E7EB",
        GrayDark = "#6B7280",
        GrayDarker = "#4B5563"
    };



}



