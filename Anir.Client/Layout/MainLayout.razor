        // OVERLAYS (modales)
        // ============================================================
        OverlayDark = "rgba(0,0,0,0.40)",  // Oscurece fondo — modal resalta
        OverlayLight = "rgba(255,255,255,0.50)",

        // ============================================================
        // ESTADOS (Success, Warning, Error, Info)
        // ============================================================
        Success = "#1B873F",             // Verde éxito
        SuccessDarken = "#0F6A2F",
        SuccessLighten = "#4CD96B",

        Warning = "#E6A437",             // Amarillo advertencia
        WarningDarken = "#C1872A",
        WarningLighten = "#F7C66A",

        Error = "#D64545",               // Rojo error
        ErrorDarken = "#B83232",
        ErrorLighten = "#E97A7A",

        Info = "#3A6EA5",                // Azul informativo
        InfoDarken = "#2E5684",
        InfoLighten = "#7AA3D1",

        // ============================================================
        // GRAYS (coherentes con Slate Light)
        // ============================================================
        GrayDefault = "#9CA3AF",         // Slate 400 — gris base
        GrayLight = "#D1D5DB",           // Slate 300 — gris claro
        GrayLighter = "#E5E7EB",         // Slate 200 — gris muy claro
        GrayDark = "#6B7280",            // Slate 500 — gris oscuro
        GrayDarker = "#4B5563"           // Slate 600 — gris profundo
    };





    private readonly PaletteDark _darkPalette = new()
    {
        // ============================================================
        // CAPA 1 — FONDO GENERAL (Gunmetal / Slate 900)
        // ============================================================
        Background = "#1E293B",          // Azul-gris oscuro (Slate 900) — fondo principal
        BackgroundGray = "#2A3244",      // Slate 800 — secciones secundarias, headers
        DrawerBackground = "#1E293B",    // Igual que Background — menú lateral moderno

        DrawerText = "rgba(255,255,255,0.75)",   // Blanco suave — texto del menú
        DrawerIcon = "rgba(255,255,255,0.75)",   // Blanco suave — íconos del menú

        // ============================================================
        // CAPA 2 — SUPERFICIES (tarjetas, tablas, modales)
        // ============================================================
        Surface = "#273447",             // Slate 850 — tarjetas, tablas, modales (más claro que fondo)

