        SecondaryLighten = "#9E9E9E",

        // ============================================================
        // TEXTO
        // ============================================================
        TextPrimary = "#1A1A1A",         // Negro suave — texto principal
        TextSecondary = "#555555",       // Gris medio — texto secundario
        TextDisabled = "#999999",        // Gris claro — texto deshabilitado

        // ============================================================
        // LÍNEAS Y DIVISORES (más visibles)
        // ============================================================
        Divider = "#D1D5DB",             // Slate 300 — líneas visibles y elegantes
        DividerLight = "rgba(0,0,0,0.06)", // Líneas suaves
        LinesDefault = "#D1D5DB",        // Líneas generales
