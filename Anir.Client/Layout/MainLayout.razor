@using System
@using System.Security.Claims
@using Anir.Shared.Enums
@using Anir.Client.Services.Administration
@using Microsoft.AspNetCore.Components.Authorization

@inherits LayoutComponentBase

@inject AuthenticationStateProvider AuthProvider
@inject Anir.Client.Services.Auth.IAuthService AuthService
@inject Anir.Client.Services.Auth.UserState UserState
@inject SystemSettingService SettingService
@inject NavigationManager NavManager
@inject IJSRuntime JS
@inject ILogger<MainLayout> Logger
@inject IDialogService DialogService

<MudThemeProvider Theme="@_theme" IsDarkMode="IsDarkMode" />

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    @if (_isAuthenticated)
    {
        <MudDrawer @bind-Open="_drawerOpen"
                   Anchor="Anchor.Start"
                   Color="Color.Inherit"
                   ClipMode="DrawerClipMode.Never"
                   Variant="DrawerVariant.Mini"
                   Elevation="2"
                   Width="240px">
           
           
            <NavMenu DrawerOpen="_drawerOpen" />

        </MudDrawer>
    }

    <MudMainContent>
        <MudAppBar Elevation="0" Dense="true">
            @if (_isAuthenticated)
            {
                <MudIconButton Icon="@(_drawerOpen ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                               Color="Color.Inherit"
                               OnClick="DrawerToggle"
                               Class="ml-0" />
            }
            
            <MudSpacer />

            @if (_isAuthenticated)
            {
                <UserMenu />
            }
            else
            {
                <MudTooltip Text="Entrar al sistema" Arrow="true">
                    <MudIconButton Icon="@(Icons.Material.Filled.Login)"
                                   Color="Color.Inherit"
                                   OnClick="OpenLogin" />
                </MudTooltip>

                <MudTooltip Text="Cambiar tema" Arrow="true">
                    <MudIconButton Icon="@DarkLightModeButtonIcon"
                                   Color="Color.Inherit"
                                   OnClick="DarkModeToggle" />
                </MudTooltip>
            }
        </MudAppBar>

        <MudContainer MaxWidth="MaxWidth.False">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    // ============================================================
    // ESTADO Y DEPENDENCIAS
    // ============================================================
    private bool _isAuthenticated = false;
    private bool _drawerOpen = true;
    private ThemeMode _themeMode = ThemeMode.Auto;
    private bool prefersDarkScheme = true;
    private MudTheme? _theme = null;
    private string _currentPrimaryColor = "#4A6FA5";
    
    private Action? _userStateOnChangeHandler;
    private Action? _settingOnChangeHandler;

    // ============================================================
    // CICLO DE VIDA
    // ============================================================
    protected override async Task OnInitializedAsync()
    {
        AuthProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        
        _userStateOnChangeHandler = () => ApplyTheme(UserState.ThemeMode);
        UserState.OnChange += _userStateOnChangeHandler;

        _settingOnChangeHandler = RefreshThemeFromSettings;
        SettingService.OnChange += _settingOnChangeHandler;

        try
        {
            var savedTheme = await JS.InvokeAsync<string>("localStorage.getItem", "themeMode");
            if (!string.IsNullOrWhiteSpace(savedTheme) && Enum.TryParse<ThemeMode>(savedTheme, out var mode))
                _themeMode = mode;
            else
                _themeMode = ThemeMode.Auto;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No se pudo leer themeMode desde localStorage");
            _themeMode = ThemeMode.Auto;
        }

        RebuildTheme();

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated ?? false;

        if (_isAuthenticated)
        {
            await TryPopulateUserState();
            ApplyTheme(UserState.ThemeMode);
            await LoadSystemSettingsAsync();
        }
        else
        {
            ApplyTheme(_themeMode);
        }
    }

    public void Dispose()
    {
        AuthProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
        if (_userStateOnChangeHandler != null)
            UserState.OnChange -= _userStateOnChangeHandler;
        if (_settingOnChangeHandler != null)
            SettingService.OnChange -= _settingOnChangeHandler;
    }

    // ============================================================
    // EVENTOS DE AUTENTICACIÓN
    // ============================================================
    private async void OnAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            var state = await task;
            var isAuth = state.User.Identity?.IsAuthenticated ?? false;

            if (isAuth && !_isAuthenticated)
            {
                _isAuthenticated = true;
                await TryPopulateUserState();
                ApplyTheme(UserState.ThemeMode);
                await LoadSystemSettingsAsync();
            }
            else if (!isAuth && _isAuthenticated)
            {
                _isAuthenticated = false;
                UserState.Clear();
                SettingService.Clear();
                _drawerOpen = false;
                ApplyTheme(_themeMode);
                RefreshThemeFromSettings();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error en OnAuthenticationStateChanged");
        }
    }

    private async Task TryPopulateUserState()
    {
        try { await AuthService.MeAsync(); }
        catch (Exception ex) { Logger.LogWarning(ex, "No se pudo poblar UserState tras autenticación"); }
    }

    /// <summary>
    /// Carga la config de la DB SIN disparar el evento (para la primera carga).
    /// </summary>
    private async Task LoadSystemSettingsAsync()
    {
        try
        {
            await SettingService.GetAsync();
            RefreshThemeFromSettings();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No se pudo cargar la configuración del sistema.");
        }
    }

    /// <summary>
    /// SE DISPARA SOLO cuando el admin guarda cambios en /system/settings
    /// </summary>
    private void RefreshThemeFromSettings()
    {
        var settings = SettingService.Settings;
        
        _currentPrimaryColor = (settings is not null && !string.IsNullOrWhiteSpace(settings.PrimaryColor))
            ? settings.PrimaryColor
            : "#4A6FA5";
            
        RebuildTheme();
        StateHasChanged(); // Refresca el Drawer (logo/nombre) y colores
    }

    // ============================================================
    // ACCIONES
    // ============================================================
    public void OpenLogin() => NavManager.NavigateTo("/login");
    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task DarkModeToggle()
    {
        _themeMode = _themeMode switch
        {
            ThemeMode.Light => ThemeMode.Dark,
            ThemeMode.Dark => ThemeMode.Auto,
            ThemeMode.Auto => ThemeMode.Light,
            _ => ThemeMode.Auto
        };

        if (!_isAuthenticated)
            await JS.InvokeVoidAsync("localStorage.setItem", "themeMode", _themeMode.ToString());

        ApplyTheme(_themeMode);
    }

    private void ApplyTheme(ThemeMode mode)
    {
        _themeMode = mode;
        StateHasChanged();
    }

    // ============================================================
    // PROPIEDADES
    // ============================================================
    private bool IsDarkMode => _themeMode switch { ThemeMode.Light => false, ThemeMode.Dark => true, ThemeMode.Auto => prefersDarkScheme, _ => false };

    public string DarkLightModeButtonIcon => _themeMode switch { ThemeMode.Light => Icons.Material.Filled.LightMode, ThemeMode.Dark => Icons.Material.Filled.DarkMode, ThemeMode.Auto => Icons.Material.Filled.Brightness4, _ => Icons.Material.Filled.LightMode };

    // ============================================================
    // CONSTRUCTOR DE TEMA DINÁMICO
    // ============================================================
    private void RebuildTheme()
    {
        _theme = new MudTheme
        {
            PaletteLight = BuildLightPalette(_currentPrimaryColor),
            PaletteDark = BuildDarkPalette(_currentPrimaryColor),
            LayoutProperties = new LayoutProperties()
        };
    }

    private PaletteLight BuildLightPalette(string primary) => new()
    {
        Background = "#F3F4F6",
        BackgroundGray = "#E7E9EC",
        DrawerBackground = "#F3F4F6",
        DrawerText = "#1F2937",
        DrawerIcon = "#1F2937",
        Surface = "#FFFFFF",
        AppbarBackground = "#FFFFFF",
        AppbarText = "#1F2937",
        Primary = primary,
        PrimaryDarken = DarkenColor(primary, 15),
        PrimaryLighten = LightenColor(primary, 20),
        Secondary = "#6D6D6D",
        SecondaryDarken = "#4F4F4F",
        SecondaryLighten = "#9E9E9E",
        TextPrimary = "#1A1A1A",
        TextSecondary = "#555555",
        TextDisabled = "#999999",
        Divider = "#D1D5DB",
        DividerLight = "rgba(0,0,0,0.06)",
        LinesDefault = "#D1D5DB",
        LinesInputs = "rgba(0,0,0,0.25)",
        TableLines = "#D1D5DB",
        TableStriped = "rgba(0,0,0,0.02)",
        TableHover = "rgba(0,0,0,0.06)",
        OverlayDark = "rgba(0,0,0,0.40)",
        OverlayLight = "rgba(255,255,255,0.50)",
        Success = "#16A34A",
        SuccessDarken = "#15803D",
        SuccessLighten = "#4ADE80",
        Warning = "#CA8A04",
        WarningDarken = "#A16207",
        WarningLighten = "#FDE047",
        Error = "#DC2626",
        ErrorDarken = "#B91C1C",
        ErrorLighten = "#FCA5A5",
        Info = "#2563EB",
        InfoDarken = "#1D4ED8",
        InfoLighten = "#93C5FD",
        GrayDefault = "#9CA3AF",
        GrayLight = "#D1D5DB",
        GrayLighter = "#E5E7EB",
        GrayDark = "#6B7280",
        GrayDarker = "#4B5563"
    };

    private PaletteDark BuildDarkPalette(string primary) => new()
    {
        Background = "#1B2433",
        BackgroundGray = "#2A3244",
        DrawerBackground = "#1E293B",
        DrawerText = "rgba(255,255,255,0.75)",
        DrawerIcon = "rgba(255,255,255,0.75)",
        Surface = "#273447",
        AppbarBackground = "#1B2433",
        AppbarText = "rgba(255,255,255,0.85)",
        Primary = primary,
        PrimaryDarken = DarkenColor(primary, 10),
        PrimaryLighten = LightenColor(primary, 30),
        Secondary = "#A0A0A0",
        SecondaryDarken = "#7A7A7A",
        SecondaryLighten = "#C8C8C8",
        TextPrimary = "#FFFFFF",
        TextSecondary = "#C0C0C0",
        TextDisabled = "#7A7A7A",
        Divider = "#4B5563",
        DividerLight = "rgba(255,255,255,0.10)",
        LinesDefault = "#4B5563",
        LinesInputs = "rgba(255,255,255,0.40)",
        TableLines = "#4B5563",
        TableStriped = "rgba(255,255,255,0.03)",
        TableHover = "rgba(255,255,255,0.16)",
        OverlayDark = "rgba(0,0,0,0.55)",
        OverlayLight = "rgba(255,255,255,0.50)",
        Success = "#4ADE80",
        SuccessDarken = "#22C55E",
        SuccessLighten = "#86EFAC",
        Warning = "#FACC15",
        WarningDarken = "#EAB308",
        WarningLighten = "#FDE047",
        Error = "#FCA5A5",
        ErrorDarken = "#F87171",
        ErrorLighten = "#FECACA",
        Info = "#93C5FD",
        InfoDarken = "#60A5FA",
        InfoLighten = "#BFDBFE",
        GrayDefault = "#9CA3AF",
        GrayLight = "#D1D5DB",
        GrayLighter = "#E5E7EB",
        GrayDark = "#6B7280",
        GrayDarker = "#4B5563"
    };

    // ============================================================
    // HELPERS DE COLOR
    // ============================================================
    private static string DarkenColor(string hex, int percent)
    {
        var rgb = HexToRgb(hex);
        return $"#{(int)(rgb.R * (100 - percent) / 100):X2}{(int)(rgb.G * (100 - percent) / 100):X2}{(int)(rgb.B * (100 - percent) / 100):X2}";
    }

    private static string LightenColor(string hex, int percent)
    {
        var rgb = HexToRgb(hex);
        var r = Math.Min(255, rgb.R + (int)((255 - rgb.R) * percent / 100));
        var g = Math.Min(255, rgb.G + (int)((255 - rgb.G) * percent / 100));
        var b = Math.Min(255, rgb.B + (int)((255 - rgb.B) * percent / 100));
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    private static (int R, int G, int B) HexToRgb(string hex)
    {
        hex = hex.Replace("#", "");
        if (hex.Length == 6)
        {
            return (
                R: Convert.ToInt32(hex.Substring(0, 2), 16),
                G: Convert.ToInt32(hex.Substring(2, 2), 16),
                B: Convert.ToInt32(hex.Substring(4, 2), 16)
            );
        }
        return (74, 111, 165); // Fallback por defecto
    }
}