@using Anir.Client.Services.Auth
@using Anir.Client.Services.SystemSettings
@inject UserState User
@inject SystemSettingService SettingService

<MudNavMenu Dense="true">
        
    @* ═══ 1. HEADER DEL DRAWER ═══ *@
    @if (SettingService.Settings is not null)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="pa-4 pb-2">
            
            @if (!string.IsNullOrEmpty(SettingService.Settings.ImageFile?.Url))
            {
                @* LOGO REAL: Se muestra rectangular, se adapta al ancho, máximo 40px de alto *@
                <MudImage Src="@SettingService.Settings.ImageFile.Url"
                          ObjectFit="ObjectFit.Contain"
                          Style="max-height: 40px; width: auto;" />
            }
            else
            {
                @* SI NO HAY LOGO: Se muestra el ícono dentro de un Avatar cuadrado *@
                <MudAvatar Color="Color.Surface"
                           Variant="Variant.Outlined"
                           Style="width: 40px; height: 40px;">
                    <MudIcon Icon="@Icons.Material.Filled.Business" />
                </MudAvatar>
            }
            
            @if (DrawerOpen)
            {
                <MudText Typo="Typo.subtitle2"
                         Color="Color.Primary"
                         Class="font-weight-bold mt-2 text-center"
                         Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 100%;">
                    @(SettingService.Settings.ShortName ?? SettingService.Settings.Name)
                </MudText>
            }
        </MudStack>
        <MudDivider Light="true" />
    }

    @* ═══ 2. MENÚ ═══ *@
    <MudNavLink Href="/dashboard"
                Icon="@Icons.Material.Outlined.Dashboard"
                Match="NavLinkMatch.Prefix">
        Dashboard
    </MudNavLink>

    @if (User.Active)
    {
        <MudNavGroup Title="Estructura Organizativa"
                     Icon="@Icons.Material.Outlined.AccountTree"
                     Expanded="true">

            <MudNavLink Href="/organisms" Icon="@Icons.Material.Outlined.AccountBalance" Match="NavLinkMatch.Prefix">Organismos</MudNavLink>
            <MudNavLink Href="/companies" Icon="@Icons.Material.Outlined.Domain" Match="NavLinkMatch.Prefix">Empresas</MudNavLink>
            <MudNavLink Href="/uebs" Icon="@Icons.Material.Outlined.Factory" Match="NavLinkMatch.Prefix">Establecimientos</MudNavLink>
            <MudNavLink Href="/persons" Icon="@Icons.Material.Outlined.Hail" Match="NavLinkMatch.Prefix">Aniristas</MudNavLink>
        </MudNavGroup>

        <MudNavGroup Title="Trabajos ANIR"
                     Icon="@Icons.Material.Outlined.Work"
                     Expanded="true">

            <MudNavLink Href="/anirworks" Icon="@Icons.Material.Outlined.ListAlt" Match="NavLinkMatch.Prefix">Trabajos ANIR</MudNavLink>
            <MudNavLink Href="/anirworks/create" Icon="@Icons.Material.Outlined.AddCircle" Match="NavLinkMatch.Prefix">Crear Trabajo</MudNavLink>
            <MudNavLink Href="/anirworks/reports" Icon="@Icons.Material.Outlined.Assessment" Match="NavLinkMatch.Prefix">Reportes ANIR</MudNavLink>
        </MudNavGroup>
    }

    @if (User.Roles.Contains("Administrador") || User.Roles.Contains("Supervisor"))
    {
        <MudNavLink Href="/users" Icon="@Icons.Material.Outlined.People" Match="NavLinkMatch.Prefix">Gestión de Usuarios</MudNavLink>
    }
  
  
</MudNavMenu>

<MudSpacer />

@* ═══ 4. CONFIGURACIÓN ABAJO ═══ *@
@if (User.Roles.Contains("Administrador"))
{
    <MudNavMenu Dense="true">
    <MudDivider Light="true" />
    <MudNavLink Href="/system/settings"
                Icon="@Icons.Material.Outlined.Settings"
                Match="NavLinkMatch.Prefix">
        Configuración
    </MudNavLink>
    </MudNavMenu>
}

@code {
    [Parameter] public bool DrawerOpen { get; set; }
}