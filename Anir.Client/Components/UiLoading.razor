@using MudBlazor
@implements IDisposable

<div class="d-flex justify-center align-center" style="@WrapperStyle">
    <MudStack Spacing="2" AlignItems="AlignItems.Center">
        @if (Indeterminate)
        {
            <MudProgressCircular Color="@Color" Size="@Size" Indeterminate="true" />
        }
        else
        {
            <MudProgressCircular Color="@Color" Size="@Size" Value="@ProgressValue">
                <ChildContent>
                    <MudText Typo="Typo.subtitle2">@($"{ProgressValue:0}%")</MudText>
                </ChildContent>
            </MudProgressCircular>
        }

        <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Message</MudText>
    </MudStack>
</div>

@code {
    [Parameter] public string Message { get; set; } = "Cargando...";
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public Size Size { get; set; } = Size.Medium;
    [Parameter] public bool Indeterminate { get; set; } = true;
    [Parameter] public double ProgressValue { get; set; } = 0;
    
    [Parameter] public string ContainerHeight { get; set; } = "auto";

    // Si le pasas altura (ej: "300px" o "100vh"), la aplica. Si es "auto", ocupa lo del contenido.
    private string WrapperStyle => ContainerHeight == "auto"
        ? ""
        : $"height: {ContainerHeight}; width: 100%;";

    public void Dispose() { }
}