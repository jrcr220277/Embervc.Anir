@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3" Class="mb-2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudAvatar Color="@ResolvedColor" Variant="Variant.Filled" Size="Size.Medium">
                    <MudIcon Icon="@ResolvedIcon" Style="font-size: 1.4rem;" />
                </MudAvatar>
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">@Title</MudText>
            </MudStack>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="@((CenterMessage ? Align.Center : Align.Left))">@Message</MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        @if (ShowCancelButton)
        {
            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="Cancel">@CancelText</MudButton>
        }
        <MudButton Variant="Variant.Filled" Color="@ResolvedColorButton" StartIcon="@ResolvedActionIcon" OnClick="Confirm">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Title { get; set; } = "Confirmar";
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public string ConfirmText { get; set; } = "Aceptar";
    [Parameter] public string CancelText { get; set; } = "Cancelar";
    [Parameter] public bool CenterMessage { get; set; } = false;
    [Parameter] public bool ShowCancelButton { get; set; } = true;
    [Parameter] public string Type { get; set; } = "default";

    private string NormalizedType => (Type ?? "default").Trim().ToLower();

    private Color ResolvedColor => NormalizedType switch { "delete" => Color.Error, "warning" => Color.Warning, "success" => Color.Success, "info" => Color.Info, _ => Color.Primary };
    private Color ResolvedColorButton => NormalizedType switch { "delete" => Color.Error, "warning" => Color.Default, "success" => Color.Default, "info" => Color.Default, _ => Color.Primary };
    private string ResolvedIcon => NormalizedType switch { "delete" => Icons.Material.Filled.Delete, "warning" => Icons.Material.Filled.Warning, "success" => Icons.Material.Filled.CheckCircle, "info" => Icons.Material.Filled.Info, _ => Icons.Material.Filled.HelpOutline };
    private string? ResolvedActionIcon => NormalizedType switch { "delete" => Icons.Material.Filled.Delete, "success" => Icons.Material.Filled.Check, _ => null };

    void Confirm() => MudDialog.Close(DialogResult.Ok(true));
    void Cancel() => MudDialog.Cancel();

    public static async Task<bool> Show(IDialogService dialogService, string title, string message, string type = "default", string confirmText = "Aceptar", string cancelText = "Cancelar", bool centerMessage = false, bool showCancelButton = true)
    {
        var parameters = new DialogParameters { ["Title"] = title, ["Message"] = message, ["Type"] = type, ["ConfirmText"] = confirmText, ["CancelText"] = cancelText, ["CenterMessage"] = centerMessage, ["ShowCancelButton"] = showCancelButton };
        var options = new DialogOptions { CloseButton = false, BackdropClick = false, MaxWidth = MaxWidth.Small, Position = DialogPosition.Center };
        var dialog = await dialogService.ShowAsync<ConfirmDialog>("", parameters, options);
        var result = await dialog.Result;
        return result.Data is true;
    }
}