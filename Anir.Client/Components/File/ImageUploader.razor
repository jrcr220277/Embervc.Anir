@using Anir.Client.Services.Files
@using Anir.Shared
@inject FileService FileService

<MudStack Spacing="2" AlignItems="AlignItems.Center">

    <div style="position: relative; width:@Size}px; height:@Size}px;">
        <MudAvatar Elevation="2"
                   Square="Square"
                   Rounded="Rounded"
                   Style="@($"width:{Size}px;height:{Size}px;overflow:hidden;")">

            @if (PreviewUrl is not null)
            {
                <MudImage Src="@PreviewUrl" Fluid="true" />
            }
            else if (!string.IsNullOrEmpty(Value))
            {
                <MudImage Src="@Value" Fluid="true" />
            }
            else
            {
                <MudIcon Icon="@PlaceholderIcon" Style="font-size:4rem;" />
            }
        </MudAvatar>
    </div>

    @if (!ReadOnly)
    {
        <FileUploaderBase OnChanged="HandleTempFile"
                          OnDelete="DeleteImage" />
    }

</MudStack>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public string Container { get; set; } = "general";
    [Parameter] public int Size { get; set; } = 200;
    [Parameter] public bool Rounded { get; set; } = true;
    [Parameter] public bool Square { get; set; } = false;
    [Parameter] public bool ReadOnly { get; set; } = false;
    [Parameter] public string PlaceholderIcon { get; set; } = Icons.Material.Filled.Image;

    [Parameter] public EventCallback<FileResponse?> OnChanged { get; set; }

    private IBrowserFile? TempFile;
    private string? PreviewUrl;

    protected override void OnParametersSet()
    {
        // Si no hay archivo temporal, usar la imagen original
        if (TempFile is null)
            PreviewUrl = Value;
    }

    private async Task HandleTempFile(IBrowserFile? file)
    {
        TempFile = file;

        if (file is null)
        {
            PreviewUrl = Value;
            await OnChanged.InvokeAsync(null);
            return;
        }

        // Crear preview local
        using var stream = file.OpenReadStream();
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        PreviewUrl = $"data:{file.ContentType};base64,{base64}";

        await OnChanged.InvokeAsync(null);
    }

    public async Task<FileResponse?> UploadIfNeededAsync()
    {
        if (TempFile is null)
            return null;

        var result = await FileService.UploadAsync(TempFile, Container);

        TempFile = null;
        PreviewUrl = result?.Url;

        return result;
    }

    // ⭐ Lógica de borrado (usada por el botón de abajo)
    private async Task DeleteImage()
    {
        // Caso 1: borrar archivo temporal
        if (TempFile is not null)
        {
            TempFile = null;
            PreviewUrl = null;
            await OnChanged.InvokeAsync(null);
            return;
        }

        // Caso 2: borrar imagen actual del servidor
        if (!string.IsNullOrEmpty(Value))
        {
            try
            {
                var fileId = Path.GetFileName(new Uri(Value).LocalPath);
                if (!string.IsNullOrEmpty(fileId))
                    await FileService.DeleteAsync(Container, fileId);
            }
            catch
            {
                var fileId = Path.GetFileName(Value);
                if (!string.IsNullOrEmpty(fileId))
                    await FileService.DeleteAsync(Container, fileId);
            }
        }

        // Limpiar preview y notificar
        PreviewUrl = null;
        await OnChanged.InvokeAsync(null);
    }
}
