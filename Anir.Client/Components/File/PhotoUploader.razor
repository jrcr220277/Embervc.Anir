@using Anir.Shared.Contracts.Common
@using Anir.Web.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject FileService FileService
@inject IAlertService AlertService

<MudStack AlignItems="AlignItems.Center" Spacing="1">
    
    <div style="display: none;">
        <MudFileUpload T="IBrowserFile"
                       @ref="FileUploadRef"
                       Accept="image/*"
                       FilesChanged="OnFileChanged" />
    </div>

    <div style="position: relative; width: @(PixelSize)px; height: @(PixelSize)px;">
        
        @if (HasImage)
        {
            <img src="@(PreviewUrl ?? Value)" alt="Vista previa"
                 style="width: 100%; height: 100%; object-fit: cover; border-radius: @(IsProfile ? "50%" : "8px");" />
            
            @if (!IsViewMode)
            {
                <!-- Overlay con botones monocromáticos (blancos) y buen espaciado -->
                <div class="d-flex align-center gap-2 pa-2"
                     style="position: absolute; bottom: 8px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.6); border-radius: 24px;">
                    
                    <MudTooltip Text="Cambiar imagen">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Inherit"
                                       Style="color: white;"
                                       OnClick="TriggerUpload" />
                    </MudTooltip>

                    @if (ShowDelete)
                    {
                        <MudDivider Vertical="true" FlexItem="true" Light="true" Style="height: 16px;" />
                        
                        <MudTooltip Text="Eliminar imagen">
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                           Size="Size.Small"
                                           Color="Color.Inherit"
                                           Style="color: white;"
                                           OnClick="HandleDelete" />
                        </MudTooltip>
                    }
                </div>
            }
        }
        else if (IsViewMode)
        {
            <MudAvatar Rounded="@(!IsProfile)" Color="Color.Surface" Size="Size.Large"
                       Style="@($"width:{PixelSize}px; height:{PixelSize}px; border: 2px dashed var(--mud-palette-divider);")">
                <MudIcon Icon="@DefaultIcon" Style="font-size: 3rem; color: var(--mud-palette-text-disabled);" />
            </MudAvatar>
        }
        else
        {
            <!-- Dropzone clickeable -->
            <div @onclick="TriggerUpload" class="cursor-pointer d-flex justify-center align-center"
                 Style="@($"width:{PixelSize}px; height:{PixelSize}px; border-radius: {(IsProfile ? "50%" : "8px")}; border: 2px dashed var(--mud-palette-primary); background-color: var(--mud-palette-action-disabled-background);")">
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudIcon Icon="@DefaultIcon" Style="font-size: 3rem; color: var(--mud-palette-primary);" />
                    <MudText Typo="Typo.overline" Color="Color.Primary" Style="font-size: 0.7rem;">Subir imagen</MudText>
                </MudStack>
            </div>
        }

        @if (isUploading)
        {
            <div class="d-flex justify-center align-center"
                 Style="@($"position: absolute; inset: 0; background: rgba(255,255,255,0.8); border-radius: {(IsProfile ? "50%" : "8px")}; z-index: 5;")">
                <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(UploadedResponse?.Name))
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="text-truncate text-center mt-1"
                 Style="@($"max-width: {PixelSize}px;")">
            @UploadedResponse.Name
        </MudText>
    }
</MudStack>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public int PixelSize { get; set; } = 150;
    [Parameter] public bool ShowDelete { get; set; } = true;
    [Parameter] public EventCallback<FileResponse?> OnUploaded { get; set; }
    [Parameter] public bool IsProfile { get; set; } = true;
    [Parameter] public bool IsViewMode { get; set; } = false;
    [Parameter] public string Folder { get; set; } = "images";
    
    private const long MaxFileSize = 10 * 1024 * 1024;
    private string? PreviewUrl;
    private FileResponse? UploadedResponse;
    private bool isUploading = false;
    
    private MudFileUpload<IBrowserFile>? FileUploadRef;

    private string DefaultIcon => IsProfile ? Icons.Material.Filled.Person : Icons.Material.Filled.Image;
    private bool HasImage => PreviewUrl != null || !string.IsNullOrEmpty(Value) || UploadedResponse != null;

    private async Task TriggerUpload()
    {
        if (FileUploadRef != null)
        {
            await FileUploadRef.OpenFilePickerAsync();
        }
    }

    private async Task OnFileChanged(IBrowserFile file)
    {
        if (file == null) return;

        if (file.Size > MaxFileSize)
        {
            await AlertService.ShowError("Tamaño excedido", $"La imagen no puede superar {MaxFileSize / 1024 / 1024} MB.");
            return;
        }

        isUploading = true;
        StateHasChanged();

        try
        {
            var response = await FileService.UploadAsync(file, Folder);
            if (response != null)
            {
                UploadedResponse = response;
                PreviewUrl = response.Url;
                await OnUploaded.InvokeAsync(response);
            }
            else
            {
                await CleanupAndNotify(null);
                await AlertService.ShowError("Error", "No se recibió respuesta del servidor.");
            }
        }
        catch (Exception ex)
        {
            await CleanupAndNotify(null);
            await AlertService.ShowError("Error al subir", ex.Message);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task HandleDelete()
    {
        if (UploadedResponse != null && UploadedResponse.Id > 0)
        {
            try { await FileService.DeleteAsync(UploadedResponse.Id); }
            catch (Exception ex) { await AlertService.ShowError("Error", $"No se pudo eliminar del servidor: {ex.Message}"); }
        }
        await CleanupAndNotify(null);
    }

    private async Task CleanupAndNotify(FileResponse? response)
    {
        PreviewUrl = null;
        UploadedResponse = response;
        await OnUploaded.InvokeAsync(response);
    }
}