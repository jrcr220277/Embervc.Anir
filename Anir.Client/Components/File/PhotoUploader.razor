@using MudBlazor
@using Microsoft.AspNetCore.Components.Forms

<MudStack AlignItems="AlignItems.Center" Spacing="2">

    <div style="@($"position:relative; width:{Size}px; height:{Size}px;")">

        @if (PreviewUrl != null || !string.IsNullOrEmpty(Value))
        {
            <img src="@(PreviewUrl ?? Value)"
                 style="width:100%; height:100%; object-fit:cover; border-radius:@(IsProfile ? "50%" : "6px");" />
        }
        else
        {
            <MudAvatar Rounded="@(!IsProfile)"
                       Style="@($"width:{Size}px; height:{Size}px; overflow:hidden;")">
                <MudIcon Icon="@DefaultIcon" Style="font-size:3rem;" />
            </MudAvatar>
        }

    </div>

    @if (!IsViewMode)
    {
        <MudStack Row="true" Spacing="1">
            <MudFileUpload T="IBrowserFile"
                           FilesChanged="HandleSelected"
                           ShowList="false"
                           ShowSize="false"
                           ShowProgress="false"
                           SuppressOnChangeWhenInvalid="true"
                           SelectedTemplate="@(file => null)">
                <CustomContent>
                    <MudIconButton OnClick="@context.OpenFilePickerAsync"
                                   Icon="@Icons.Material.Filled.Upload" />
                </CustomContent>
            </MudFileUpload>

            @if (ShowDelete && (PreviewUrl != null || !string.IsNullOrEmpty(Value)))
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                               Color="Color.Error"
                               OnClick="HandleDelete" />
            }
        </MudStack>
    }

</MudStack>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public int Size { get; set; } = 150;
    [Parameter] public bool ShowDelete { get; set; } = true;

    // ⭐ CORREGIDO: ahora IBrowserFile?
    [Parameter] public EventCallback<IBrowserFile?> OnChanged { get; set; }

    [Parameter] public bool IsProfile { get; set; } = true;
    [Parameter] public bool IsViewMode { get; set; } = false;

    private const long MaxFileSize = 10 * 1024 * 1024;
    private string? PreviewUrl;

    private IBrowserFile? _pendingFile;

    private string DefaultIcon => IsProfile ? Icons.Material.Filled.Person : Icons.Material.Filled.Image;

    private async Task HandleSelected(IBrowserFile? file)
    {
        if (file == null)
        {
            PreviewUrl = Value;
            _pendingFile = null;
            await OnChanged.InvokeAsync(null);
            return;
        }

        if (file.Size > MaxFileSize)
        {
            // Aquí puedes usar tu AlertService si quieres
            return;
        }

        _pendingFile = file;

        using var stream = file.OpenReadStream(MaxFileSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        PreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(ms.ToArray())}";

        await OnChanged.InvokeAsync(file);
    }

    private async Task HandleDelete()
    {
        PreviewUrl = null;
        _pendingFile = null;
        await OnChanged.InvokeAsync(null);
    }

    public IBrowserFile? GetPendingFile() => _pendingFile;
}
