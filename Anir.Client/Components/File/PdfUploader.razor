@using Anir.Shared.Contracts.Common
@using Anir.Web.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject FileService FileService
@inject IAlertService AlertService
@inject IJSRuntime JS

<MudPaper Outlined="true" Class="pa-4">
    
    <!-- EL SECRETO: El componente siempre está montado, pero oculto. Así no pierde el archivo. -->
    <div style="display: none;">
        <MudFileUpload T="IBrowserFile"
                       @ref="FileUploadRef"
                       Accept=".pdf,application/pdf"
                       FilesChanged="OnFileChanged" />
    </div>

    @if (isUploading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2" Style="min-height: 80px;">
            <MudText Typo="Typo.body2" Color="Color.Secondary">Subiendo PDF...</MudText>
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="w-100" />
        </MudStack>
    }
    else if (HasPdf)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Style="font-size: 3rem;" />
            
            <!-- NUEVO: Mostramos el nombre real. Si es muy largo, lo corta con "..." y muestra el nombre completo al pasar el ratón -->
            <MudText Typo="Typo.body2" Color="Color.Primary" Class="font-weight-medium text-center" Style="max-width: 100%;">
                <MudTooltip Text="@(UploadedResponse?.Name ?? "Documento sin nombre")">
                    <span style="display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;">
                        @(UploadedResponse?.Name ?? "Documento adjunto")
                    </span>
                </MudTooltip>
            </MudText>
        </MudStack>

        <MudStack Row="true" Spacing="1" Class="mt-2" Justify="Justify.Center" AlignItems="AlignItems.Center">
            
            <MudTooltip Text="Ver PDF">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                               Color="Color.Primary"
                               OnClick="OpenPdf" />
            </MudTooltip>

            @if (!IsViewMode)
            {
                <MudTooltip Text="Cambiar PDF">
                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                   Color="Color.Info"
                                   OnClick="TriggerUpload" />
                </MudTooltip>
            }

            @if (ShowDelete && !IsViewMode)
            {
                <MudTooltip Text="Eliminar PDF">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="HandleDelete" />
                </MudTooltip>
            }
        </MudStack>
    }
    else
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2" Style="min-height: 80px;">
            <MudText Typo="Typo.body2" Color="Color.Secondary">No hay PDF adjunto</MudText>

            @if (!IsViewMode)
            {
                <MudTooltip Text="Subir PDF">
                    <MudIconButton Icon="@Icons.Material.Filled.NoteAdd"
                                   Color="Color.Primary"
                                   OnClick="TriggerUpload" />
                </MudTooltip>
            }
        </MudStack>
    }

</MudPaper>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool ShowDelete { get; set; } = true;
    [Parameter] public EventCallback<FileResponse?> OnUploaded { get; set; }
    [Parameter] public bool IsViewMode { get; set; } = false;
    [Parameter] public string Folder { get; set; } = "docs";

    private const long MaxFileSize = 20 * 1024 * 1024;
    private FileResponse? UploadedResponse;
    private bool isUploading = false;
    
    // Referencia al componente oculto
    private MudFileUpload<IBrowserFile>? FileUploadRef;

    private bool HasPdf => UploadedResponse != null || !string.IsNullOrEmpty(Value);

    // Método para abrir el explorador usando la referencia
    private async Task TriggerUpload()
    {
        if (FileUploadRef != null)
        {
            await FileUploadRef.OpenFilePickerAsync();
        }
    }

    private async Task OnFileChanged(IBrowserFile file)
    {
        if (file == null) return;

        if (file.Size > MaxFileSize)
        {
            await AlertService.ShowError("Tamaño excedido", $"El PDF no puede superar {MaxFileSize / 1024 / 1024} MB.");
            return;
        }

        isUploading = true;
        StateHasChanged();

        try
        {
            var response = await FileService.UploadAsync(file, Folder);
            if (response != null)
            {
                UploadedResponse = response;
                await OnUploaded.InvokeAsync(response);
            }
            else
            {
                await CleanupAndNotify(null);
                await AlertService.ShowError("Error", "No se recibió respuesta del servidor.");
            }
        }
        catch (Exception ex)
        {
            await CleanupAndNotify(null);
            await AlertService.ShowError("Error al subir", ex.Message);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task HandleDelete()
    {
        if (UploadedResponse != null && UploadedResponse.Id > 0)
        {
            try { await FileService.DeleteAsync(UploadedResponse.Id); }
            catch (Exception ex) { await AlertService.ShowError("Error", $"No se pudo eliminar del servidor: {ex.Message}"); }
        }
        await CleanupAndNotify(null);
    }

    private async Task OpenPdf()
    {
        var url = UploadedResponse?.Url ?? Value;
        if (!string.IsNullOrEmpty(url))
        {
            await JS.InvokeVoidAsync("openPdfInNewTab", url);
        }
    }

    private async Task CleanupAndNotify(FileResponse? response)
    {
        UploadedResponse = response;
        await OnUploaded.InvokeAsync(response);
    }
}