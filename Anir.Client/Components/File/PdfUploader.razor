@using Anir.Shared.Contracts.Common
@using Anir.Web.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject FileService FileService
@inject IAlertService AlertService
@inject IJSRuntime JS

@if (!string.IsNullOrEmpty(Label))
{
    <MudText Typo="Typo.subtitle2" Class="mb-1" Color="Color.Secondary">@Label</MudText>
}

<div style="display: none;">
    <MudFileUpload T="IBrowserFile"
                   @ref="FileUploadRef"
                   Accept=".pdf,application/pdf"
                   FilesChanged="OnFileChanged" />
</div>

@if (isUploading)
{
    <MudPaper Outlined="true" Class="d-flex align-center pa-2 gap-2 rounded-lg">
        <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Size="Size.Small" />
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="flex-grow-1" Style="height: 3px;" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="flex-shrink-0">Subiendo...</MudText>
    </MudPaper>
}
else if (HasPdf)
{
    <MudPaper Outlined="true" Class="d-flex align-center pa-2 gap-2 rounded-lg overflow-hidden">
        <MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Color="Color.Error" Size="Size.Small" Class="flex-shrink-0" />

        <MudTooltip Text="@(UploadedResponse?.Name ?? "Documento")" Placement="Placement.Top">
            <MudText Typo="Typo.body2" Class="text-truncate flex-grow-1" Style="font-weight: 500;">
                @(UploadedResponse?.Name ?? "Documento adjunto")
            </MudText>
        </MudTooltip>

        @if (UploadedResponse?.Size > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="flex-shrink-0">
                @FormatSize(UploadedResponse.Size)
            </MudText>
        }

        <div class="d-flex align-center flex-shrink-0 ml-auto">
            <MudTooltip Text="Ver PDF">
                <MudIconButton Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Color="Color.Primary" OnClick="OpenPdf" />
            </MudTooltip>

            @if (!IsViewMode)
            {
                <MudTooltip Text="Cambiar">
                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Color="Color.Info" OnClick="TriggerUpload" />
                </MudTooltip>
            }

            @if (ShowDelete && !IsViewMode)
            {
                <MudTooltip Text="Eliminar">
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" OnClick="HandleDelete" />
                </MudTooltip>
            }
        </div>
    </MudPaper>
}
else if (IsViewMode)
{
    <MudPaper Outlined="true" Class="d-flex align-center pa-2 gap-2 rounded-lg">
        <MudIcon Icon="@Icons.Material.Outlined.Description" Size="Size.Small" Color="Color.Default" />
        <MudText Typo="Typo.body2" Color="Color.Default">Sin documento adjunto</MudText>
    </MudPaper>
}
else
{
    @* MudPaper no soporta OnClick, por eso envolvemos en div con @onclick *@
    <div @onclick="TriggerUpload" class="cursor-pointer">
        <MudPaper Outlined="true" Class="d-flex align-center justify-center pa-2 gap-2 rounded-lg">
            <MudIcon Icon="@Icons.Material.Outlined.CloudUpload" Size="Size.Small" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight: 500;">Subir PDF</MudText>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool ShowDelete { get; set; } = true;
    [Parameter] public EventCallback<FileResponse?> OnUploaded { get; set; }
    [Parameter] public bool IsViewMode { get; set; } = false;
    [Parameter] public string Folder { get; set; } = "docs";
    [Parameter] public string? Label { get; set; }

    private const long MaxFileSize = 20 * 1024 * 1024;
    private FileResponse? UploadedResponse;
    private bool isUploading = false;
    private MudFileUpload<IBrowserFile>? FileUploadRef;

    private bool HasPdf => UploadedResponse != null || !string.IsNullOrEmpty(Value);

    private static string FormatSize(long? bytes)
    {
        if (bytes == null || bytes <= 0) return string.Empty;
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.0} KB";
        return $"{bytes / (1024.0 * 1024.0):0.1} MB";
    }

    private async Task TriggerUpload()
    {
        if (FileUploadRef != null)
        {
            await FileUploadRef.OpenFilePickerAsync();
        }
    }

    private async Task OnFileChanged(IBrowserFile file)
    {
        if (file == null) return;

        if (file.Size > MaxFileSize)
        {
            await AlertService.ShowError("Tamaño excedido", $"El PDF no puede superar {MaxFileSize / 1024 / 1024} MB.");
            return;
        }

        isUploading = true;
        StateHasChanged();

        try
        {
            var response = await FileService.UploadAsync(file, Folder);
            if (response != null)
            {
                UploadedResponse = response;
                await OnUploaded.InvokeAsync(response);
            }
            else
            {
                await CleanupAndNotify(null);
                await AlertService.ShowError("Error", "No se recibió respuesta del servidor.");
            }
        }
        catch (Exception ex)
        {
            await CleanupAndNotify(null);
            await AlertService.ShowError("Error al subir", ex.Message);
        }
        finally
        {
            isUploading = false;
            StateHasChanged();
        }
    }

    private async Task HandleDelete()
    {
        if (UploadedResponse != null && UploadedResponse.Id > 0)
        {
            try { await FileService.DeleteAsync(UploadedResponse.Id); }
            catch (Exception ex) { await AlertService.ShowError("Error", $"No se pudo eliminar del servidor: {ex.Message}"); }
        }
        await CleanupAndNotify(null);
    }

    private async Task OpenPdf()
    {
        var url = UploadedResponse?.Url ?? Value;
        if (!string.IsNullOrEmpty(url))
        {
            await JS.InvokeVoidAsync("openPdfInNewTab", url);
        }
    }

    private async Task CleanupAndNotify(FileResponse? response)
    {
        UploadedResponse = response;
        await OnUploaded.InvokeAsync(response);
    }
}