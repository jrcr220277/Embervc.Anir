@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Color="Color.Error" Typo="Typo.h6">@Title</MudText>
    </TitleContent>

    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(Message) && !IsSameText(Title, Message))
        {
            <MudText Typo="Typo.body2" Class="mb-3">@Message</MudText>
        }

        <MudTextField @bind-Value="InputValue"
                      Placeholder="@Placeholder"
                      Immediate="true"
                      Adornment="Adornment.None"
                      Class="w-100" />
    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Default" OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirm">Confirmar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }

    [Parameter] public string Title { get; set; } = "Delete Records";
    [Parameter] public string Message { get; set; } = "Escribe el texto de confirmación:";
    [Parameter] public string Placeholder { get; set; } = "CONFIRM_DELETE_ALL";

    private string InputValue { get; set; } = string.Empty;

    void Confirm() => MudDialog?.Close(DialogResult.Ok(InputValue?.Trim()));
    void Cancel() => MudDialog?.Cancel();

    private static bool IsSameText(string? a, string? b)
    {
        if (string.IsNullOrWhiteSpace(a) && string.IsNullOrWhiteSpace(b)) return true;
        return string.Equals(a?.Trim(), b?.Trim(), StringComparison.OrdinalIgnoreCase);
    }
}
