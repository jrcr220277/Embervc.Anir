@namespace Anir.Client.Components
@using MudBlazor

<MudText Typo="Typo.h6">@Title</MudText>

<MudTable Items="@Items" Dense="true">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Nombre</MudTh>
    </HeaderContent>
    <RowTemplate Context="item">
        <MudTd>@item.Id</MudTd>
        <MudTd>@item.Name</MudTd>
    </RowTemplate>
</MudTable>

<MudButton Color="Color.Primary" OnClick="Close">Cerrar</MudButton>

@code {
    [CascadingParameter] private IDialogReference Dialog { get; set; } = default!;

    [Parameter] public string Title { get; set; } = "";
    [Parameter] public List<BlockedItem> Items { get; set; } = new();

    private void Close() => Dialog.Close();

    public class BlockedItem
    {
        public int Id { get; set; }
        public string Name { get; set; }
    }
}
