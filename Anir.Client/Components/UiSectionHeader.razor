<!-- ============================
     EJEMPLOS DE USO
 
     Encabezado normal con borde lateral Primary
     <UiSectionHeader Text="Datos de la Persona" Color="Color.Primary" />

    Encabezado con borde lateral Info
    <UiSectionHeader Text="Foto y Estado" Color="Color.Info" />

    Encabezado con borde lateral Success y raya inferior
    <UiSectionHeader Text="Descripción" Color="Color.Success" ShowBottomBorder="true" />

    Encabezado con borde lateral Warning
    <UiSectionHeader Text="Advertencias" Color="Color.Warning" />

    Encabezado con borde lateral Error
    <UiSectionHeader Text="Errores encontrados" Color="Color.Error" ShowBottomBorder="true" />
============================ -->


<MudStack Class="mb-3" Style="@BuildStyle()">
    <MudText Typo="Typo.subtitle2" Class="font-weight-semibold"
             Style="color:var(--mud-palette-textprimary); letter-spacing:0.3px;">
        @Text
    </MudText>
</MudStack>

@code {
    [Parameter] public string Text { get; set; } = string.Empty;

    /// <summary>
    /// Color del borde lateral: Primary, Info, Success, Warning, Error
    /// </summary>
    [Parameter] public Color Color { get; set; } = Color.Primary;

    /// <summary>
    /// Si quieres también mostrar una raya inferior fina
    /// </summary>
    [Parameter] public bool ShowBottomBorder { get; set; } = false;

    private string BuildStyle()
    {
        var leftBorder = $"border-left:4px solid {GetColorCss()}; padding-left:10px;";
        var bottomBorder = ShowBottomBorder ? " border-bottom:1px solid var(--mud-palette-divider); padding-bottom:4px;" : "";
        return leftBorder + bottomBorder;
    }

    private string GetColorCss()
    {
        return Color switch
        {
            Color.Primary => "var(--mud-palette-primary)",
            Color.Info => "var(--mud-palette-info)",
            Color.Success => "var(--mud-palette-success)",
            Color.Warning => "var(--mud-palette-warning)",
            Color.Error => "var(--mud-palette-error)",
            _ => "var(--mud-palette-primary)"
        };
    }
}
